{%- liquid
  assign scheme = section.settings.color_scheme | default: 'scheme-1'
-%}
<div class="color-{{ scheme }} ed-section" style="background: rgb(var(--color-background));">
  <div class="ed-container">
    {%- if section.settings.eyebrow != blank -%}
      <p class="ed-caption" style="color: var(--ed-text-mute); margin: 0 0 var(--sp-3);">{{ section.settings.eyebrow }}</p>
    {%- endif -%}
    {%- if section.settings.heading != blank -%}
      <h2 class="ed-display-m" style="margin: 0 0 var(--sp-4); max-width: 720px;">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.body != blank -%}
      <div class="ed-body-l" style="color: var(--ed-text-mute); max-width: 720px; margin-bottom: var(--sp-6);">{{ section.settings.body }}</div>
    {%- endif -%}

    <table class="ed-bulk-table">
      <thead>
        <tr>
          <th>Tier</th>
          <th>Cases</th>
          <th>Price / case</th>
          <th>Save</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        {%- for block in section.blocks -%}
          <tr {{ block.shopify_attributes }}>
            <td><strong>{{ block.settings.tier_name }}</strong></td>
            <td>{{ block.settings.cases }}</td>
            <td>{{ block.settings.price }}</td>
            <td>{%- if block.settings.save != blank %}<span style="color: var(--ed-success);">▼ {{ block.settings.save }}</span>{%- endif -%}</td>
            <td>
              {%- if block.settings.cta_label != blank -%}
                <a href="{{ block.settings.cta_link | default: '#' }}" class="ed-btn ed-btn--sm {% if forloop.last %}ed-btn--primary{% else %}ed-btn--ghost{% endif %}">{{ block.settings.cta_label }}</a>
              {%- endif -%}
            </td>
          </tr>
        {%- endfor -%}
      </tbody>
    </table>

    {%- if section.settings.footnote != blank -%}
      <p class="ed-help" style="margin-top: var(--sp-4); color: var(--ed-text-mute);">{{ section.settings.footnote }}</p>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "ED Bulk pricing table",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Bulk pricing" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Buy more, pay less — published tiers, no negotiation." },
    { "type": "richtext", "id": "body", "label": "Body", "default": "<p>Indicative pricing for thermal shipping labels (ED-TL-4X6-1K). Final per-SKU pricing on each PDP.</p>" },
    { "type": "text", "id": "footnote", "label": "Footnote", "default": "All prices include 18% GST. Free shipping pan-India on orders above ₹2,500." },
    { "type": "select", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1",
      "options": [
        { "value": "scheme-1", "label": "Paper" },
        { "value": "scheme-2", "label": "Snow" }
      ]
    }
  ],
  "blocks": [
    {
      "type": "tier",
      "name": "Tier",
      "settings": [
        { "type": "text", "id": "tier_name", "label": "Tier name", "default": "Starter" },
        { "type": "text", "id": "cases", "label": "Range", "default": "1–4 cases" },
        { "type": "text", "id": "price", "label": "Price", "default": "₹2,800" },
        { "type": "text", "id": "save", "label": "Save %", "default": "" },
        { "type": "text", "id": "cta_label", "label": "CTA label", "default": "Add to cart" },
        { "type": "url",  "id": "cta_link",  "label": "CTA link" }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "ED Bulk pricing tiers",
      "blocks": [
        { "type": "tier", "settings": { "tier_name": "Starter", "cases": "1–4 cases", "price": "₹2,800 / case", "save": "" } },
        { "type": "tier", "settings": { "tier_name": "Volume", "cases": "5–19 cases", "price": "₹2,650 / case", "save": "5%" } },
        { "type": "tier", "settings": { "tier_name": "Bulk",   "cases": "20–49 cases", "price": "₹2,500 / case", "save": "11%" } },
        { "type": "tier", "settings": { "tier_name": "Enterprise", "cases": "50+ cases", "price": "Quote", "save": "", "cta_label": "Request quote" } }
      ]
    }
  ]
}
{% endschema %}
