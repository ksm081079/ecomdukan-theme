{%- liquid
  assign _pt = section.settings.padding_top | default: 24
  assign _pb = section.settings.padding_bottom | default: 24
-%}
{% style %}
  #shopify-section-{{ section.id }} { padding-top: {{ _pt }}px !important; padding-bottom: {{ _pb }}px !important; }
{% endstyle %}
{%- liquid
  assign scheme = section.settings.color_scheme | default: 'scheme-1'
  assign min_free = settings.minimum_free_shipping | times: 100 | default: 250000
  assign progress = 0
  assign remaining = 0
  if cart.total_price < min_free
    assign progress = cart.total_price | times: 100.0 | divided_by: min_free
    assign remaining = min_free | minus: cart.total_price
  else
    assign progress = 100
  endif
-%}
<div class="color-{{ scheme }} ed-section" style="background: rgb(var(--color-background)); padding-block: var(--sp-7);">
  <div class="ed-container">
    <div style="display: flex; align-items: baseline; justify-content: space-between; gap: var(--sp-4); margin-bottom: var(--sp-6); flex-wrap: wrap; border-bottom: 1.5px solid var(--ed-ink); padding-bottom: var(--sp-4);">
      <h1 class="ed-display-m" style="margin: 0;">Cart</h1>
      <p class="ed-mono" style="color: var(--ed-text-mute); margin: 0; text-transform: uppercase; letter-spacing: .06em; font-size: 12px;">{{ cart.item_count }} {{ cart.item_count | pluralize: 'item', 'items' }}</p>
    </div>

    {%- if cart == empty -%}
      <div class="ed-card" style="text-align: center; padding: var(--sp-9) var(--sp-5);">
        <h2 class="ed-headline" style="margin: 0 0 var(--sp-3);">Cart is empty.</h2>
        <p class="ed-body" style="color: var(--ed-text-mute); margin: 0 0 var(--sp-5);">When it's full, we'll quote in 2 hours.</p>
        <a href="{{ routes.all_products_collection_url }}" class="ed-btn ed-btn--primary ed-btn--lg">Browse catalog</a>
      </div>
    {%- else -%}
      <div class="ed-cart-layout" style="display: grid; grid-template-columns: 1fr 380px; gap: var(--sp-7); align-items: start;">
        <form action="{{ routes.cart_url }}" method="post" id="ed-cart-form">
          {%- for item in cart.items -%}
            <div class="ed-cart-line" style="display: grid; grid-template-columns: 96px 1fr auto; gap: var(--sp-4); padding: var(--sp-4) 0; border-bottom: 1px solid var(--ed-border); align-items: start;">
              <a href="{{ item.url }}" style="border: 1.5px solid var(--ed-ink); border-radius: 2px; overflow: hidden; background: var(--ed-paper); display: block; aspect-ratio: 1/1;">
                {%- if item.image -%}
                  {{ item.image | image_url: width: 200 | image_tag: loading: 'lazy', alt: item.product.title, style: 'width:100%;height:100%;object-fit:cover;display:block;' }}
                {%- endif -%}
              </a>

              <div>
                <p class="ed-sku" style="margin: 0 0 4px;">{{ item.sku | default: item.variant.sku }}</p>
                <a href="{{ item.url }}" style="text-decoration: none; color: var(--ed-ink);">
                  <p class="ed-title" style="margin: 0 0 4px; font-size: 16px;">{{ item.product.title }}</p>
                </a>
                {%- unless item.variant.title contains 'Default' -%}
                  <p class="ed-body-s" style="color: var(--ed-text-mute); margin: 0 0 var(--sp-3);">{{ item.variant.title }}</p>
                {%- endunless -%}

                <div style="display: inline-grid; grid-template-columns: 36px 60px 36px; border: 1.5px solid var(--ed-ink); border-radius: 2px;">
                  <a href="{{ item.url_to_remove }}" aria-label="Decrease" style="text-align: center; padding: 8px 0; text-decoration: none; color: var(--ed-ink); border-right: 1.5px solid var(--ed-ink); font-family: var(--font-ed-mono);" data-cart-remove>−</a>
                  <input type="number" name="updates[{{ item.key }}]" value="{{ item.quantity }}" min="0" class="ed-input" style="border: 0; text-align: center; padding: 8px 0; font-family: var(--font-ed-mono);">
                  <button type="submit" name="update" aria-label="Update" style="background: var(--ed-snow); border: 0; border-left: 1.5px solid var(--ed-ink); cursor: pointer; padding: 8px 0; font-family: var(--font-ed-mono);">+</button>
                </div>
              </div>

              <div style="text-align: right;">
                <p class="ed-mono" style="margin: 0 0 4px; font-size: 16px; font-weight: 600;">{{ item.final_line_price | money }}</p>
                {%- if item.original_line_price != item.final_line_price -%}
                  <p class="ed-mono" style="margin: 0; color: var(--ed-text-mute); font-size: 12px; text-decoration: line-through;">{{ item.original_line_price | money }}</p>
                {%- endif -%}
                <a href="{{ item.url_to_remove }}" class="ed-mono" style="font-size: 11px; color: var(--ed-error); text-transform: uppercase; letter-spacing: .06em; text-decoration: none; display: inline-block; margin-top: var(--sp-3);">Remove</a>
              </div>
            </div>
          {%- endfor -%}

          {%- if settings.show_cart_note -%}
            <div style="padding-top: var(--sp-5);">
              <label for="ed-cart-note" class="ed-label">Order note</label>
              <textarea id="ed-cart-note" name="note" class="ed-textarea" placeholder="GST notes, PO number, delivery instructions…">{{ cart.note }}</textarea>
            </div>
          {%- endif -%}
        </form>

        <aside class="ed-cart-summary" style="position: sticky; top: 24px;">
          <div class="ed-card" style="padding: var(--sp-5);">
            {%- if settings.show_shipping_bar -%}
              <div style="margin-bottom: var(--sp-5);">
                <div class="ed-progress"><div class="ed-progress__fill" style="width: {{ progress }}%;"></div></div>
                <p class="ed-mono" style="margin: 0; font-size: 12px; color: var(--ed-text-mute); text-transform: uppercase; letter-spacing: .04em;">
                  {%- if remaining > 0 -%}
                    {{ remaining | money }} away from free shipping
                  {%- else -%}
                    ✓ Free shipping unlocked
                  {%- endif -%}
                </p>
              </div>
            {%- endif -%}

            <table class="ed-spec" style="margin-bottom: var(--sp-4);">
              <tbody>
                <tr><th>Subtotal</th><td style="text-align: right;">{{ cart.items_subtotal_price | money }}</td></tr>
                {%- if cart.total_discount > 0 -%}
                  <tr><th>Discount</th><td style="text-align: right; color: var(--ed-success);">−{{ cart.total_discount | money }}</td></tr>
                {%- endif -%}
                <tr><th>Shipping</th><td style="text-align: right; color: var(--ed-text-mute);">Calculated at checkout</td></tr>
                <tr><th style="font-weight: 600; color: var(--ed-ink); font-size: 13px;">Total</th><td style="text-align: right; font-size: 18px; font-weight: 600; color: var(--ed-ink);">{{ cart.total_price | money }}</td></tr>
              </tbody>
            </table>

            <p class="ed-help" style="margin: 0 0 var(--sp-4);">GST will be calculated and added at checkout. Enter your GSTIN on the billing step for a GST-compliant invoice.</p>

            <button type="submit" form="ed-cart-form" name="checkout" class="ed-btn ed-btn--primary ed-btn--block ed-btn--lg">Checkout — {{ cart.total_price | money }}</button>

            <a href="{{ section.settings.quote_url | default: '/pages/request-quote' }}?cart={{ cart.item_count }}" class="ed-btn--link" style="display: block; text-align: center; margin-top: var(--sp-4); font-family: var(--font-ed-body); font-weight: 600; font-size: 13px;">Request a quote on this cart →</a>
          </div>
        </aside>
      </div>
    {%- endif -%}
  </div>
</div>

<style>
  @media (max-width: 989px) {
    .ed-cart-layout { grid-template-columns: 1fr !important; }
    .ed-cart-summary { position: static !important; }
  }
  @media (max-width: 599px) {
    .ed-cart-line { grid-template-columns: 64px 1fr !important; }
    .ed-cart-line > div:last-child { grid-column: 1 / -1; text-align: left !important; }
  }
</style>

{% schema %}
{
  "name": "ED Cart",
  "tag": "section",
  "settings": [
    {
      "type": "url",
      "id": "quote_url",
      "label": "Quote page URL"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1",
      "options": [
        {
          "value": "scheme-1",
          "label": "Paper"
        },
        {
          "value": "scheme-2",
          "label": "Snow"
        }
      ]
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding (px)",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 24,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding (px)",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 24,
      "unit": "px"
    }
  ],
  "enabled_on": {
    "templates": [
      "cart"
    ]
  }
}
{% endschema %}
