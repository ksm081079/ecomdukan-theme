{%- liquid
  assign scheme = section.settings.color_scheme | default: 'scheme-1'
-%}
<div class="color-{{ scheme }} ed-section" style="background: rgb(var(--color-background));">
  <div class="ed-container" style="max-width: 760px;">
    <div style="text-align: center; margin-bottom: var(--sp-7);">
      {%- if section.settings.eyebrow != blank -%}
        <p class="ed-caption" style="color: var(--ed-text-mute); margin: 0 0 var(--sp-3);">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      <h1 class="ed-display-l" style="margin: 0 0 var(--sp-4);">{{ section.settings.heading | default: 'Request a sample pack' }}</h1>
      {%- if section.settings.body != blank -%}
        <div class="ed-body-l" style="color: var(--ed-text-mute);">{{ section.settings.body }}</div>
      {%- endif -%}
    </div>

    <div class="ed-card" style="padding: var(--sp-6);">
      {%- form 'contact', class: 'ed-form', id: 'ed-sample-form' -%}
        <input type="hidden" name="contact[tags]" value="sample">
        <input type="hidden" name="contact[subject]" value="Sample pack request">

        <div class="ed-row">
          <div>
            <label class="ed-label" for="s-name">Name</label>
            <input id="s-name" type="text" name="contact[name]" class="ed-input" required>
          </div>
          <div>
            <label class="ed-label" for="s-company">Company</label>
            <input id="s-company" type="text" name="contact[Company]" class="ed-input" required>
          </div>
        </div>

        <div class="ed-row">
          <div>
            <label class="ed-label" for="s-email">Email</label>
            <input id="s-email" type="email" name="contact[email]" class="ed-input" required>
          </div>
          <div>
            <label class="ed-label" for="s-phone">Phone</label>
            <input id="s-phone" type="tel" name="contact[Phone]" class="ed-input">
          </div>
        </div>

        <div>
          <label class="ed-label" for="s-address">Shipping address (full)</label>
          <textarea id="s-address" name="contact[Shipping address]" class="ed-textarea" placeholder="Door no, building, street, area, city, PIN" required></textarea>
        </div>

        <div>
          <label class="ed-label" for="s-want">What would you like to sample? (max 3)</label>
          <textarea id="s-want" name="contact[Samples wanted]" class="ed-textarea" placeholder="e.g. 4×6 thermal labels · kraft mailers · 80gsm A4 sheets" required></textarea>
        </div>

        <button type="submit" class="ed-btn ed-btn--primary ed-btn--lg ed-btn--block">Send my sample pack</button>

        {%- if form.posted_successfully? -%}
          <p class="ed-form-success">Got it — pack ships in 2 business days. We'll send the AWB to your email.</p>
        {%- elsif form.errors -%}
          <p class="ed-err">{{ form.errors | default_errors }}</p>
        {%- endif -%}
      {%- endform -%}

      <p class="ed-help" style="text-align: center; margin-top: var(--sp-4);">Free. Ships in 2 business days. One sample pack per business per quarter.</p>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "ED Sample-pack form",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Sample pack · free" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Try before you commit" },
    { "type": "richtext", "id": "body", "label": "Body", "default": "<p>Pick up to 3 SKUs you'd like to feel and test. We ship a sample pack — free, in 2 business days.</p>" },
    { "type": "select", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1",
      "options": [
        { "value": "scheme-1", "label": "Paper" },
        { "value": "scheme-2", "label": "Snow" }
      ]
    }
  ],
  "presets": [{ "name": "ED Sample-pack form" }]
}
{% endschema %}
