{%- liquid
  assign scheme = section.settings.color_scheme | default: 'scheme-1'
-%}
<div class="color-{{ scheme }} ed-section" style="background: rgb(var(--color-background));">
  <div class="ed-container" style="max-width: 880px;">
    <div style="text-align: center; margin-bottom: var(--sp-7);">
      {%- if section.settings.eyebrow != blank -%}
        <p class="ed-caption" style="color: var(--ed-text-mute); margin: 0 0 var(--sp-3);">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      <h1 class="ed-display-l" style="margin: 0 0 var(--sp-4);">{{ section.settings.heading | default: 'Request a quote' }}</h1>
      {%- if section.settings.body != blank -%}
        <div class="ed-body-l" style="color: var(--ed-text-mute); max-width: 600px; margin: 0 auto;">{{ section.settings.body }}</div>
      {%- endif -%}
    </div>

    <div class="ed-card" style="padding: var(--sp-7);">
      {%- form 'contact', class: 'ed-form', id: 'ed-quote-form' -%}
        <input type="hidden" name="contact[tags]" value="quote">
        <input type="hidden" name="contact[subject]" value="New quote request">
        <input type="hidden" name="contact[Form type]" value="Quote">

        <div class="ed-row">
          <div>
            <label class="ed-label" for="q-company">Company</label>
            <input id="q-company" type="text" name="contact[Company]" class="ed-input" required>
          </div>
          <div>
            <label class="ed-label" for="q-name">Contact name</label>
            <input id="q-name" type="text" name="contact[name]" class="ed-input" required>
          </div>
        </div>

        <div class="ed-row">
          <div>
            <label class="ed-label" for="q-email">Email</label>
            <input id="q-email" type="email" name="contact[email]" class="ed-input" required autocomplete="email">
          </div>
          <div>
            <label class="ed-label" for="q-phone">Phone (WhatsApp preferred)</label>
            <input id="q-phone" type="tel" name="contact[Phone]" class="ed-input" autocomplete="tel">
          </div>
        </div>

        <div class="ed-row">
          <div>
            <label class="ed-label" for="q-gstin">GSTIN <span style="color: var(--ed-text-mute); font-weight: 400; text-transform: none; letter-spacing: 0;">(optional)</span></label>
            <input id="q-gstin" type="text" name="contact[GSTIN]" class="ed-input" placeholder="27ABCDE1234F1Z5">
          </div>
          <div>
            <label class="ed-label" for="q-need-by">Required by</label>
            <input id="q-need-by" type="date" name="contact[Required by]" class="ed-input">
          </div>
        </div>

        <div>
          <label class="ed-label" for="q-cadence">Cadence</label>
          <select id="q-cadence" name="contact[Cadence]" class="ed-select">
            <option>One-off order</option>
            <option>Monthly</option>
            <option>Quarterly</option>
            <option>Ad-hoc / undecided</option>
          </select>
        </div>

        <div>
          <label class="ed-label" for="q-products">What do you need?</label>
          <textarea id="q-products" name="contact[Products & quantity]" class="ed-textarea" placeholder="e.g. 50 cases of 4×6 thermal labels (1,000/roll, 4 rolls/case) every month + 200 kraft mailers" required></textarea>
        </div>

        <div>
          <label class="ed-label" for="q-notes">Anything else?</label>
          <textarea id="q-notes" name="contact[Notes]" class="ed-textarea" placeholder="NET-30 needs, sample requirements, printer model, brand specs…"></textarea>
        </div>

        <button type="submit" class="ed-btn ed-btn--primary ed-btn--lg ed-btn--block">Send quote request</button>

        {%- if form.posted_successfully? -%}
          <p class="ed-form-success">Got it — we'll reply within 2 business hours, {{ settings.ed_support_hours | default: 'Mon–Sat · 9 AM – 7 PM IST' }}.</p>
        {%- elsif form.errors -%}
          <p class="ed-err">{{ form.errors | default_errors }}</p>
        {%- endif -%}
      {%- endform -%}

      <p class="ed-help" style="text-align: center; margin-top: var(--sp-4);">We reply in <strong>2 business hours</strong>. {{ settings.ed_support_hours | default: 'Mon–Sat · 9 AM – 7 PM IST' }}.</p>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "ED Quote form",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Quote" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Request a bulk quote" },
    { "type": "richtext", "id": "body", "label": "Body", "default": "<p>Tell us what you need. We reply with pricing, lead time, and a one-page proposal — usually within 2 business hours.</p>" },
    { "type": "select", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1",
      "options": [
        { "value": "scheme-1", "label": "Paper" },
        { "value": "scheme-2", "label": "Snow" }
      ]
    }
  ],
  "presets": [{ "name": "ED Quote form" }]
}
{% endschema %}
