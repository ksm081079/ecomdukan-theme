{%- liquid
  assign scheme = section.settings.color_scheme | default: 'scheme-1'
  assign limit = section.settings.product_count | default: 8
  assign products = collections[section.settings.collection].products
  assign fallback_used = false
  if products.size == 0
    assign products = collections.all.products
    assign fallback_used = true
  endif
  assign cols_desktop = section.settings.columns_desktop | default: 4
  assign cols_mobile = section.settings.columns_mobile | default: 2
-%}
<div class="color-{{ scheme }} ed-section" style="background: rgb(var(--color-background));">
  <div class="ed-container">
    <div style="display: flex; align-items: baseline; justify-content: space-between; margin-bottom: var(--sp-6); gap: var(--sp-4); flex-wrap: wrap;">
      <div>
        {%- if section.settings.eyebrow != blank -%}
          <p class="ed-caption" style="color: var(--ed-text-mute); margin: 0 0 var(--sp-2);">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="ed-display-m" style="margin: 0;">{{ section.settings.heading }}</h2>
        {%- endif -%}
      </div>
      {%- if section.settings.collection != blank -%}
        <a href="{{ collections[section.settings.collection].url }}" class="ed-btn--link" style="font-family: var(--font-ed-body); font-weight: 600; font-size: 14px;">View all →</a>
      {%- endif -%}
    </div>

    {%- if fallback_used -%}
      <p class="ed-caption" style="color: var(--ed-text-mute); margin: 0 0 var(--sp-3); font-size: 11px;">Showing recent products · pick a collection in section settings to curate.</p>
    {%- endif -%}

    <div style="display: grid; grid-template-columns: repeat({{ cols_desktop }}, 1fr); gap: var(--sp-4);" class="ed-product-grid" data-cols-mobile="{{ cols_mobile }}">
      {%- for product in products limit: limit -%}
        {%- render 'ed-product-card', product: product -%}
      {%- else -%}
        {%- for i in (1..limit) -%}
          <div class="ed-card" style="aspect-ratio: 1/1.4;"><p class="ed-caption" style="color: var(--ed-mute);">Add products to your store to see them here.</p></div>
        {%- endfor -%}
      {%- endfor -%}
    </div>
  </div>
</div>

<style>
  @media (max-width: 989px) { .ed-product-grid { grid-template-columns: repeat({{ cols_mobile }}, 1fr) !important; gap: 12px !important; } }
  @media (max-width: 599px) { .ed-product-grid { grid-template-columns: repeat({{ cols_mobile }}, 1fr) !important; gap: 10px !important; } }
</style>

{% schema %}
{
  "name": "ED Best-sellers carousel",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Best-sellers" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Moving fast this week" },
    { "type": "collection", "id": "collection", "label": "Collection (leave blank to show recent products)" },
    { "type": "range", "id": "product_count", "label": "Products to show", "min": 4, "max": 12, "step": 2, "default": 8 },
    { "type": "range", "id": "columns_desktop", "label": "Desktop columns", "min": 2, "max": 6, "step": 1, "default": 4 },
    { "type": "select", "id": "columns_mobile", "label": "Mobile columns", "default": "2",
      "options": [
        { "value": "1", "label": "1 per row" },
        { "value": "2", "label": "2 per row" }
      ]
    },
    { "type": "select", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1",
      "options": [
        { "value": "scheme-1", "label": "Paper" },
        { "value": "scheme-2", "label": "Snow" }
      ]
    }
  ],
  "presets": [{ "name": "ED Best-sellers" }]
}
{% endschema %}
