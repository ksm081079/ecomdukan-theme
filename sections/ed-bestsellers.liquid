{%- liquid
  assign _pt = section.settings.padding_top | default: 24
  assign _pb = section.settings.padding_bottom | default: 24
-%}
{% style %}
  #shopify-section-{{ section.id }} { padding-top: {{ _pt }}px !important; padding-bottom: {{ _pb }}px !important; }
{% endstyle %}
{%- liquid
  assign scheme = section.settings.color_scheme | default: 'scheme-1'
  assign limit = section.settings.product_count | default: 8
  assign products = collections[section.settings.collection].products
  assign fallback_used = false
  if products.size == 0
    assign products = collections.all.products
    assign fallback_used = true
  endif
  assign cols_desktop = section.settings.columns_desktop | default: 4
  assign cols_mobile = section.settings.columns_mobile | default: 2
-%}
<div class="color-{{ scheme }} ed-section ed-bs" style="background: rgb(var(--color-background));">
  <div class="ed-container">
    <div class="ed-bs__header">
      <div class="ed-bs__head-text">
        {%- if section.settings.eyebrow != blank -%}
          <p class="ed-caption ed-bs__eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="ed-display-m ed-bs__h">{{ section.settings.heading }}</h2>
        {%- endif -%}
      </div>
      {%- if section.settings.show_view_all and section.settings.collection != blank -%}
        <a href="{{ collections[section.settings.collection].url }}" class="ed-bs__view-all-top" data-action="view_all_top">
          <span>{{ section.settings.view_all_label | default: 'View all' }}</span>
          <span aria-hidden="true">→</span>
        </a>
      {%- endif -%}
    </div>

    {%- if fallback_used -%}
      <p class="ed-caption" style="color: var(--ed-text-mute); margin: 0 0 var(--sp-3); font-size: 11px;">Showing recent products · pick a collection in section settings to curate.</p>
    {%- endif -%}

    {%- assign layout_mode = section.settings.layout | default: 'carousel' -%}

    {%- if layout_mode == 'carousel' -%}
      <div class="ed-bs-carousel-wrap">
        <button type="button" class="ed-bs-nav ed-bs-nav--prev" data-bs-nav="prev" aria-label="Previous">‹</button>
        <div class="ed-bs-strip" data-bs-strip>
          {%- for product in products limit: limit -%}
            <div class="ed-bs-cell">{%- render 'ed-product-card', product: product -%}</div>
          {%- else -%}
            {%- for i in (1..limit) -%}
              <div class="ed-bs-cell"><div class="ed-card" style="aspect-ratio: 1/1.4;"><p class="ed-caption" style="color: var(--ed-mute);">Add products to your store to see them here.</p></div></div>
            {%- endfor -%}
          {%- endfor -%}
        </div>
        <button type="button" class="ed-bs-nav ed-bs-nav--next" data-bs-nav="next" aria-label="Next">›</button>
      </div>
    {%- else -%}
      <div style="display: grid; grid-template-columns: repeat({{ cols_desktop }}, 1fr); gap: var(--sp-4);" class="ed-product-grid" data-cols-mobile="{{ cols_mobile }}">
        {%- for product in products limit: limit -%}
          {%- render 'ed-product-card', product: product -%}
        {%- else -%}
          {%- for i in (1..limit) -%}
            <div class="ed-card" style="aspect-ratio: 1/1.4;"><p class="ed-caption" style="color: var(--ed-mute);">Add products to your store to see them here.</p></div>
          {%- endfor -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- if section.settings.show_view_all_bottom and section.settings.collection != blank -%}
      <div class="ed-bs__view-all-bottom-wrap">
        <a href="{{ collections[section.settings.collection].url }}" class="ed-bs__view-all-bottom" data-action="view_all_bottom">
          <span>{{ section.settings.view_all_label | default: 'View all' }}</span>
          <span aria-hidden="true">→</span>
        </a>
      </div>
    {%- endif -%}
  </div>
</div>

<style>
  /* Header with view-all link */
  .ed-bs__header {
    display: flex; align-items: baseline; justify-content: space-between;
    gap: 12px;
    margin-bottom: 20px;
    flex-wrap: wrap;
  }
  .ed-bs__head-text { min-width: 0; flex: 1 1 auto; }
  .ed-bs__eyebrow { color: var(--ed-text-mute, #5C6068); margin: 0 0 6px; }
  .ed-bs__h { margin: 0; }
  .ed-bs__view-all-top {
    display: inline-flex; align-items: center; gap: 6px;
    font-family: "Inter", sans-serif; font-weight: 600; font-size: 14px;
    color: var(--ed-ink, #0A0B0E);
    text-decoration: none;
    border-bottom: 1.5px solid var(--ed-ink, #0A0B0E);
    padding-bottom: 1px;
    flex-shrink: 0;
    transition: color 120ms, border-color 120ms;
  }
  .ed-bs__view-all-top:hover { color: var(--ed-electric, #1E5FFF); border-color: var(--ed-electric, #1E5FFF); }

  /* Bottom "View all" big CTA */
  .ed-bs__view-all-bottom-wrap {
    margin-top: 28px;
    text-align: center;
  }
  .ed-bs__view-all-bottom {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 12px 28px;
    background: transparent;
    border: 1.5px solid var(--ed-ink, #0A0B0E);
    border-radius: 8px;
    font-family: "Inter", sans-serif; font-weight: 600; font-size: 14px;
    color: var(--ed-ink, #0A0B0E);
    text-decoration: none;
    transition: background 120ms, color 120ms;
  }
  .ed-bs__view-all-bottom:hover {
    background: var(--ed-ink, #0A0B0E);
    color: var(--ed-paper, #F4F0E8);
  }
  @media (max-width: 749px) {
    .ed-bs__header { margin-bottom: 14px; gap: 8px; }
    .ed-bs__view-all-top { font-size: 12px; }
    .ed-bs__view-all-bottom { padding: 10px 22px; font-size: 13px; width: auto; }
    .ed-bs__view-all-bottom-wrap { margin-top: 18px; }
  }

  /* Grid mode */
  @media (max-width: 989px) { .ed-product-grid { grid-template-columns: repeat({{ cols_mobile }}, 1fr) !important; gap: 12px !important; } }
  @media (max-width: 599px) { .ed-product-grid { grid-template-columns: repeat({{ cols_mobile }}, 1fr) !important; gap: 10px !important; } }

  /* Carousel mode */
  .ed-bs-carousel-wrap { position: relative; }
  .ed-bs-strip {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: minmax(220px, 1fr);
    gap: 14px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
    padding: 4px 2px 12px;
  }
  .ed-bs-strip::-webkit-scrollbar { display: none; }
  .ed-bs-cell { scroll-snap-align: start; min-width: 0; }
  .ed-bs-cell .ed-product-card { height: 100%; }

  @media (min-width: 990px) {
    .ed-bs-strip { grid-auto-columns: minmax(0, calc((100% - 14px * 3) / 4)); }
  }
  @media (max-width: 989px) {
    .ed-bs-strip { grid-auto-columns: minmax(180px, 46%); gap: 12px; }
  }
  @media (max-width: 599px) {
    .ed-bs-strip { grid-auto-columns: 78%; gap: 10px; }
  }

  .ed-bs-nav {
    position: absolute; top: 35%; transform: translateY(-50%);
    width: 36px; height: 36px; border-radius: 50%;
    background: var(--ed-snow, #FBFAF6);
    border: 1.5px solid var(--ed-ink, #0A0B0E);
    color: var(--ed-ink, #0A0B0E);
    font-size: 20px; font-weight: 600; line-height: 1;
    cursor: pointer; z-index: 3;
    display: none;
  }
  .ed-bs-nav--prev { left: -18px; }
  .ed-bs-nav--next { right: -18px; }
  @media (min-width: 750px) {
    .ed-bs-nav { display: inline-flex; align-items: center; justify-content: center; }
  }
  .ed-bs-nav:hover { background: var(--ed-ink, #0A0B0E); color: var(--ed-paper, #F4F0E8); }
</style>

<script>
  document.querySelectorAll('[data-bs-nav]').forEach(function(btn) {
    btn.addEventListener('click', function() {
      const strip = btn.parentElement.querySelector('[data-bs-strip]');
      if (!strip) return;
      const dir = btn.dataset.bsNav === 'next' ? 1 : -1;
      const cell = strip.querySelector('.ed-bs-cell');
      const step = (cell ? cell.offsetWidth + 14 : strip.clientWidth) * 1;
      strip.scrollBy({ left: step * dir, behavior: 'smooth' });
      if (window.posthog) try { posthog.capture('bestsellers_scroll', { direction: btn.dataset.bsNav }); } catch (e) {}
    });
  });
</script>

{% schema %}
{
  "name": "ED Best-sellers carousel",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Best-sellers"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Moving fast this week"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection (leave blank to show recent products)"
    },
    {
      "type": "range",
      "id": "product_count",
      "label": "Products to show",
      "min": 4,
      "max": 16,
      "step": 1,
      "default": 8
    },
    {
      "type": "header",
      "content": "View all link"
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show 'View all' link in header (top right)",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_view_all_bottom",
      "label": "Show 'View all' button under grid",
      "default": true
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "View-all label",
      "default": "View all"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "default": "grid",
      "options": [
        {
          "value": "grid",
          "label": "Static grid"
        },
        {
          "value": "carousel",
          "label": "Horizontal carousel"
        }
      ]
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Desktop columns (grid only)",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 4
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Mobile columns (grid only)",
      "default": "2",
      "options": [
        {
          "value": "1",
          "label": "1 per row"
        },
        {
          "value": "2",
          "label": "2 per row"
        },
        {
          "value": "3",
          "label": "3 per row"
        }
      ]
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1",
      "options": [
        {
          "value": "scheme-1",
          "label": "Paper"
        },
        {
          "value": "scheme-2",
          "label": "Snow"
        }
      ]
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding (px)",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 24,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding (px)",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 24,
      "unit": "px"
    }
  ],
  "presets": [
    {
      "name": "ED Best-sellers"
    }
  ]
}
{% endschema %}
