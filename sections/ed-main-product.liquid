{%- comment -%}
  Ecomdukan PDP — spec-led, bulk-buyer first.
  Reads metafields under `specs.*`, `pricing.tiers`, `lead.*`.
{%- endcomment -%}

<link rel="stylesheet" href="{{ 'ed-pdp.css' | asset_url }}">
<script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>

{%- liquid
  assign variant = product.selected_or_first_available_variant
  assign sku = variant.sku | default: product.sku
  assign gsm = product.metafields.specs.gsm.value
  assign dims = product.metafields.specs.dimensions_mm.value
  assign pack = product.metafields.specs.pack_qty.value
  assign case_qty = product.metafields.specs.case_qty.value
  assign core = product.metafields.specs.core_size.value
  assign printers = product.metafields.specs.printer_compat.value
  assign tiers = product.metafields.pricing.tiers.value
  assign dcs = product.metafields.lead.in_stock_at.value
  assign sample = product.metafields.lead.sample_available.value
-%}

<div class="color-{{ section.settings.color_scheme | default: 'scheme-1' }} ed-section" style="background: rgb(var(--color-background)); padding-block: var(--sp-5);">
  <div class="ed-container">
    {%- comment -%} Breadcrumb {%- endcomment -%}
    {%- if section.settings.show_breadcrumb -%}
      <nav class="ed-mono" style="font-size: 12px; color: var(--ed-text-mute); margin-bottom: var(--sp-5); text-transform: uppercase; letter-spacing: .06em;">
        <a href="{{ routes.root_url }}" style="color: inherit; text-decoration: none;">Home</a>
        {%- if collection -%}
          <span class="ed-foot-meta__dot"> › </span>
          <a href="{{ collection.url }}" style="color: inherit; text-decoration: none;">{{ collection.title }}</a>
        {%- endif -%}
        <span class="ed-foot-meta__dot"> › </span>
        <span style="color: var(--ed-ink);">{{ product.title }}</span>
      </nav>
    {%- endif -%}

    <div class="ed-pdp-grid">
      {%- comment -%} Media gallery — left vertical thumb rail + main stage (11-may "thumbnail_left" layout) {%- endcomment -%}
      <div class="ed-pdp__media ed-gallery" data-ed-gallery>
        {%- if product.media.size > 0 -%}
          {%- assign featured = product.selected_or_first_available_variant.featured_media | default: product.featured_media -%}
          <div class="ed-gallery__inner">
            {%- if product.media.size > 1 -%}
              <div class="ed-gallery__thumbs" data-ed-gallery-thumbs role="tablist" aria-label="Product images">
                {%- for media in product.media -%}
                  <button type="button" class="ed-gallery__thumb{% if media.id == featured.id %} is-active{% endif %}" data-ed-thumb="{{ media.id }}" role="tab" aria-selected="{% if media.id == featured.id %}true{% else %}false{% endif %}" aria-label="View image {{ forloop.index }}">
                    {{ media.preview_image | image_url: width: 240 | image_tag: loading: 'lazy', widths: '120, 200, 240', sizes: '80px', alt: media.alt | default: product.title, class: 'ed-gallery__thumb-img' }}
                    {%- if media.media_type == 'video' or media.media_type == 'external_video' -%}
                      <span class="ed-gallery__thumb-badge" aria-hidden="true">▶</span>
                    {%- elsif media.media_type == 'model' -%}
                      <span class="ed-gallery__thumb-badge" aria-hidden="true">3D</span>
                    {%- endif -%}
                  </button>
                {%- endfor -%}
              </div>
            {%- endif -%}
            <div class="ed-gallery__stage" data-ed-gallery-stage>
              {%- for media in product.media -%}
                <div class="ed-gallery__slide{% if media.id == featured.id %} is-active{% endif %}" data-ed-media-id="{{ media.id }}" data-media-type="{{ media.media_type }}">
                  {%- case media.media_type -%}
                    {%- when 'image' -%}
                      {{ media | image_url: width: 1600 | image_tag: loading: 'lazy', widths: '480, 720, 960, 1200, 1600', sizes: '(min-width: 990px) 600px, 100vw', alt: media.alt | default: product.title, class: 'ed-gallery__img' }}
                    {%- when 'video', 'external_video' -%}
                      {{ media | media_tag: image_size: '1600x', autoplay: false, loop: false, controls: true, preload: 'metadata' }}
                    {%- when 'model' -%}
                      {{ media | media_tag: image_size: '1600x', toggleable: true }}
                    {%- else -%}
                      {{ media | media_tag }}
                  {%- endcase -%}
                </div>
              {%- endfor -%}
              {%- if product.media.size > 1 -%}
                <button type="button" class="ed-gallery__nav ed-gallery__nav--prev" aria-label="Previous image" data-ed-gallery-prev>‹</button>
                <button type="button" class="ed-gallery__nav ed-gallery__nav--next" aria-label="Next image" data-ed-gallery-next>›</button>
                <span class="ed-gallery__counter" aria-live="polite"><span data-ed-gallery-current>1</span> / {{ product.media.size }}</span>
              {%- endif -%}
            </div>
          </div>
        {%- else -%}
          <div class="ed-gallery__inner">
            <div class="ed-gallery__stage ed-gallery__placeholder">
              <img src="{{ 'ed-mark.svg' | asset_url }}" alt="" class="ed-gallery__placeholder-img">
            </div>
          </div>
        {%- endif -%}
      </div>

      {%- comment -%} Info column — Rentmojo-style stacked cards {%- endcomment -%}
      <div class="ed-pdp__info ed-rm">
        <h1 class="ed-rm__title">{{ product.title }}</h1>

        {%- comment -%} Price + stock + rating card {%- endcomment -%}
        <div class="ed-rm-card ed-rm-price-card">
          <div class="ed-rm-price-card__row">
            <div class="ed-rm-price-card__amount">
              <span class="ed-rm-price-card__big">{{ variant.price | money }}</span>
              {%- if variant.compare_at_price and variant.compare_at_price > variant.price -%}
                <s class="ed-rm-price-card__compare">{{ variant.compare_at_price | money }}</s>
                {%- assign pct = variant.compare_at_price | minus: variant.price | times: 100 | divided_by: variant.compare_at_price -%}
                <span class="ed-rm-price-card__off">−{{ pct }}%</span>
              {%- endif -%}
              {%- if section.settings.price_unit_label != blank -%}
                <span class="ed-rm-price-card__unit">/{{ section.settings.price_unit_label }}</span>
              {%- endif -%}
            </div>
            {%- if dims -%}
              <span class="ed-rm-pill">{{ dims }}</span>
            {%- endif -%}
          </div>
          <div class="ed-rm-price-card__meta">
            {%- if product.metafields.reviews.rating.value -%}
              <span class="ed-rm-rating">★ {{ product.metafields.reviews.rating.value }}</span>
            {%- endif -%}
            {%- if product.metafields.reviews.rating_count -%}
              <span class="ed-rm-meta-item">👤 {{ product.metafields.reviews.rating_count }} reviews</span>
            {%- endif -%}
            {%- if product.available -%}
              <span class="ed-rm-meta-item">📦 {{ section.settings.delivery_promise | default: 'Same-day dispatch' }}</span>
            {%- endif -%}
          </div>

          {%- comment -%} Social proof: X sold today · Y viewing now {%- endcomment -%}
          {%- if section.settings.show_social_proof -%}
            <div class="ed-rm-social" data-ed-social>
              {%- if section.settings.sold_values != blank -%}
                <span class="ed-rm-social__item ed-rm-social__sold">
                  <span class="ed-rm-social__dot" aria-hidden="true"></span>
                  <strong data-ed-sold>0</strong> sold in last 24h
                </span>
              {%- endif -%}
              {%- if section.settings.viewing_min > 0 -%}
                <span class="ed-rm-social__item ed-rm-social__viewing">
                  <span class="ed-rm-social__pulse" aria-hidden="true"></span>
                  <strong data-ed-viewing>0</strong> viewing now
                </span>
              {%- endif -%}
            </div>
          {%- endif -%}
        </div>

        {%- comment -%} Available offers strip (11-may style — 3 coupon cards with copy) {%- endcomment -%}
        {%- if section.settings.offer_1_code != blank or section.settings.offer_2_code != blank or section.settings.offer_3_code != blank -%}
          <div class="ed-offers">
            <p class="ed-offers__title">{{ section.settings.offers_heading | default: 'Available offers' }}</p>
            <div class="ed-offers__row">
              {%- for i in (1..3) -%}
                {%- assign h_key = 'offer_' | append: i -%}
                {%- assign s_key = 'offer_' | append: i | append: '_tagline' -%}
                {%- assign c_key = 'offer_' | append: i | append: '_code' -%}
                {%- assign h = section.settings[h_key] -%}
                {%- assign s = section.settings[s_key] -%}
                {%- assign c = section.settings[c_key] -%}
                {%- if c != blank -%}
                  <div class="ed-offer">
                    <span class="ed-offer__head">{{ h }}</span>
                    {%- if s != blank -%}<span class="ed-offer__sub">{{ s }}</span>{%- endif -%}
                    <div class="ed-offer__foot">
                      <span class="ed-offer__code">Code: <strong>{{ c }}</strong></span>
                      <button type="button" class="ed-offer__copy" data-ed-copy="{{ c }}" aria-label="Copy {{ c }}">
                        <svg width="16" height="16" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M14.999 6.667H8.333a1.667 1.667 0 0 0-1.667 1.667V15a1.667 1.667 0 0 0 1.667 1.667h6.666A1.667 1.667 0 0 0 16.667 15V8.334a1.667 1.667 0 0 0-1.667-1.667Z" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"/><path d="M13.334 6.667V5A1.667 1.667 0 0 0 11.667 3.333H5A1.667 1.667 0 0 0 3.333 5v6.667A1.667 1.667 0 0 0 5 13.333h1.666" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"/></svg>
                      </button>
                    </div>
                  </div>
                {%- endif -%}
              {%- endfor -%}
            </div>
          </div>
        {%- endif -%}

        {%- comment -%} Tier pricing — selectable cards (rentmojo-style). Only shown when tiers exist. {%- endcomment -%}
        {%- if tiers != blank -%}
          <p class="ed-caption" style="color: var(--ed-text-mute); margin: 0 0 var(--sp-3);">Choose your quantity (incl GST)</p>
          <div class="ed-tier-cards" data-ed-tier-cards>
            {%- for tier in tiers -%}
              <button type="button" class="ed-tier-card{% if forloop.first %} is-active{% endif %}" data-tier-min="{{ tier.min | default: 1 }}" data-tier-max="{{ tier.max | default: '' }}" data-tier-price="{{ tier.price_cents | default: 0 }}">
                <span class="ed-tier-card__range">{{ tier.range }}</span>
                <span class="ed-tier-card__price">{{ tier.price }}</span>
                {%- if tier.save -%}<span class="ed-tier-card__save">Save {{ tier.save }}</span>{%- endif -%}
                {%- if tier.note -%}<span class="ed-tier-card__note">{{ tier.note }}</span>{%- endif -%}
              </button>
            {%- endfor -%}
          </div>
        {%- endif -%}

        {%- comment -%} Highlight strip (e.g. "Order before 2:30 PM for same-day dispatch") {%- endcomment -%}
        {%- if section.settings.highlight_text != blank -%}
          <div class="ed-rm-highlight">
            <span class="ed-rm-highlight__icon" aria-hidden="true">{{ section.settings.highlight_icon | default: '⏰' }}</span>
            <span class="ed-rm-highlight__text">{{ section.settings.highlight_text }}</span>
          </div>
        {%- endif -%}

        {%- comment -%} Pincode / delivery estimator (Rentmojo-style) {%- endcomment -%}
        {%- if section.settings.show_pincode_check -%}
          <div class="ed-pincode" data-ed-pincode>
            <label class="ed-label" for="ed-pincode-input">Delivery</label>
            <div class="ed-pincode__row">
              <input id="ed-pincode-input" type="text" inputmode="numeric" maxlength="6" placeholder="Enter pincode (e.g. 400001)" class="ed-input ed-pincode__input">
              <button type="button" class="ed-btn ed-btn--ghost ed-pincode__btn">Check</button>
            </div>
            <p class="ed-pincode__result" data-ed-pincode-result aria-live="polite"></p>
          </div>
        {%- endif -%}

        {%- comment -%} Buy form — wrapped in <product-form> so cart drawer auto-opens on add {%- endcomment -%}
        <product-form class="ed-product-form-wrap" data-section="{{ section.id }}">
        {%- form 'product', product, id: 'product-form', class: 'ed-form', novalidate: 'novalidate', data-type: 'add-to-cart-form' -%}
          <input type="hidden" name="id" value="{{ variant.id }}">
          <div class="loading__spinner hidden">
            <svg aria-hidden="true" focusable="false" class="spinner" viewBox="0 0 66 66" xmlns="http://www.w3.org/2000/svg"><circle class="path" fill="none" stroke-width="6" cx="33" cy="33" r="30"></circle></svg>
          </div>

          {%- if product.variants.size > 1 -%}
            {%- for option in product.options_with_values -%}
              <div class="ed-rm-card ed-rm-variant-card">
                <p class="ed-rm-variant-card__label">{{ option.name }}</p>
                <div class="ed-rm-variant-pills" role="radiogroup" aria-label="{{ option.name }}">
                  {%- for value in option.values -%}
                    {%- assign selected = false -%}
                    {%- if option.selected_value == value -%}{%- assign selected = true -%}{%- endif -%}
                    <label class="ed-rm-pill-opt{% if selected %} is-active{% endif %}">
                      <input type="radio" name="options[{{ option.name }}]" value="{{ value | escape }}" {% if selected %}checked{% endif %}>
                      <span>{{ value }}</span>
                    </label>
                  {%- endfor -%}
                </div>
              </div>
            {%- endfor -%}
          {%- endif -%}

          {%- comment -%} Multi-qty picker (chips + custom + stepper) + blue add-to-cart bar {%- endcomment -%}
          <div class="ed-rm-buy">
            <div class="ed-rm-qpicker" role="radiogroup" aria-label="Select quantity">
              <span class="ed-rm-qpicker__label">Qty</span>
              <button type="button" class="ed-rm-qpicker__chip is-active" data-ed-qchip="1" aria-checked="true">1</button>
              <button type="button" class="ed-rm-qpicker__chip" data-ed-qchip="2" aria-checked="false">2</button>
              <button type="button" class="ed-rm-qpicker__chip" data-ed-qchip="5" aria-checked="false">5</button>
              <button type="button" class="ed-rm-qpicker__chip" data-ed-qchip="10" aria-checked="false">10</button>
              <div class="ed-rm-qpicker__stepper">
                <button type="button" aria-label="Decrease" data-ed-qty-step="-1">−</button>
                <input id="ed-qty" type="number" name="quantity" value="1" min="1" aria-label="Quantity">
                <button type="button" aria-label="Increase" data-ed-qty-step="1">+</button>
              </div>
            </div>

            <button type="submit" name="add" class="ed-rm-buy__bar" id="ed-pdp-add" data-base-price="{{ variant.price }}" data-currency="{{ cart.currency.symbol }}" {% unless product.available %}disabled{% endunless %}>
              {%- if product.available -%}
                <span class="ed-rm-buy__bar-left">
                  <span class="ed-rm-buy__bar-meta">Total <span class="ed-rm-buy__bar-sub">(incl GST)</span></span>
                  <span class="ed-rm-buy__bar-total" data-ed-btn-total>{{ variant.price | money }}</span>
                </span>
                <span class="ed-rm-buy__bar-right">
                  <span class="ed-rm-buy__bar-cta" data-ed-btn-label>Add to cart</span>
                  <span aria-hidden="true" class="ed-rm-buy__bar-arrow">→</span>
                </span>
              {%- else -%}
                <span class="ed-rm-buy__bar-cta">Sold out</span>
              {%- endif -%}
            </button>
          </div>

          <div class="product-form__error-message-wrapper" role="alert" hidden>
            <span class="product-form__error-message"></span>
          </div>
        {%- endform -%}
        </product-form>

        {%- comment -%} Upsell card — bulk savings or quote (Rentmojo Mojo-Secure equivalent) {%- endcomment -%}
        {%- if section.settings.upsell_heading != blank -%}
          <a href="{{ section.settings.upsell_link | default: '/pages/bulk-pricing' }}" class="ed-rm-card ed-rm-upsell" data-action="upsell_click">
            <span class="ed-rm-upsell__icon" aria-hidden="true">{{ section.settings.upsell_icon | default: '🛡️' }}</span>
            <span class="ed-rm-upsell__body">
              <span class="ed-rm-upsell__h">{{ section.settings.upsell_heading }}</span>
              <span class="ed-rm-upsell__sub">{{ section.settings.upsell_sub }}</span>
            </span>
            <span class="ed-rm-upsell__arrow" aria-hidden="true">›</span>
          </a>
        {%- endif -%}

        {%- comment -%} Delivery promise card {%- endcomment -%}
        {%- if section.settings.promise_text != blank -%}
          <div class="ed-rm-card ed-rm-promise">
            <span class="ed-rm-promise__icon" aria-hidden="true">{{ section.settings.promise_icon | default: '🚚' }}</span>
            <span class="ed-rm-promise__text">{{ section.settings.promise_text }}</span>
          </div>
        {%- endif -%}

        {%- comment -%} Two-col policy info row {%- endcomment -%}
        {%- if section.settings.policy_1_label != blank or section.settings.policy_2_label != blank -%}
          <div class="ed-rm-policies">
            {%- if section.settings.policy_1_label != blank -%}
              <a href="{{ section.settings.policy_1_url | default: '#' }}" class="ed-rm-policy" data-action="policy_click" data-policy="1">
                <span class="ed-rm-policy__icon" aria-hidden="true">{{ section.settings.policy_1_icon | default: '↩️' }}</span>
                <span class="ed-rm-policy__label">{{ section.settings.policy_1_label }}</span>
                <span class="ed-rm-policy__arrow" aria-hidden="true">›</span>
              </a>
            {%- endif -%}
            {%- if section.settings.policy_2_label != blank -%}
              <a href="{{ section.settings.policy_2_url | default: '#' }}" class="ed-rm-policy" data-action="policy_click" data-policy="2">
                <span class="ed-rm-policy__icon" aria-hidden="true">{{ section.settings.policy_2_icon | default: '🧾' }}</span>
                <span class="ed-rm-policy__label">{{ section.settings.policy_2_label }}</span>
                <span class="ed-rm-policy__arrow" aria-hidden="true">›</span>
              </a>
            {%- endif -%}
          </div>
        {%- endif -%}

        {%- if section.settings.show_quote_cta -%}
          <a href="{{ section.settings.quote_url | default: '/pages/request-quote' }}" class="ed-rm-quote-link" data-action="quote_link_click">{{ section.settings.quote_cta_label | default: 'Need 50+ cases? Request a custom quote →' }}</a>
        {%- endif -%}

        {%- comment -%} Trust badge image (11-may style — single horizontal banner) {%- endcomment -%}
        {%- if section.settings.trust_badge_image != blank -%}
          <div class="ed-rm-trust-badge">
            {{ section.settings.trust_badge_image | image_url: width: 1200 | image_tag: loading: 'lazy', widths: '480, 720, 960, 1200', alt: 'Trust badge', class: 'ed-rm-trust-badge__img' }}
          </div>
        {%- endif -%}

        {%- comment -%} Trust strip — icon grid (Rentmojo-style) {%- endcomment -%}
        <div class="ed-trust-grid">
          {%- if section.settings.trust_1_label != blank -%}
            <div class="ed-trust-item">
              <span class="ed-trust-item__icon" aria-hidden="true">{{ section.settings.trust_1_icon | default: '🚚' }}</span>
              <div>
                <p class="ed-trust-item__label">{{ section.settings.trust_1_label }}</p>
                {%- if section.settings.trust_1_sub != blank -%}<p class="ed-trust-item__sub">{{ section.settings.trust_1_sub }}</p>{%- endif -%}
              </div>
            </div>
          {%- endif -%}
          {%- if section.settings.trust_2_label != blank -%}
            <div class="ed-trust-item">
              <span class="ed-trust-item__icon" aria-hidden="true">{{ section.settings.trust_2_icon | default: '🧾' }}</span>
              <div>
                <p class="ed-trust-item__label">{{ section.settings.trust_2_label }}</p>
                {%- if section.settings.trust_2_sub != blank -%}<p class="ed-trust-item__sub">{{ section.settings.trust_2_sub }}</p>{%- endif -%}
              </div>
            </div>
          {%- endif -%}
          {%- if section.settings.trust_3_label != blank -%}
            <div class="ed-trust-item">
              <span class="ed-trust-item__icon" aria-hidden="true">{{ section.settings.trust_3_icon | default: '⚡' }}</span>
              <div>
                <p class="ed-trust-item__label">{{ section.settings.trust_3_label }}</p>
                {%- if section.settings.trust_3_sub != blank -%}<p class="ed-trust-item__sub">{{ section.settings.trust_3_sub }}</p>{%- endif -%}
              </div>
            </div>
          {%- endif -%}
          {%- if section.settings.trust_4_label != blank -%}
            <div class="ed-trust-item">
              <span class="ed-trust-item__icon" aria-hidden="true">{{ section.settings.trust_4_icon | default: '↩️' }}</span>
              <div>
                <p class="ed-trust-item__label">{{ section.settings.trust_4_label }}</p>
                {%- if section.settings.trust_4_sub != blank -%}<p class="ed-trust-item__sub">{{ section.settings.trust_4_sub }}</p>{%- endif -%}
              </div>
            </div>
          {%- endif -%}
          {%- if sample -%}
            <div class="ed-trust-item">
              <span class="ed-trust-item__icon" aria-hidden="true">🎁</span>
              <div>
                <p class="ed-trust-item__label">Free sample</p>
                <p class="ed-trust-item__sub"><a href="{{ section.settings.sample_url | default: '/pages/sample-pack' }}" class="ed-link">Request one</a></p>
              </div>
            </div>
          {%- endif -%}
        </div>

        {%- if printers -%}
          <details style="margin-top: var(--sp-5); border-top: 1px solid var(--ed-border); padding-top: var(--sp-4);">
            <summary class="ed-caption" style="cursor: pointer; color: var(--ed-ink);">Printer compatibility ({{ printers.size }})</summary>
            <ul class="ed-mono" style="list-style: none; padding: var(--sp-3) 0 0; margin: 0; font-size: 12px; color: var(--ed-text-mute);">
              {%- for p in printers -%}
                <li style="padding: 3px 0;">· {{ p }}</li>
              {%- endfor -%}
            </ul>
          </details>
        {%- endif -%}
      </div>
    </div>

    {%- comment -%} Tabbed content blocks (Description / Specs / Reviews / FAQ) {%- endcomment -%}
    {%- if section.blocks.size > 0 -%}
      <div class="ed-pdp-tabs" data-ed-tabs>
        <div class="ed-pdp-tabs__nav" role="tablist">
          {%- for block in section.blocks -%}
            <button type="button" class="ed-pdp-tabs__tab{% if forloop.first %} is-active{% endif %}" role="tab" aria-selected="{% if forloop.first %}true{% else %}false{% endif %}" data-tab="{{ forloop.index }}" {{ block.shopify_attributes }}>
              {{ block.settings.title }}
            </button>
          {%- endfor -%}
        </div>
        <div class="ed-pdp-tabs__panels">
          {%- for block in section.blocks -%}
            <div class="ed-pdp-tabs__panel{% if forloop.first %} is-active{% endif %}" role="tabpanel" data-panel="{{ forloop.index }}">
              {%- case block.type -%}
                {%- when 'rich_text' -%}
                  <div class="ed-rte">{{ block.settings.content }}</div>
                {%- when 'specs_table' -%}
                  <div class="ed-rte">{{ block.settings.intro }}</div>
                  {%- if block.settings.specs != blank -%}
                    <table class="ed-spec ed-spec--full">
                      <tbody>
                        {%- assign rows = block.settings.specs | newline_to_br | split: '<br />' -%}
                        {%- for row in rows -%}
                          {%- assign parts = row | split: '|' -%}
                          {%- if parts.size >= 2 -%}
                            <tr><th>{{ parts[0] | strip }}</th><td>{{ parts[1] | strip }}</td></tr>
                          {%- endif -%}
                        {%- endfor -%}
                      </tbody>
                    </table>
                  {%- endif -%}
                {%- when 'faq' -%}
                  {%- for i in (1..6) -%}
                    {%- assign q_key = 'q' | append: i -%}
                    {%- assign a_key = 'a' | append: i -%}
                    {%- assign q = block.settings[q_key] -%}
                    {%- assign a = block.settings[a_key] -%}
                    {%- if q != blank -%}
                      <details class="ed-faq-item">
                        <summary>{{ q }}<span class="ed-faq-item__chev">+</span></summary>
                        <div class="ed-rte">{{ a }}</div>
                      </details>
                    {%- endif -%}
                  {%- endfor -%}
              {%- endcase -%}
            </div>
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}
  </div>

  {%- comment -%} Sticky mobile bottom bar {%- endcomment -%}
  {%- if product.available -%}
    <div class="ed-pdp-stickybar" id="ed-pdp-stickybar" aria-hidden="true">
      <div class="ed-pdp-stickybar__info">
        <p class="ed-pdp-stickybar__title">{{ product.title | truncate: 32 }}</p>
        <p class="ed-pdp-stickybar__price" data-ed-stickybar-price>{{ variant.price | money }}</p>
      </div>
      <div class="ed-pdp-stickybar__qty">
        <button type="button" aria-label="Decrease" data-ed-qty-step="-1">−</button>
        <span data-ed-stickybar-qty>1</span>
        <button type="button" aria-label="Increase" data-ed-qty-step="1">+</button>
      </div>
      <button type="submit" form="product-form" class="ed-btn ed-btn--primary ed-pdp-stickybar__btn" data-action="pdp_sticky_add">Add to cart</button>
    </div>
  {%- endif -%}
</div>


<script>
  (function() {
    const ph = function(name, props) { if (window.posthog) try { posthog.capture(name, props || {}); } catch (e) {} };
    const meta = { product_id: '{{ product.id }}', product_handle: '{{ product.handle }}', product_title: {{ product.title | json }} };

    // Qty stepper — works on PDP form stepper + sticky bar buttons
    document.querySelectorAll('[data-ed-qty-step]').forEach(function (btn) {
      btn.addEventListener('click', function () {
        const step = parseInt(btn.dataset.edQtyStep, 10);
        const input = btn.parentElement.querySelector('input[type="number"]') || document.getElementById('ed-qty');
        if (!input) return;
        const v = Math.max(1, (parseInt(input.value, 10) || 1) + step);
        input.value = v;
        input.dispatchEvent(new Event('change', { bubbles: true }));
      });
    });

    // Brute-force gallery image fill — sets inline styles JS-style so nothing else can win
    (function() {
      const apply = function() {
        document.querySelectorAll('.ed-gallery__img').forEach(function(img) {
          img.removeAttribute('width');
          img.removeAttribute('height');
          img.style.setProperty('position', 'absolute', 'important');
          img.style.setProperty('top', '0', 'important');
          img.style.setProperty('left', '0', 'important');
          img.style.setProperty('right', '0', 'important');
          img.style.setProperty('bottom', '0', 'important');
          img.style.setProperty('width', '100%', 'important');
          img.style.setProperty('height', '100%', 'important');
          img.style.setProperty('object-fit', 'cover', 'important');
          img.style.setProperty('display', 'block', 'important');
        });
        document.querySelectorAll('.ed-gallery__slide').forEach(function(s) {
          s.style.setProperty('position', 'absolute', 'important');
          s.style.setProperty('top', '0', 'important');
          s.style.setProperty('left', '0', 'important');
          s.style.setProperty('right', '0', 'important');
          s.style.setProperty('bottom', '0', 'important');
          s.style.setProperty('width', '100%', 'important');
          s.style.setProperty('height', '100%', 'important');
        });
      };
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', apply);
      else apply();
    })();

    // Sync sticky-bar qty display with ed-qty input
    (function() {
      const stickyQty = document.querySelector('[data-ed-stickybar-qty]');
      const input = document.getElementById('ed-qty');
      if (!stickyQty || !input) return;
      const sync = function() { stickyQty.textContent = input.value || '1'; };
      input.addEventListener('change', sync);
      input.addEventListener('input', sync);
      sync();
    })();

    // Multi-qty chip picker (1 / 2 / 5 / 10)
    document.querySelectorAll('[data-ed-qchip]').forEach(function(chip) {
      chip.addEventListener('click', function() {
        const q = parseInt(chip.dataset.edQchip, 10) || 1;
        document.querySelectorAll('[data-ed-qchip]').forEach(function(c) {
          const active = c === chip;
          c.classList.toggle('is-active', active);
          c.setAttribute('aria-checked', active ? 'true' : 'false');
        });
        const input = document.getElementById('ed-qty');
        if (input) {
          input.value = q;
          input.dispatchEvent(new Event('change', { bubbles: true }));
        }
        ph('qty_chip_selected', Object.assign({}, meta, { quantity: q }));
      });
    });

    // Custom typed qty: clear chip active state when user types a custom value
    (function() {
      const customInput = document.getElementById('ed-qty');
      if (!customInput) return;
      customInput.addEventListener('input', function() {
        const v = parseInt(customInput.value, 10) || 1;
        const chips = document.querySelectorAll('[data-ed-qchip]');
        let matched = false;
        chips.forEach(function(c) {
          const active = parseInt(c.dataset.edQchip, 10) === v;
          c.classList.toggle('is-active', active);
          c.setAttribute('aria-checked', active ? 'true' : 'false');
          if (active) matched = true;
        });
      });
    })();

    // Live total + tier highlight on qty change
    const qtyInput = document.getElementById('ed-qty');
    const btn = document.getElementById('ed-pdp-add');
    const stickyPrice = document.querySelector('[data-ed-stickybar-price]');
    const totalEl = document.querySelector('[data-ed-btn-total]');
    const tiers = document.querySelectorAll('.ed-tier-list li');
    const base = btn ? parseInt(btn.dataset.basePrice, 10) : 0;
    const sym = btn ? btn.dataset.currency || '₹' : '₹';

    function formatMoney(cents) {
      return sym + (cents / 100).toLocaleString('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    }

    if (qtyInput && totalEl) {
      qtyInput.addEventListener('change', function() {
        const q = Math.max(1, parseInt(qtyInput.value, 10) || 1);
        const total = base * q;
        totalEl.textContent = ' · ' + formatMoney(total);
        if (stickyPrice) stickyPrice.textContent = formatMoney(total);
        // Highlight matching tier row (best-effort: parse range like "1-4" or "5-19" or "50+")
        tiers.forEach(function(li) {
          const range = (li.querySelector('.ed-tier-range') || {}).textContent || '';
          const m = range.match(/(\d+)\s*[-–]\s*(\d+)/) || range.match(/(\d+)\s*\+/);
          let lo = m ? parseInt(m[1], 10) : 0;
          let hi = m && m[2] ? parseInt(m[2], 10) : Infinity;
          li.classList.toggle('is-active', q >= lo && q <= hi);
        });
        ph('qty_changed', Object.assign({}, meta, { quantity: q, surface: 'pdp' }));
      });
      // initial tier highlight
      qtyInput.dispatchEvent(new Event('change', { bubbles: true }));
    }

    // Variant select tracking
    document.querySelectorAll('.ed-form select').forEach(function(sel) {
      sel.addEventListener('change', function() {
        ph('variant_selected', Object.assign({}, meta, { option: sel.name, value: sel.value }));
      });
    });

    // Add-to-cart: take full control. Bypass Dawn's product-form.js to guarantee
    // the cart drawer opens cleanly every time (11 may behavior: tap add → drawer slides in).
    const form = document.getElementById('product-form');
    if (form) {
      form.addEventListener('submit', async function(e) {
        e.preventDefault();
        e.stopImmediatePropagation();
        const submitBtn = form.querySelector('[type="submit"][name="add"]');
        if (submitBtn && submitBtn.getAttribute('aria-disabled') === 'true') return;
        if (submitBtn) {
          submitBtn.setAttribute('aria-disabled', 'true');
          submitBtn.classList.add('loading');
        }
        const spinner = form.querySelector('.loading__spinner');
        if (spinner) spinner.classList.remove('hidden');
        const errorWrap = form.querySelector('.product-form__error-message-wrapper');
        if (errorWrap) { errorWrap.hidden = true; }

        const q = qtyInput ? parseInt(qtyInput.value, 10) : 1;
        ph('add_to_cart', Object.assign({}, meta, { quantity: q, surface: 'pdp' }));

        try {
          // 1. Add item to cart
          const fd = new FormData(form);
          const drawer = document.querySelector('cart-drawer');
          const sections = drawer && typeof drawer.getSectionsToRender === 'function'
            ? drawer.getSectionsToRender().map(function(s) { return s.id; }).join(',')
            : 'cart-drawer,cart-icon-bubble,cart-live-region-text';
          fd.append('sections', sections);
          fd.append('sections_url', window.location.pathname);

          const addRes = await fetch(window.routes ? window.routes.cart_add_url : '/cart/add.js', {
            method: 'POST',
            headers: { 'Accept': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
            body: fd
          });
          const addJson = await addRes.json();
          if (!addRes.ok || addJson.status) {
            const msg = addJson.description || addJson.message || 'Could not add to cart';
            if (errorWrap) {
              errorWrap.hidden = false;
              const msgSpan = errorWrap.querySelector('.product-form__error-message');
              if (msgSpan) msgSpan.textContent = msg;
            }
            throw new Error(msg);
          }

          // 2. Replace cart drawer HTML with fresh server-rendered sections
          if (drawer && addJson.sections) {
            const targets = drawer.getSectionsToRender ? drawer.getSectionsToRender() : [];
            targets.forEach(function(t) {
              const el = t.selector ? document.querySelector(t.selector) : document.getElementById(t.id);
              if (!el || !addJson.sections[t.id]) return;
              const parsed = new DOMParser().parseFromString(addJson.sections[t.id], 'text/html');
              const src = parsed.querySelector(t.selector || '.shopify-section');
              if (src) el.innerHTML = src.innerHTML;
            });
          }

          // 3. Publish cart update event for any other listeners (cart icon bubble, etc.)
          try {
            if (typeof publish === 'function' && typeof PUB_SUB_EVENTS !== 'undefined') {
              publish(PUB_SUB_EVENTS.cartUpdate, { source: 'product-form', cartData: addJson });
            }
          } catch (e) {}

          // 4. Open the drawer
          if (drawer && typeof drawer.open === 'function') {
            if (drawer.classList.contains('is-empty')) drawer.classList.remove('is-empty');
            drawer.open();
          } else {
            // No drawer — fall back to cart page
            window.location = window.routes ? window.routes.cart_url : '/cart';
          }
        } catch (err) {
          console.error('[ed-pdp] add to cart failed:', err);
        } finally {
          if (submitBtn) {
            submitBtn.removeAttribute('aria-disabled');
            submitBtn.classList.remove('loading');
          }
          if (spinner) spinner.classList.add('hidden');
        }
      }, true); // capture phase so we run before Dawn's listener
    }

    // Sticky-bar PostHog event
    document.querySelectorAll('[data-action="pdp_sticky_add"]').forEach(function(b) {
      b.addEventListener('click', function() { ph('add_to_cart_sticky', meta); });
    });

    // Tier card selection — sets qty to tier minimum
    document.querySelectorAll('[data-ed-tier-cards] .ed-tier-card').forEach(function(card) {
      card.addEventListener('click', function() {
        document.querySelectorAll('[data-ed-tier-cards] .ed-tier-card').forEach(function(c) {
          c.classList.toggle('is-active', c === card);
        });
        const min = parseInt(card.dataset.tierMin, 10) || 1;
        if (qtyInput) {
          qtyInput.value = min;
          qtyInput.dispatchEvent(new Event('change', { bubbles: true }));
        }
        ph('tier_card_selected', Object.assign({}, meta, { tier_min: min }));
      });
    });

    // Pincode checker (mock — replace with real serviceability API if needed)
    const pinWrap = document.querySelector('[data-ed-pincode]');
    if (pinWrap) {
      const input = pinWrap.querySelector('.ed-pincode__input');
      const btn = pinWrap.querySelector('.ed-pincode__btn');
      const result = pinWrap.querySelector('[data-ed-pincode-result]');
      const check = function() {
        const v = (input.value || '').trim();
        if (!/^\d{6}$/.test(v)) {
          result.textContent = 'Enter a valid 6-digit Indian pincode.';
          result.classList.add('is-err');
          return;
        }
        // Mock: estimate EDD = today + 3 business days
        const d = new Date(); d.setDate(d.getDate() + 3);
        const opts = { weekday: 'short', day: '2-digit', month: 'short' };
        result.textContent = '✓ Delivers to ' + v + ' by ' + d.toLocaleDateString('en-IN', opts) + ' · free shipping above ₹2,500';
        result.classList.remove('is-err');
        ph('pincode_check', Object.assign({}, meta, { pincode: v }));
      };
      btn.addEventListener('click', check);
      input.addEventListener('keydown', function(e) { if (e.key === 'Enter') { e.preventDefault(); check(); } });
    }

    // Variant pills (radio-styled labels) — toggle is-active class on change
    document.querySelectorAll('.ed-rm-pill-opt input').forEach(function(input) {
      input.addEventListener('change', function() {
        const group = input.closest('.ed-rm-variant-pills');
        if (!group) return;
        group.querySelectorAll('.ed-rm-pill-opt').forEach(function(p) {
          p.classList.toggle('is-active', p.querySelector('input').checked);
        });
        ph('variant_pill_selected', Object.assign({}, meta, { option: input.name, value: input.value }));
      });
    });

    // Upsell / policy click tracking
    document.querySelectorAll('[data-action="upsell_click"], [data-action="policy_click"], [data-action="quote_link_click"]').forEach(function(el) {
      el.addEventListener('click', function() {
        ph(el.dataset.action, Object.assign({}, meta, { href: el.getAttribute('href'), policy: el.dataset.policy }));
      });
    });

    // Tabs
    document.querySelectorAll('[data-ed-tabs]').forEach(function(wrap) {
      const tabs = wrap.querySelectorAll('.ed-pdp-tabs__tab');
      const panels = wrap.querySelectorAll('.ed-pdp-tabs__panel');
      tabs.forEach(function(t) {
        t.addEventListener('click', function() {
          const id = t.dataset.tab;
          tabs.forEach(function(x) {
            const active = x === t;
            x.classList.toggle('is-active', active);
            x.setAttribute('aria-selected', active ? 'true' : 'false');
          });
          panels.forEach(function(p) { p.classList.toggle('is-active', p.dataset.panel === id); });
          ph('pdp_tab_click', Object.assign({}, meta, { tab: t.textContent.trim() }));
        });
      });
    });

    // Offer code copy-to-clipboard
    document.querySelectorAll('[data-ed-copy]').forEach(function(btn) {
      btn.addEventListener('click', function() {
        const code = btn.getAttribute('data-ed-copy');
        const done = function() {
          btn.classList.add('is-copied');
          const original = btn.innerHTML;
          btn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M5 12l5 5 9-11" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>';
          setTimeout(function() { btn.classList.remove('is-copied'); btn.innerHTML = original; }, 1600);
          ph('offer_copy', Object.assign({}, meta, { code: code }));
        };
        if (navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard.writeText(code).then(done).catch(function() {
            const ta = document.createElement('textarea'); ta.value = code; document.body.appendChild(ta); ta.select();
            try { document.execCommand('copy'); done(); } catch (e) {}
            document.body.removeChild(ta);
          });
        }
      });
    });

    // Social proof — sold + viewing now (deterministic-ish randomness, refreshes every 22-45s)
    (function() {
      const wrap = document.querySelector('[data-ed-social]');
      if (!wrap) return;
      const soldEl = wrap.querySelector('[data-ed-sold]');
      const viewEl = wrap.querySelector('[data-ed-viewing]');
      const soldPool = ({{ section.settings.sold_values | default: '8,12,15,18,22,26' | json }} || '').split(',').map(function(s) { return parseInt(s.trim(), 10); }).filter(Boolean);
      const vMin = {{ section.settings.viewing_min | default: 8 }};
      const vMax = {{ section.settings.viewing_max | default: 32 }};
      const pick = function(arr) { return arr[Math.floor(Math.random() * arr.length)]; };
      const rand = function(lo, hi) { return Math.floor(lo + Math.random() * (hi - lo + 1)); };
      const tick = function() {
        if (soldEl && soldPool.length) soldEl.textContent = pick(soldPool);
        if (viewEl) viewEl.textContent = rand(vMin, vMax);
      };
      tick();
      setInterval(tick, rand(22000, 45000));
    })();

    // Gallery — thumb click + arrows + variant featured-image swap
    (function() {
      const root = document.querySelector('[data-ed-gallery]');
      if (!root) return;
      const slides = Array.from(root.querySelectorAll('.ed-gallery__slide'));
      const thumbs = Array.from(root.querySelectorAll('[data-ed-thumb]'));
      const counter = root.querySelector('[data-ed-gallery-current]');
      const prev = root.querySelector('[data-ed-gallery-prev]');
      const next = root.querySelector('[data-ed-gallery-next]');
      if (!slides.length) return;
      const indexOfId = function(id) {
        for (let i = 0; i < slides.length; i++) if (slides[i].dataset.edMediaId === String(id)) return i;
        return -1;
      };
      const show = function(i) {
        if (i < 0) i = slides.length - 1;
        if (i >= slides.length) i = 0;
        slides.forEach(function(s, idx) { s.classList.toggle('is-active', idx === i); });
        thumbs.forEach(function(t, idx) {
          const active = idx === i;
          t.classList.toggle('is-active', active);
          t.setAttribute('aria-selected', active ? 'true' : 'false');
          if (active) t.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
        });
        if (counter) counter.textContent = (i + 1);
      };
      const current = function() { return slides.findIndex(function(s) { return s.classList.contains('is-active'); }); };
      thumbs.forEach(function(t, i) { t.addEventListener('click', function() { show(i); ph('gallery_thumb_click', Object.assign({}, meta, { index: i })); }); });
      if (prev) prev.addEventListener('click', function() { show(current() - 1); });
      if (next) next.addEventListener('click', function() { show(current() + 1); });
      // keyboard nav
      root.addEventListener('keydown', function(e) {
        if (e.key === 'ArrowLeft') { e.preventDefault(); show(current() - 1); }
        if (e.key === 'ArrowRight') { e.preventDefault(); show(current() + 1); }
      });
      root.setAttribute('tabindex', '0');
      // Variant change → swap featured media if variant has featured_media
      document.addEventListener('change', function(e) {
        if (!e.target.matches('input[name^="options["]') && !e.target.matches('.ed-form select')) return;
        // ask the form's variant_id input post-shopify-update; fallback: re-poll selected variant via name="id"
        const idInput = document.querySelector('#product-form input[name="id"]');
        if (!idInput) return;
        const variantId = idInput.value;
        // Variant data sits in product.variants — embedded below for client use
        const variants = window.__edProductVariants || [];
        const variant = variants.find(function(v) { return String(v.id) === String(variantId); });
        if (variant && variant.featured_media && variant.featured_media.id) {
          const idx = indexOfId(variant.featured_media.id);
          if (idx >= 0) show(idx);
        }
      });
    })();
    // expose variant featured-media map for gallery
    window.__edProductVariants = {{ product.variants | json }};

    // PDP viewed
    ph('pdp_view', meta);
  })();
</script>

{% schema %}
{
  "name": "ED Main product",
  "tag": "section",
  "settings": [
    { "type": "header", "content": "Layout" },
    { "type": "checkbox", "id": "show_breadcrumb", "label": "Show breadcrumb", "default": true },
    { "type": "text", "id": "price_unit_label", "label": "Price unit label (e.g. 'case', 'roll')", "default": "case" },
    { "type": "text", "id": "delivery_promise", "label": "Delivery promise (in price card)", "default": "Same-day dispatch" },

    { "type": "header", "content": "Social proof (sold + live viewers)" },
    { "type": "checkbox", "id": "show_social_proof", "label": "Show sold / viewing-now row", "default": true },
    { "type": "text", "id": "sold_values", "label": "Sold counts (comma-separated, rotates)", "default": "8,12,15,18,22,26" },
    { "type": "range", "id": "viewing_min", "label": "Viewing now — min", "min": 0, "max": 100, "step": 1, "default": 8 },
    { "type": "range", "id": "viewing_max", "label": "Viewing now — max", "min": 0, "max": 200, "step": 2, "default": 32 },

    { "type": "header", "content": "Available offers (3 coupon cards)" },
    { "type": "text", "id": "offers_heading", "label": "Heading", "default": "Available offers" },
    { "type": "text", "id": "offer_1", "label": "Offer 1 — Title", "default": "Get ₹100 off" },
    { "type": "text", "id": "offer_1_tagline", "label": "Offer 1 — Tagline", "default": "On carts above ₹899" },
    { "type": "text", "id": "offer_1_code", "label": "Offer 1 — Code", "default": "SAVE100" },
    { "type": "text", "id": "offer_2", "label": "Offer 2 — Title", "default": "Get 9% off" },
    { "type": "text", "id": "offer_2_tagline", "label": "Offer 2 — Tagline", "default": "On carts above ₹1,200" },
    { "type": "text", "id": "offer_2_code", "label": "Offer 2 — Code", "default": "SAVE09" },
    { "type": "text", "id": "offer_3", "label": "Offer 3 — Title", "default": "Get 15% off" },
    { "type": "text", "id": "offer_3_tagline", "label": "Offer 3 — Tagline", "default": "On carts above ₹2,400" },
    { "type": "text", "id": "offer_3_code", "label": "Offer 3 — Code", "default": "SAVE15" },

    { "type": "header", "content": "Highlight strip (single line under buy bar)" },
    { "type": "text", "id": "highlight_icon", "label": "Icon (emoji)", "default": "⏰" },
    { "type": "text", "id": "highlight_text", "label": "Text", "default": "Order before 2:30 PM IST for same-day dispatch" },

    { "type": "header", "content": "Trust badge image (replaces emoji grid if set)" },
    { "type": "image_picker", "id": "trust_badge_image", "label": "Image (full width, transparent PNG works best)" },

    { "type": "header", "content": "Quote CTA" },
    { "type": "checkbox", "id": "show_quote_cta", "label": "Show quote link", "default": true },
    { "type": "text", "id": "quote_cta_label", "label": "Quote link label", "default": "Need 50+ cases? Request a custom quote →" },
    { "type": "text", "id": "quote_url", "label": "Quote page URL", "default": "/pages/request-quote" },
    { "type": "text", "id": "sample_url", "label": "Sample-pack page URL", "default": "/pages/sample-pack" },

    { "type": "header", "content": "Upsell card (Mojo-Secure equivalent)" },
    { "type": "text", "id": "upsell_icon", "label": "Icon (emoji)", "default": "💎" },
    { "type": "text", "id": "upsell_heading", "label": "Heading", "default": "Bulk savings unlock at 20+ cases" },
    { "type": "text", "id": "upsell_sub", "label": "Sub", "default": "Save up to 11% per case. See the full tier table." },
    { "type": "text", "id": "upsell_link", "label": "Link", "default": "/pages/bulk-pricing" },

    { "type": "header", "content": "Delivery promise card" },
