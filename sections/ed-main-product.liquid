  }
  .ed-rm-buy__bar-arrow { font-size: 16px; transition: transform 120ms; }
  .ed-rm-buy__bar:hover .ed-rm-buy__bar-arrow { transform: translateX(2px); }

  /* Upsell card */
  .ed-rm-upsell {
    display: flex; align-items: center; gap: 12px;
    background: rgba(30, 95, 255, 0.04);
