    .ed-rm-buy__qty { flex-direction: row; align-items: center; gap: 8px; }
    .ed-rm-qty { height: 44px; grid-template-columns: 32px 40px 32px; }
    .ed-rm-buy__bar { height: 56px; }
  }

  /* Sticky mobile bar */
  .ed-pdp-stickybar {
    display: none;
    position: fixed; left: 0; right: 0; bottom: 0;
    z-index: 49;
