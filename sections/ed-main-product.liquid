  }
  .ed-rm-buy__bar:hover { background: #1747D6; }
  .ed-rm-buy__bar:active { transform: scale(0.99); }
  .ed-rm-buy__bar:disabled { background: rgba(10,11,14,0.18); cursor: not-allowed; }
  .ed-rm-buy__bar-left { display: flex; flex-direction: column; align-items: flex-start; line-height: 1.1; }
  .ed-rm-buy__bar-meta {
    font-family: "Inter", sans-serif; font-weight: 500; font-size: 11px;
    text-transform: uppercase; letter-spacing: 0.06em;
