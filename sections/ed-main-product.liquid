  }
  .ed-rm-upsell:hover { background: rgba(30, 95, 255, 0.08); }
  .ed-rm-upsell__icon { font-size: 22px; flex: 0 0 auto; }
  .ed-rm-upsell__body { flex: 1; display: flex; flex-direction: column; gap: 2px; }
  .ed-rm-upsell__h { font-family: "Inter", sans-serif; font-weight: 700; font-size: 14px; color: var(--ed-ink, #0A0B0E); }
  .ed-rm-upsell__sub { font-family: "Inter", sans-serif; font-size: 12px; color: var(--ed-text-mute, #5C6068); }
  .ed-rm-upsell__arrow { font-size: 20px; color: var(--ed-electric, #1E5FFF); font-weight: 600; }

  /* Delivery promise card */
  .ed-rm-promise {
    display: flex; align-items: center; gap: 12px;
    padding: 12px 16px;
  }
  .ed-rm-promise__icon { font-size: 18px; flex: 0 0 auto; }
  .ed-rm-promise__text { font-family: "Inter", sans-serif; font-size: 13px; color: var(--ed-ink, #0A0B0E); }

  /* Two-col policy row */
  .ed-rm-policies {
    display: grid; grid-template-columns: 1fr 1fr; gap: 10px;
  }
  .ed-rm-policy {
    display: flex; align-items: center; gap: 8px;
