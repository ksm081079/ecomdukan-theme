    font-family: "Inter", sans-serif;
  }
  .ed-pincode__result.is-err { color: var(--ed-error, #A8281C); }

  /* Trust grid */
  .ed-trust-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    margin-top: 24px;
    padding-top: 20px;
