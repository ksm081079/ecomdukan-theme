    background: var(--ed-snow, #FBFAF6);
    border: 1px solid var(--ed-border, #E0DBCF);
    border-radius: 8px;
    text-decoration: none;
    color: var(--ed-ink, #0A0B0E);
    transition: border-color 120ms;
  }
  .ed-rm-policy:hover { border-color: var(--ed-ink, #0A0B0E); }
  .ed-rm-policy__icon { font-size: 16px; flex: 0 0 auto; }
  .ed-rm-policy__label { flex: 1; font-family: "Inter", sans-serif; font-weight: 600; font-size: 12px; }
  .ed-rm-policy__arrow { color: var(--ed-text-mute, #5C6068); font-size: 16px; }

  .ed-rm-quote-link {
    display: inline-block;
    margin-top: 6px;
    font-family: "Inter", sans-serif; font-weight: 600; font-size: 13px;
    color: var(--ed-electric, #1E5FFF);
    text-decoration: none;
