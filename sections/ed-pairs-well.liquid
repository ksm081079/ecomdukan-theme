{%- liquid
  assign _pt = section.settings.padding_top | default: 0
  assign _pb = section.settings.padding_bottom | default: 0
-%}
{% style %}
  #shopify-section-{{ section.id }} { padding-top: {{ _pt }}px !important; padding-bottom: {{ _pb }}px !important; }
{% endstyle %}
{%- liquid
  assign scheme = section.settings.color_scheme | default: 'scheme-1'
  assign coll = collections[section.settings.collection]
  assign products = coll.products
  assign limit = section.settings.product_count | default: 4
-%}
<div class="color-{{ scheme }} ed-section" style="background: rgb(var(--color-background));">
  <div class="ed-container">
    {%- if section.settings.heading != blank -%}
      <h2 class="ed-display-m" style="margin: 0 0 var(--sp-6);">{{ section.settings.heading }}</h2>
    {%- endif -%}

    <div style="display: grid; grid-template-columns: repeat({{ limit }}, 1fr); gap: var(--sp-5);" class="ed-pairs-grid">
      {%- for product in products limit: limit -%}
        {%- render 'ed-product-card', product: product -%}
      {%- else -%}
        {%- for i in (1..limit) -%}
          <div class="ed-card" style="aspect-ratio: 1/1.4;"><p class="ed-caption" style="color: var(--ed-mute);">Pick a collection</p></div>
        {%- endfor -%}
      {%- endfor -%}
    </div>
  </div>
</div>

<style>
  @media (max-width: 989px) { .ed-pairs-grid { grid-template-columns: repeat(2, 1fr) !important; } }
  @media (max-width: 599px) { .ed-pairs-grid { grid-template-columns: 1fr !important; } }
</style>

{% schema %}
{
  "name": "ED Pairs well with",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Pairs well with"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "product_count",
      "label": "Products to show",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1",
      "options": [
        {
          "value": "scheme-1",
          "label": "Paper"
        },
        {
          "value": "scheme-2",
          "label": "Snow"
        }
      ]
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding (px)",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding (px)",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 0,
      "unit": "px"
    }
  ],
  "presets": [
    {
      "name": "ED Pairs well with"
    }
  ]
}
{% endschema %}
