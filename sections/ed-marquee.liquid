{%- comment -%} ED Marquee — infinite-scroll text strip (11-may style) {%- endcomment -%}

{%- liquid
  assign scheme = section.settings.color_scheme | default: 'scheme-4'
  assign speed = section.settings.speed | default: 30
  assign reverse = section.settings.reverse
-%}

<div class="ed-marquee color-{{ scheme }}" style="background: rgb(var(--color-background)); color: rgb(var(--color-foreground)); padding: {{ section.settings.padding_y | default: 14 }}px 0;">
  {%- if section.blocks.size > 0 -%}
    <div class="ed-marquee__track" style="animation-duration: {{ speed }}s; animation-direction: {% if reverse %}reverse{% else %}normal{% endif %};">
      {%- for i in (1..2) -%}
        <div class="ed-marquee__group" {% if i == 2 %}aria-hidden="true"{% endif %}>
          {%- for block in section.blocks -%}
            <span class="ed-marquee__item" {{ block.shopify_attributes }}>
              {%- if block.settings.icon != blank -%}
                <span class="ed-marquee__icon" aria-hidden="true">{{ block.settings.icon }}</span>
              {%- endif -%}
              <span class="ed-marquee__text">{{ block.settings.text }}</span>
            </span>
            <span class="ed-marquee__sep" aria-hidden="true">★</span>
          {%- endfor -%}
        </div>
      {%- endfor -%}
    </div>
  {%- endif -%}
</div>

<style>
  /* Kill the global .section + .section { margin-top: 96px } rule for any section flagged ed-section-flush */
  .section.ed-section-flush, .shopify-section.ed-section-flush { margin-top: 0 !important; }
  .ed-marquee { overflow: hidden; }
  .ed-marquee__track {
    display: flex;
    width: max-content;
    animation: ed-marquee-scroll linear infinite;
  }
  .ed-marquee__track:hover { animation-play-state: paused; }
  .ed-marquee__group {
    display: flex;
    align-items: center;
    gap: 28px;
    padding-right: 28px;
  }
  .ed-marquee__item {
    display: inline-flex; align-items: center; gap: 8px;
    font-family: "Inter", sans-serif; font-weight: 600; font-size: 14px;
    letter-spacing: 0.02em;
    white-space: nowrap;
  }
  .ed-marquee__icon { font-size: 16px; }
  .ed-marquee__sep { opacity: 0.5; font-size: 10px; }
  @keyframes ed-marquee-scroll {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }
  @media (max-width: 749px) {
    .ed-marquee__item { font-size: 12px; gap: 6px; }
    .ed-marquee__group { gap: 20px; padding-right: 20px; }
  }
</style>

{% schema %}
{
  "name": "ED Marquee",
  "tag": "section",
  "class": "ed-section-flush",
  "settings": [
    { "type": "range", "id": "speed", "label": "Speed (seconds per loop)", "min": 10, "max": 60, "step": 5, "default": 30 },
    { "type": "checkbox", "id": "reverse", "label": "Reverse direction", "default": false },
    { "type": "range", "id": "padding_y", "label": "Vertical padding (px)", "min": 6, "max": 40, "step": 2, "default": 14 },
    { "type": "select", "id": "color_scheme", "label": "Color scheme", "default": "scheme-4",
      "options": [
        { "value": "scheme-1", "label": "Paper" },
        { "value": "scheme-2", "label": "Snow" },
        { "value": "scheme-3", "label": "Indigo" },
        { "value": "scheme-4", "label": "Ink" }
      ]
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Item",
      "settings": [
        { "type": "text", "id": "icon", "label": "Icon (emoji)", "default": "🚚" },
        { "type": "text", "id": "text", "label": "Text", "default": "Free shipping above ₹2,500" }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "ED Marquee",
      "blocks": [
        { "type": "item", "settings": { "icon": "🚚", "text": "Free shipping above ₹2,500" } },
        { "type": "item", "settings": { "icon": "🧾", "text": "GST invoice on every order" } },
        { "type": "item", "settings": { "icon": "⚡", "text": "Same-day dispatch — Mumbai · Bengaluru · Delhi" } },
        { "type": "item", "settings": { "icon": "↩️", "text": "7-day easy returns" } }
      ]
    }
  ]
}
{% endschema %}
