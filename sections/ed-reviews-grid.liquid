{%- liquid
  assign _pt = section.settings.padding_top | default: 24
  assign _pb = section.settings.padding_bottom | default: 24
-%}
{% style %}
  #shopify-section-{{ section.id }} { padding-top: {{ _pt }}px !important; padding-bottom: {{ _pb }}px !important; }
{% endstyle %}
{%- liquid
  assign scheme = section.settings.color_scheme | default: 'scheme-2'
  assign accent = section.settings.accent_color | default: '#1E5FFF'
  assign total = section.settings.total_count
  assign view_all_url = section.settings.view_all_url
-%}

<div class="color-{{ scheme }} ed-reviews" style="background: rgb(var(--color-background));">
  <div class="ed-container">
    <div class="ed-reviews__head">
      <h2 class="ed-reviews__h">
        {{ section.settings.heading_lead | default: 'Over 1.5 lac' }}
        <span class="ed-reviews__h-accent">{{ section.settings.heading_accent | default: 'Happy customers' }}</span>
        <span class="ed-reviews__rule" aria-hidden="true"></span>
      </h2>
      {%- if section.settings.subhead != blank -%}
        <p class="ed-reviews__sub">{{ section.settings.subhead }}</p>
      {%- endif -%}
    </div>

    <ul class="ed-reviews__grid" role="list">
      {%- for block in section.blocks -%}
        <li class="ed-reviews__card" {{ block.shopify_attributes }}>
          <p class="ed-reviews__name">{{ block.settings.name }}</p>
          <div class="ed-reviews__rating">
            <span class="ed-reviews__score">{{ block.settings.rating | default: '5.0' }}</span>
            <span class="ed-reviews__stars" aria-label="{{ block.settings.rating | default: 5 }} stars">
              {%- assign full = block.settings.rating | default: 5.0 | round -%}
              {%- for i in (1..5) -%}
                <span class="ed-reviews__star{% if i > full %} is-empty{% endif %}">★</span>
              {%- endfor -%}
            </span>
          </div>
          {%- if block.settings.body != blank -%}
            <p class="ed-reviews__body">{{ block.settings.body }}</p>
          {%- endif -%}
        </li>
      {%- endfor -%}
    </ul>

    {%- if view_all_url != blank -%}
      <div class="ed-reviews__cta-wrap">
        <a href="{{ view_all_url }}" class="ed-reviews__cta" data-action="reviews_view_all">
          View all{% if total != blank %} {{ total }}{% endif %} reviews
          <span aria-hidden="true" style="margin-left:8px;">›</span>
        </a>
      </div>
    {%- endif -%}
  </div>
</div>

<style>
  .ed-reviews { padding-block: clamp(48px, 6vw, 96px); }
  .ed-reviews__head { margin-bottom: clamp(24px, 3vw, 40px); }
  .ed-reviews__h {
    margin: 0;
    font-family: "Poppins", sans-serif; font-weight: 700;
    font-size: clamp(28px, 4vw, 44px);
    letter-spacing: -0.035em; line-height: 1.1;
    color: rgb(var(--color-foreground));
    display: inline-flex; align-items: center; flex-wrap: wrap; gap: 12px;
  }
  .ed-reviews__h-accent { color: {{ accent }}; }
  .ed-reviews__rule {
    display: inline-block; width: 64px; height: 2px;
    background: {{ accent }};
  }
  .ed-reviews__sub {
    margin: 12px 0 0;
    font-family: "Inter", sans-serif; font-size: 16px;
    color: rgba(var(--color-foreground), 0.65);
  }

  .ed-reviews__grid {
    list-style: none; margin: 0; padding: 0;
    column-count: 3;
    column-gap: 16px;
  }
  @media (max-width: 989px) { .ed-reviews__grid { column-count: 2; } }
  @media (max-width: 599px) { .ed-reviews__grid { column-count: 1; } }

  .ed-reviews__card {
    display: inline-block;
    width: 100%;
    margin: 0 0 16px;
    padding: 18px 20px;
    background: var(--ed-snow, #FBFAF6);
    border: 1px solid var(--ed-border, #E0DBCF);
    border-radius: 8px;
    break-inside: avoid;
    transition: border-color 120ms, transform 120ms;
  }
  .ed-reviews__card:hover {
    border-color: var(--ed-ink, #0A0B0E);
    transform: translateY(-2px);
  }
  .ed-reviews__name {
    margin: 0 0 8px;
    font-family: "Poppins", sans-serif; font-weight: 600;
    font-size: 16px; letter-spacing: -0.01em;
    color: var(--ed-ink, #0A0B0E);
  }
  .ed-reviews__rating {
    display: inline-flex; align-items: center; gap: 6px;
    margin-bottom: 12px;
  }
  .ed-reviews__score {
    font-family: "Inter", sans-serif; font-weight: 700; font-size: 14px;
    color: var(--ed-ink, #0A0B0E);
  }
  .ed-reviews__stars { display: inline-flex; gap: 2px; color: #FAB400; font-size: 15px; line-height: 1; }
  .ed-reviews__star.is-empty { color: rgba(0,0,0,0.18); }

  .ed-reviews__body {
    margin: 0;
    font-family: "Inter", sans-serif; font-size: 14px; line-height: 1.55;
    color: rgba(var(--color-foreground), 0.85);
  }

  .ed-reviews__cta-wrap {
    display: flex; justify-content: center;
    margin-top: 16px;
  }
  .ed-reviews__cta {
    display: inline-flex; align-items: center;
    padding: 12px 24px;
    background: transparent;
    border: 1.5px solid {{ accent }};
    border-radius: 999px;
    font-family: "Inter", sans-serif; font-weight: 600; font-size: 14px;
    color: {{ accent }};
    text-decoration: none;
    transition: background 120ms, color 120ms;
  }
  .ed-reviews__cta:hover { background: {{ accent }}; color: var(--ed-paper, #F4F0E8); }
</style>

<script>
  document.addEventListener('click', function(e) {
    const el = e.target.closest('[data-action="reviews_view_all"]');
    if (!el || !window.posthog) return;
    try { posthog.capture('reviews_view_all_click', { href: el.getAttribute('href') }); } catch (err) {}
  });
</script>

