{%- liquid
  assign _pt = section.settings.padding_top | default: 0
  assign _pb = section.settings.padding_bottom | default: 0
-%}
{% style %}
  #shopify-section-{{ section.id }} { padding-top: {{ _pt }}px !important; padding-bottom: {{ _pb }}px !important; }
{% endstyle %}
{%- liquid
  assign scheme = section.settings.color_scheme | default: 'scheme-1'
-%}
<div class="color-{{ scheme }} ed-section" style="background: rgb(var(--color-background));">
  <div class="ed-container" style="max-width: 760px;">
    {%- if section.settings.eyebrow != blank -%}
      <p class="ed-caption" style="color: var(--ed-text-mute); margin: 0 0 var(--sp-4);">{{ section.settings.eyebrow }}</p>
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <h1 class="ed-display-l" style="margin: 0 0 var(--sp-6);">{{ section.settings.heading }}</h1>
    {%- endif -%}

    {%- if section.settings.body != blank -%}
      <div class="ed-editorial ed-body-l" style="color: var(--ed-text); line-height: 1.7;">{{ section.settings.body }}</div>
    {%- endif -%}

    {%- for block in section.blocks -%}
      {%- case block.type -%}
        {%- when 'heading' -%}
          <h2 {{ block.shopify_attributes }} class="ed-display-m" style="margin: var(--sp-7) 0 var(--sp-4); font-size: 28px;">{{ block.settings.text }}</h2>
        {%- when 'paragraph' -%}
          <div {{ block.shopify_attributes }} class="ed-body-l" style="margin: 0 0 var(--sp-4); line-height: 1.7;">{{ block.settings.text }}</div>
        {%- when 'pull_quote' -%}
          <blockquote {{ block.shopify_attributes }} style="margin: var(--sp-6) 0; padding: var(--sp-5) 0 var(--sp-5) var(--sp-5); border-left: 2px solid var(--ed-electric); font-family: var(--font-ed-display); font-weight: 500; font-style: italic; font-size: 24px; letter-spacing: -0.02em; line-height: 1.3;">{{ block.settings.text }}</blockquote>
        {%- when 'image' -%}
          <figure {{ block.shopify_attributes }} style="margin: var(--sp-6) 0;">
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 1200 | image_tag: loading: 'lazy', widths: '600, 900, 1200', alt: block.settings.caption, style: 'width: 100%; border: 1.5px solid var(--ed-ink); border-radius: 2px;' }}
            {%- endif -%}
            {%- if block.settings.caption != blank -%}
              <figcaption class="ed-mono" style="font-size: 12px; color: var(--ed-text-mute); text-align: center; margin-top: var(--sp-3);">{{ block.settings.caption }}</figcaption>
            {%- endif -%}
          </figure>
        {%- when 'stat' -%}
          <div {{ block.shopify_attributes }} style="margin: var(--sp-5) 0; padding: var(--sp-4) 0; border-top: 2px solid var(--ed-ink); border-bottom: 1px solid var(--ed-border);">
            <p class="ed-display-m" style="margin: 0 0 4px; font-size: 40px;">{{ block.settings.value }}</p>
            <p class="ed-mono" style="margin: 0; color: var(--ed-text-mute); text-transform: uppercase; letter-spacing: .06em; font-size: 12px;">{{ block.settings.label }}</p>
          </div>
      {%- endcase -%}
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "ED Editorial",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "About"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "\u0926\u0941\u0915\u093e\u0928, scaled."
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body",
      "default": "<p>Ecomdukan is a bulk supplier of stationery and printer labels for D2C brands and businesses across India. We sit between the <em>kirana</em>-shop reliability our customers grew up with and the precision-grade output a modern fulfillment operation demands.</p>"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1",
      "options": [
        {
          "value": "scheme-1",
          "label": "Paper"
        },
        {
          "value": "scheme-2",
          "label": "Snow"
        }
      ]
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding (px)",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding (px)",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 0,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "heading",
      "name": "Heading",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Heading",
          "default": "Section heading"
        }
      ]
    },
    {
      "type": "paragraph",
      "name": "Paragraph",
      "settings": [
        {
          "type": "richtext",
          "id": "text",
          "label": "Body",
          "default": "<p>Paragraph copy here.</p>"
        }
      ]
    },
    {
      "type": "pull_quote",
      "name": "Pull quote",
      "settings": [
        {
          "type": "textarea",
          "id": "text",
          "label": "Quote",
          "default": "Operator-grade craft, dukan-level reliability."
        }
      ]
    },
    {
      "type": "image",
      "name": "Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "caption",
          "label": "Caption"
        }
      ]
    },
    {
      "type": "stat",
      "name": "Stat",
      "settings": [
        {
          "type": "text",
          "id": "value",
          "label": "Value",
          "default": "92%"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Orders ship within 24 hours"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "ED Editorial"
    }
  ]
}
{% endschema %}
