{%- liquid
  assign _pt = section.settings.padding_top | default: 0
  assign _pb = section.settings.padding_bottom | default: 0
-%}
{% style %}
  #shopify-section-{{ section.id }} { padding-top: {{ _pt }}px !important; padding-bottom: {{ _pb }}px !important; }
{% endstyle %}
{%- liquid
  assign scheme = section.settings.color_scheme | default: 'scheme-1'
  assign per_tab = section.settings.products_per_tab | default: 8
  assign layout = section.settings.layout | default: 'carousel'
-%}

<div class="color-{{ scheme }} ed-tabs-wrap" style="background: rgb(var(--color-background));">
  <div class="ed-container">

    <div class="ed-tabs-header">
      <div class="ed-tabs-title">
        {%- if section.settings.eyebrow != blank -%}
          <p class="ed-tabs-eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="ed-tabs-h">{{ section.settings.heading }}</h2>
        {%- endif -%}
      </div>
      <nav class="ed-tabs-nav" role="tablist" data-ed-tabs-nav>
        {%- for block in section.blocks -%}
          <button
            type="button"
            class="ed-tabs-tab{% if forloop.first %} is-active{% endif %}"
            role="tab"
            aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
            data-tab-id="{{ block.id }}"
            {{ block.shopify_attributes }}
          >{{ block.settings.label }}</button>
        {%- endfor -%}
      </nav>
    </div>

    {%- for block in section.blocks -%}
      {%- liquid
        assign coll = collections[block.settings.collection]
        assign products = coll.products
      -%}
      <div class="ed-tabs-panel{% if forloop.first %} is-active{% endif %}" role="tabpanel" data-tab-panel="{{ block.id }}" aria-hidden="{% if forloop.first %}false{% else %}true{% endif %}">
        {%- if products.size > 0 -%}
          {%- if layout == 'carousel' -%}
            <div class="ed-tabs-carousel">
              <button type="button" class="ed-tabs-cnav ed-tabs-cnav--prev" data-tab-nav="prev" aria-label="Previous">‹</button>
              <div class="ed-tabs-strip" data-tabs-strip>
                {%- for product in products limit: per_tab -%}
                  <div class="ed-tabs-cell">{%- render 'ed-product-card', product: product, qty_mode: 'chips' -%}</div>
                {%- endfor -%}
              </div>
              <button type="button" class="ed-tabs-cnav ed-tabs-cnav--next" data-tab-nav="next" aria-label="Next">›</button>
            </div>
          {%- else -%}
            <div class="ed-tabs-grid">
              {%- for product in products limit: per_tab -%}
                {%- render 'ed-product-card', product: product, qty_mode: 'chips' -%}
              {%- endfor -%}
            </div>
          {%- endif -%}
          {%- if coll.url -%}
            <div class="ed-tabs-cta">
              <a href="{{ coll.url }}" class="ed-btn ed-btn--ghost" data-action="tab_view_all" data-collection="{{ block.settings.collection }}">View all in {{ block.settings.label }} →</a>
            </div>
          {%- endif -%}
        {%- else -%}
          <div class="ed-tabs-empty">
            <p class="ed-caption" style="color: var(--ed-mute);">No products in this collection yet.</p>
            <p class="ed-body-s" style="color: var(--ed-text-mute);">Pick a different collection in the block settings, or add products to <strong>{{ block.settings.collection | default: 'this' }}</strong>.</p>
          </div>
        {%- endif -%}
      </div>
    {%- endfor -%}
  </div>
</div>

<style>
  .ed-tabs-wrap { padding-block: clamp(40px, 5vw, 64px); }

  .ed-tabs-header {
    display: flex; justify-content: space-between; align-items: flex-end;
    gap: 24px; flex-wrap: wrap;
    margin-bottom: 20px;
    border-bottom: 1.5px solid var(--ed-ink, #0A0B0E);
    padding-bottom: 0;
  }
  .ed-tabs-eyebrow {
    margin: 0 0 6px;
    font-family: "IBM Plex Mono", monospace;
    font-size: 11px; font-weight: 500;
    letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--ed-text-mute, #5C6068);
  }
  .ed-tabs-h {
    margin: 0;
    font-family: "Poppins", sans-serif; font-weight: 700;
    font-size: clamp(22px, 3vw, 32px); letter-spacing: -0.03em;
  }
  .ed-tabs-nav {
    display: flex; gap: 0;
    overflow-x: auto;
    scrollbar-width: none;
  }
  .ed-tabs-nav::-webkit-scrollbar { display: none; }
  .ed-tabs-tab {
    background: transparent;
    border: 0;
    border-bottom: 2px solid transparent;
    padding: 12px 16px;
    font-family: "Inter", sans-serif;
    font-weight: 500; font-size: 13px;
    color: var(--ed-text-mute, #5C6068);
    cursor: pointer;
    white-space: nowrap;
    transition: color 120ms, border-color 120ms;
    margin-bottom: -1.5px;
  }
  .ed-tabs-tab:hover { color: var(--ed-ink, #0A0B0E); }
  .ed-tabs-tab.is-active {
    color: var(--ed-electric, #1E5FFF);
    border-bottom-color: var(--ed-electric, #1E5FFF);
    font-weight: 600;
  }

  .ed-tabs-panel { display: none; padding-top: 20px; }
  .ed-tabs-panel.is-active { display: block; }

  /* Carousel */
  .ed-tabs-carousel { position: relative; }
  .ed-tabs-strip {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: minmax(0, calc((100% - 14px * 3) / 4));
    gap: 14px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
    padding: 4px 2px 12px;
  }
  .ed-tabs-strip::-webkit-scrollbar { display: none; }
  .ed-tabs-cell { scroll-snap-align: start; min-width: 0; }
  @media (max-width: 989px) { .ed-tabs-strip { grid-auto-columns: minmax(180px, 46%); gap: 12px; } }
  @media (max-width: 599px) { .ed-tabs-strip { grid-auto-columns: 78%; gap: 10px; } }

  .ed-tabs-cnav {
    position: absolute; top: 35%; transform: translateY(-50%);
    width: 36px; height: 36px; border-radius: 50%;
    background: var(--ed-snow, #FBFAF6);
    border: 1.5px solid var(--ed-ink, #0A0B0E);
    color: var(--ed-ink, #0A0B0E);
    font-size: 20px; font-weight: 600; line-height: 1;
    cursor: pointer; z-index: 3;
    display: none;
  }
  .ed-tabs-cnav--prev { left: -18px; }
  .ed-tabs-cnav--next { right: -18px; }
  @media (min-width: 750px) { .ed-tabs-cnav { display: inline-flex; align-items: center; justify-content: center; } }

  /* Grid */
  .ed-tabs-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 14px;
  }
  @media (max-width: 989px) { .ed-tabs-grid { grid-template-columns: repeat(2, 1fr); gap: 12px; } }

  /* CTA + empty */
  .ed-tabs-cta { text-align: center; margin-top: 20px; }
  .ed-tabs-empty { padding: 40px; text-align: center; border: 1px dashed var(--ed-border, #E0DBCF); }
</style>

<script>
  (function() {
    document.querySelectorAll('.ed-tabs-wrap').forEach(function(wrap) {
      const tabs = wrap.querySelectorAll('.ed-tabs-tab');
      const panels = wrap.querySelectorAll('.ed-tabs-panel');
      tabs.forEach(function(tab) {
        tab.addEventListener('click', function() {
          const id = tab.dataset.tabId;
          tabs.forEach(function(t) {
            const active = t === tab;
            t.classList.toggle('is-active', active);
            t.setAttribute('aria-selected', active ? 'true' : 'false');
          });
          panels.forEach(function(p) {
            const show = p.dataset.tabPanel === id;
            p.classList.toggle('is-active', show);
            p.setAttribute('aria-hidden', show ? 'false' : 'true');
          });
          if (window.posthog) try { posthog.capture('collection_tab_switch', { tab: tab.textContent.trim() }); } catch (e) {}
        });
      });

      // Carousel nav (scoped to each panel)
      wrap.querySelectorAll('[data-tab-nav]').forEach(function(btn) {
        btn.addEventListener('click', function() {
          const strip = btn.parentElement.querySelector('[data-tabs-strip]');
          if (!strip) return;
          const dir = btn.dataset.tabNav === 'next' ? 1 : -1;
          const cell = strip.querySelector('.ed-tabs-cell');
          const step = (cell ? cell.offsetWidth + 14 : strip.clientWidth) * 1;
          strip.scrollBy({ left: step * dir, behavior: 'smooth' });
        });
      });
    });
  })();
</script>

{% schema %}
{
  "name": "ED Collection tabs",
  "tag": "section",
  "class": "ed-tabs-section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Shop the catalog"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Pick a category to start"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout per tab",
      "default": "carousel",
      "options": [
        {
          "value": "carousel",
          "label": "Horizontal carousel"
        },
        {
          "value": "grid",
          "label": "Static grid"
        }
      ]
    },
    {
      "type": "range",
      "id": "products_per_tab",
      "label": "Products per tab",
      "min": 4,
      "max": 16,
      "step": 1,
      "default": 8
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1",
      "options": [
        {
          "value": "scheme-1",
          "label": "Paper"
        },
        {
          "value": "scheme-2",
          "label": "Snow"
        }
      ]
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding (px)",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding (px)",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 0,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "tab",
      "name": "Tab",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Tab label",
          "default": "Thermal labels"
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "ED Collection tabs",
      "blocks": [
        {
          "type": "tab",
          "settings": {
            "label": "Thermal labels"
          }
        },
        {
          "type": "tab",
          "settings": {
            "label": "Branded labels"
          }
        },
        {
          "type": "tab",
          "settings": {
            "label": "Office paper"
          }
        },
        {
          "type": "tab",
          "settings": {
            "label": "Packing supplies"
          }
        }
      ]
    }
  ]
}
{% endschema %}
