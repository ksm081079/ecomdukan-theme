{%- liquid
  assign _pt = section.settings.padding_top | default: 24
  assign _pb = section.settings.padding_bottom | default: 24
-%}
{% style %}
  #shopify-section-{{ section.id }} { padding-top: {{ _pt }}px !important; padding-bottom: {{ _pb }}px !important; }
{% endstyle %}
{%- liquid
  assign scheme = section.settings.color_scheme | default: 'scheme-2'
-%}
<div class="color-{{ scheme }} ed-section" style="background: rgb(var(--color-background));">
  <div class="ed-container">
    {%- if section.settings.heading != blank -%}
      <h2 class="ed-display-m" style="margin: 0 0 var(--sp-6);">{{ section.settings.heading }}</h2>
    {%- endif -%}

    <div style="display: grid; grid-template-columns: repeat({{ section.blocks.size | at_most: 4 }}, 1fr); gap: var(--sp-5);" class="ed-usecase-grid">
      {%- for block in section.blocks -%}
        <div {{ block.shopify_attributes }} style="display: flex; flex-direction: column; gap: var(--sp-3);">
          <div style="aspect-ratio: 4/5; border: 1.5px solid var(--ed-ink); border-radius: 2px; overflow: hidden; background: var(--ed-paper);">
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 800 | image_tag: loading: 'lazy', widths: '400, 600, 800', alt: block.settings.title, style: 'width:100%;height:100%;object-fit:cover;display:block;' }}
            {%- else -%}
              <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;color:var(--ed-mute);font-family:var(--font-ed-mono);font-size:11px;text-transform:uppercase;letter-spacing:.08em;">add image</div>
            {%- endif -%}
          </div>
          {%- if block.settings.eyebrow != blank -%}
            <p class="ed-caption" style="color: var(--ed-text-mute); margin: 0;">{{ block.settings.eyebrow }}</p>
          {%- endif -%}
          <h3 class="ed-title" style="margin: 0;">{{ block.settings.title }}</h3>
          {%- if block.settings.body != blank -%}
            <p class="ed-body-s" style="color: var(--ed-text-mute); margin: 0;">{{ block.settings.body }}</p>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

<style>
  @media (max-width: 989px) { .ed-usecase-grid { grid-template-columns: repeat(2, 1fr) !important; } }
  @media (max-width: 599px) { .ed-usecase-grid { grid-template-columns: 1fr !important; } }
</style>

{% schema %}
{
  "name": "ED Use cases",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Use cases"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-2",
      "options": [
        {
          "value": "scheme-1",
          "label": "Paper"
        },
        {
          "value": "scheme-2",
          "label": "Snow"
        }
      ]
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding (px)",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 24,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding (px)",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 24,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "case",
      "name": "Case",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "eyebrow",
          "label": "Eyebrow",
          "default": "Shipping"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "On the warehouse line"
        },
        {
          "type": "textarea",
          "id": "body",
          "label": "Body"
        }
      ]
    }
  ],
  "max_blocks": 4
}
{% endschema %}
