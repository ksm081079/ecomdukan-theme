{%- liquid
  assign _pt = section.settings.padding_top | default: 24
  assign _pb = section.settings.padding_bottom | default: 24
-%}
{% style %}
  #shopify-section-{{ section.id }} { padding-top: {{ _pt }}px !important; padding-bottom: {{ _pb }}px !important; }
{% endstyle %}
{%- liquid
  assign scheme = section.settings.color_scheme | default: 'scheme-1'
  assign layout = section.settings.layout | default: 'circles'
  assign circle_size = section.settings.circle_size | default: 84
-%}
<div class="color-{{ scheme }} ed-section ed-cat-wrap ed-cat-wrap--{{ layout }}" style="background: rgb(var(--color-background));">
  <div class="ed-container">
    {%- if section.settings.heading != blank -%}
      <div class="ed-cat-header">
        <h2 class="ed-cat-heading">{{ section.settings.heading }}</h2>
        {%- if section.settings.link_label != blank -%}
          <a href="{{ section.settings.link_url }}" class="ed-cat-headerlink">{{ section.settings.link_label }} →</a>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if layout == 'circles' -%}
      <ul class="ed-cat-circles" style="--ed-circle: {{ circle_size }}px;">
        {%- for block in section.blocks -%}
          <li {{ block.shopify_attributes }}>
            <a href="{{ block.settings.link | default: '#' }}" class="ed-cat-circle" data-cat="{{ block.settings.title | escape }}" data-pos="{{ forloop.index }}">
              <span class="ed-cat-circle__media">
                {%- if block.settings.image != blank -%}
                  {{ block.settings.image | image_url: width: 320 | image_tag: loading: 'lazy', widths: '160, 240, 320', alt: block.settings.title, class: 'ed-cat-circle__img' }}
                {%- else -%}
                  <span class="ed-cat-circle__placeholder">{{ block.settings.title | slice: 0, 1 | upcase }}</span>
                {%- endif -%}
              </span>
              <span class="ed-cat-circle__label">{{ block.settings.title }}</span>
            </a>
          </li>
        {%- endfor -%}
      </ul>
    {%- else -%}
      <div class="ed-cat-grid">
        {%- for block in section.blocks -%}
          <a href="{{ block.settings.link | default: '#' }}" class="ed-cat" {{ block.shopify_attributes }} data-cat="{{ block.settings.title | escape }}" data-pos="{{ forloop.index }}">
            <div class="ed-cat__media">
              {%- if block.settings.image != blank -%}
                {{ block.settings.image | image_url: width: 800 | image_tag: loading: 'lazy', widths: '400, 600, 800', alt: block.settings.title }}
              {%- else -%}
                <div class="ed-cat__noimg">No image</div>
              {%- endif -%}
            </div>
            <div class="ed-cat__body">
              <span class="ed-cat__t">{{ block.settings.title }}</span>
              <span class="ed-cat__arrow">→</span>
            </div>
          </a>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</div>

<style>
  .ed-cat-wrap { padding-block: var(--sp-5, 32px); }
  .ed-cat-header {
    display: flex; align-items: baseline; justify-content: space-between;
    gap: 16px; margin-bottom: 16px;
  }
  .ed-cat-heading {
    margin: 0;
    font-family: "Poppins", sans-serif; font-weight: 700;
    font-size: clamp(18px, 2.2vw, 24px); letter-spacing: -0.02em;
  }
  .ed-cat-headerlink {
    font-family: "Inter", sans-serif; font-weight: 600; font-size: 13px;
    color: var(--ed-electric, #1E5FFF); text-decoration: none;
    border-bottom: 1.5px solid currentColor; padding-bottom: 1px;
  }

  /* ----- Circles layout ----- */
  .ed-cat-circles {
    list-style: none; margin: 0; padding: 4px 0 12px;
    display: flex; gap: 18px;
    overflow-x: auto; overflow-y: hidden;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }
  .ed-cat-circles::-webkit-scrollbar { display: none; }
  .ed-cat-circles > li { scroll-snap-align: start; flex: 0 0 auto; }
  .ed-cat-circle {
    display: flex; flex-direction: column; align-items: center; gap: 6px;
    text-decoration: none; color: var(--ed-ink, #0A0B0E);
    width: var(--ed-circle);
  }
  .ed-cat-circle__media {
    width: var(--ed-circle); height: var(--ed-circle);
    border-radius: 50%;
    background: var(--ed-snow, #FBFAF6);
    border: 2px solid var(--ed-ink, #0A0B0E);
    overflow: hidden; display: block; position: relative;
    transition: transform 160ms ease, border-color 160ms ease;
  }
  .ed-cat-circle:hover .ed-cat-circle__media {
    transform: translateY(-2px);
    border-color: var(--ed-electric, #1E5FFF);
  }
  .ed-cat-circle__img {
    width: 100%; height: 100%; object-fit: cover; display: block;
  }
  .ed-cat-circle__placeholder {
    position: absolute; inset: 0;
    display: flex; align-items: center; justify-content: center;
    font-family: "Poppins", sans-serif; font-weight: 700; font-size: 28px;
    color: var(--ed-electric, #1E5FFF);
  }
  .ed-cat-circle__label {
    font-family: "Inter", sans-serif; font-weight: 500;
    font-size: 12px; line-height: 1.2; text-align: center;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ----- Tiles layout (legacy) ----- */
  .ed-cat-grid {
    display: grid; gap: 16px;
    grid-template-columns: repeat(4, 1fr);
  }
  @media (max-width: 989px) { .ed-cat-grid { grid-template-columns: repeat(2, 1fr); } }
  .ed-cat {
    display: block; text-decoration: none; color: var(--ed-ink, #0A0B0E);
    border: 1.5px solid var(--ed-ink, #0A0B0E); border-radius: 2px;
    background: var(--ed-snow, #FBFAF6); overflow: hidden;
  }
  .ed-cat__media { aspect-ratio: 4/3; overflow: hidden; }
  .ed-cat__media img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .ed-cat__noimg {
    width: 100%; height: 100%;
    display: flex; align-items: center; justify-content: center;
    background: var(--ed-paper, #F4F0E8); color: var(--ed-mute, #8A8E97);
    font-family: "IBM Plex Mono", monospace; font-size: 11px;
    text-transform: uppercase; letter-spacing: 0.08em;
  }
  .ed-cat__body {
    padding: 12px 16px;
    display: flex; justify-content: space-between; align-items: center;
  }
  .ed-cat__t { font-family: "Inter", sans-serif; font-weight: 600; font-size: 14px; }
  .ed-cat__arrow { font-family: "Poppins", sans-serif; font-weight: 700; color: var(--ed-electric, #1E5FFF); }
</style>

<script>
  (function() {
    document.addEventListener('click', function(e) {
      const link = e.target.closest('[data-cat]');
      if (!link) return;
      if (window.posthog) {
        posthog.capture('category_circle_click', {
          category: link.dataset.cat,
          position: parseInt(link.dataset.pos, 10) || null,
          href: link.getAttribute('href') || null
        });
      }
    });
  })();
</script>

{% schema %}
{
  "name": "ED Featured categories",
  "tag": "section",
  "class": "ed-cat-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop by category"
    },
    {
      "type": "text",
      "id": "link_label",
      "label": "Link label",
      "default": "All categories"
    },
    {
      "type": "url",
      "id": "link_url",
      "label": "Link URL"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "default": "circles",
      "options": [
        {
          "value": "circles",
          "label": "Horizontal circles (Instagram-story)"
        },
        {
          "value": "tiles",
          "label": "Large square tiles"
        }
      ]
    },
    {
      "type": "range",
      "id": "circle_size",
      "label": "Circle size (px)",
      "min": 64,
      "max": 120,
      "step": 4,
      "default": 84
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1",
      "options": [
        {
          "value": "scheme-1",
          "label": "Paper"
        },
        {
          "value": "scheme-2",
          "label": "Snow"
        }
      ]
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding (px)",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 24,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding (px)",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 24,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image (square)"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Thermal labels"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "max_blocks": 16,
  "presets": [
    {
      "name": "ED Categories (circles)",
      "blocks": [
        {
          "type": "category",
          "settings": {
            "title": "Thermal labels"
          }
        },
        {
          "type": "category",
          "settings": {
            "title": "Branded labels"
          }
        },
        {
          "type": "category",
          "settings": {
            "title": "Office paper"
          }
        },
        {
          "type": "category",
          "settings": {
            "title": "Packing supplies"
          }
        },
        {
          "type": "category",
          "settings": {
            "title": "Mailers"
          }
        },
        {
          "type": "category",
          "settings": {
            "title": "Tissue & kraft"
          }
        },
        {
          "type": "category",
          "settings": {
            "title": "Tags & tape"
          }
        },
        {
          "type": "category",
          "settings": {
            "title": "Custom print"
          }
        }
      ]
    }
  ]
}
{% endschema %}
