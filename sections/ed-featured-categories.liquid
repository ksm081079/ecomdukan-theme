{%- liquid
  assign scheme = section.settings.color_scheme | default: 'scheme-1'
-%}
<div class="color-{{ scheme }} ed-section" style="background: rgb(var(--color-background));">
  <div class="ed-container">
    {%- if section.settings.heading != blank -%}
      <div style="display: flex; align-items: baseline; justify-content: space-between; margin-bottom: var(--sp-6); gap: var(--sp-4);">
        <h2 class="ed-display-m" style="margin: 0;">{{ section.settings.heading }}</h2>
        {%- if section.settings.link_label != blank -%}
          <a href="{{ section.settings.link_url }}" class="ed-btn--link" style="font-family: var(--font-ed-body); font-weight: 600; font-size: 14px;">{{ section.settings.link_label }} →</a>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="ed-cat-grid">
      {%- for block in section.blocks -%}
        <a href="{{ block.settings.link | default: '#' }}" class="ed-cat" {{ block.shopify_attributes }}>
          <div class="ed-cat__media">
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 800 | image_tag: loading: 'lazy', widths: '400, 600, 800', alt: block.settings.title }}
            {%- else -%}
              <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;background:var(--ed-paper);color:var(--ed-mute);font-family:var(--font-ed-mono);font-size:11px;text-transform:uppercase;letter-spacing:.08em;">no image</div>
            {%- endif -%}
          </div>
          <div class="ed-cat__body">
            <span class="ed-cat__t">{{ block.settings.title }}</span>
            <span class="ed-cat__arrow">→</span>
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "ED Featured categories",
  "tag": "section",
  "class": "ed-cat-section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Shop by category" },
    { "type": "text", "id": "link_label", "label": "Link label", "default": "All categories" },
    { "type": "url",  "id": "link_url",   "label": "Link URL" },
    { "type": "select", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1",
      "options": [
        { "value": "scheme-1", "label": "Paper" },
        { "value": "scheme-2", "label": "Snow" }
      ]
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "title", "label": "Title", "default": "Thermal labels" },
        { "type": "url",  "id": "link",  "label": "Link" }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "ED Categories (4-up)",
      "blocks": [
        { "type": "category", "settings": { "title": "Thermal labels" } },
        { "type": "category", "settings": { "title": "Branded labels" } },
        { "type": "category", "settings": { "title": "Office paper" } },
        { "type": "category", "settings": { "title": "Packing supplies" } }
      ]
    }
  ]
}
{% endschema %}
