    },
    {
      "type": "header",
      "content": "Collection"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection",
      "info": "All products from this collection will appear in the grid below."
    },
    {
      "type": "header",
      "content": "Bundle Box"
    },
    {
      "type": "text",
      "id": "bundle_price_label",
      "label": "Price Label",
      "default": "RS."
    },
    {
      "type": "number",
      "id": "bundle_price",
      "label": "Bundle Price (in smallest currency unit, e.g. paise/cents)",
      "default": 59900,
      "info": "Enter price in smallest unit. E.g. ₹599 → 59900"
    },
    {
      "type": "text",
      "id": "add_to_cart_text",
