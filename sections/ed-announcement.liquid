{%- liquid
  assign rotate = section.settings.rotate_seconds | default: 6
-%}

{%- if section.blocks.size > 0 -%}
  <div class="ed-announce" data-ed-announce data-rotate="{{ rotate }}">
    {%- for block in section.blocks -%}
      <div class="ed-announce__msg{% if forloop.first %} is-active{% endif %}" {{ block.shopify_attributes }}>
        {%- if block.settings.link != blank -%}
          <a href="{{ block.settings.link }}" style="color: inherit; text-decoration: none;">{{ block.settings.text }}</a>
        {%- else -%}
          {{ block.settings.text }}
        {%- endif -%}
      </div>
    {%- endfor -%}
  </div>

  <script>
    (function () {
      var els = document.querySelectorAll('[data-ed-announce]');
      els.forEach(function (root) {
        var msgs = root.querySelectorAll('.ed-announce__msg');
        if (msgs.length < 2) return;
        var rotate = parseInt(root.dataset.rotate || '6', 10) * 1000;
        var i = 0;
        setInterval(function () {
          msgs[i].classList.remove('is-active');
          i = (i + 1) % msgs.length;
          msgs[i].classList.add('is-active');
        }, rotate);
      });
    })();
  </script>
{%- endif -%}

{% schema %}
{
  "name": "ED Announcement bar",
  "tag": "section",
  "settings": [
    { "type": "range", "id": "rotate_seconds", "label": "Rotate every (seconds)", "min": 3, "max": 12, "step": 1, "default": 6 }
  ],
  "blocks": [
    {
      "type": "message",
      "name": "Message",
      "settings": [
        { "type": "text", "id": "text", "label": "Text", "default": "Free shipping on orders above ₹2,500" },
        { "type": "url", "id": "link", "label": "Link (optional)" }
      ]
    }
  ],
  "max_blocks": 5,
  "presets": [
    {
      "name": "ED Announcement",
      "blocks": [
        { "type": "message", "settings": { "text": "Free shipping on orders above ₹2,500" } },
        { "type": "message", "settings": { "text": "GST invoice on every order" } },
        { "type": "message", "settings": { "text": "Reorder in one tap →" } }
      ]
    }
  ]
}
{% endschema %}
