{% style %}
  #shopify-section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  .custom-swiper-container .swiper-pagination {
    display: block;
    position: static;
    margin: 20px 0 0;
  }
  .custom-swiper-container .swiper-pagination .swiper-pagination-bullet.swiper-pagination-bullet-active{
    background: #BE6828;
  }
  .custom-swiper-container .swiper-pagination .swiper-pagination-bullet{
    background: #BE682866;
    margin: 0 6px;
    opacity: 1;
    width: 40px;
    height: 1px;
    border-radius: 0;
  }
  .custom-swiper-container .swiper-slide{
    height: auto;
  }
  .custom-swiper-container .swiper-slide .video-container{
    height: 100%;
  }
  .diy-mask .custom-swiper-container .swiper-slide .video-container video{
    max-height: 510px;
  }
   .custom-swiper-container .swiper-slide .video-container video{
     height: 100%;
     object-fit: cover;
     border-radius: 0;
     vertical-align: top;
     width: 100%;
   }
  .step-video .custom-swiper-container .swiper-slide .video-container video{
    border-radius: 10px 10px 0 0;
  }
  .testimonial-custom h2{
    margin: 0;
    text-align: center;
    color: #0E855B;
    font-size: 48px;
    font-weight: 700;
  }
  .testimonial-custom .sub-heading{
    text-align: center;
    color: #272724;
    font-size: 38px;
    font-weight: 500;
    margin: 0 0 24px;
  }
  .testimonial-custom .compare-fabric h2{
    text-align: left;
  }
  .compare-fabric .custom-swiper-container .swiper-slide.video-card{
    padding: 16px;
    background: #EAEAEA80;
  }
  .compare-fabric .custom-swiper-container .top-image{
    margin-bottom: 10px;
    height: 100%;
    max-height: fit-content;
  }
  .testimonial-custom .page-width{
    max-width: 100%;
    margin-inline: 95px;
    padding-inline: 0;
  }
  .video-thumbnail img{
    cursor: pointer;
  }
  .custom-next.swiper-button-next:after, .custom-prev.swiper-button-prev:after{
    display: none;
  }
  .custom-next.swiper-button-next, .custom-prev.swiper-button-prev{
    width: 40px;
    height: 40px;
    margin: 0;
  }
  .position-relative{
    position: relative;
  }
  .custom-next.swiper-button-next{
    right: -20px;
  }
  .custom-prev.swiper-button-prev{
    left: -20px;
  }
 .custom-swiper-container .top-image{
    height: auto;
  }
  .step-video .custom-swiper-container .top-image{
    height: auto;
  }
  .custom-swiper-container .top-image img{
    height: auto;
    width: 100%;
    vertical-align: top;
  }
  .mobile-img{
    display: none;
  }
  .custom-swiper-container .swiper-pagination{
    display: none;
  }
  @media screen and (max-width: 768px) {
    .compare-fabric .custom-swiper-container .mobile-img {
      margin-top: 25px;
    }
    .desktop-img{
      display: none;
    }
    .mobile-img{
      display: block;
    }
    .desktop-only{
      display: none;
    }
    #shopify-section-{{ section.id }} {
      padding-top: {{ section.settings.mobile_padding_top }}px;
      padding-bottom: {{ section.settings.mobile_padding_bottom }}px;
    }
    .diy-mask .custom-swiper-container .swiper-slide .video-container video{
      max-height: 335px;
    }
    .testimonial-custom h2{
      font-size: 28px;
    }
    .testimonial-custom .sub-heading{
      font-size: 24px;
      margin: 0 0 16px;
      line-height: 1.3;
    }
    .custom-swiper-container .swiper-pagination .swiper-pagination-bullet{
      width: 30px;
      margin: 0 4px;
    }
    .testimonial-custom .page-width{
      margin-inline: 10px;
    }
    .custom-swiper-container  .swiper-pagination{
      position: static;
      margin-top: 20px;
      height: 2px;
      background: #0000003D;
      margin-right: 10px;
      width: auto;
      display: block;
    }
    .custom-swiper-container  .swiper-pagination-progressbar .swiper-pagination-progressbar-fill{
      background: #000;
    }
    .compare-fabric .custom-swiper-container .swiper-slide.video-card{
      padding: 8px;
    }
  }
{% endstyle %}
<div class="fluid_container {{ section.settings.custom_class }}">
  {% if section.settings.heading != blank %}
    <h2>{{ section.settings.heading }}</h2>
  {% endif %}
  {% if section.settings.tag != blank %}<div class="sub-heading">{{ section.settings.tag }}</div>{% endif %}
  <div id="{{ section.id }}" class="position-relative">
    <div class="custom-swiper-container swiper">
      <div class="swiper-wrapper" id="swiper-wrapper">
        {% for block in section.blocks %}
          <div class="swiper-slide video-card">
          <div class="top-image">
            {% if block.settings.desktop_image != blank or block.settings.mobile_image != blank %}
              {% if block.settings.link != blank %}
                <a href="{{ block.settings.link }}" target="_blank">
              {% endif %}
              <img src="{{ block.settings.desktop_image | image_url }}" class="desktop-img">
              <img src="{{ block.settings.mobile_image | image_url }}" class="mobile-img">
              {% if block.settings.link != blank %}
                </a>
              {% endif %}
            {% endif %}
            {% if block.settings.video != blank %}
              {% if block.settings.thumbnail != blank %}
                <div class="video-thumbnail" style="position: relative;">
                  <img
                    src="{{ block.settings.thumbnail | img_url: 'master' }}"
                    alt="Video Thumbnail"
                    class="thumbnail-image"
                    style="width: 100%; height: auto;"
                  >
                </div>
              {% endif %}
              <div class="video-container" style="display: none;">
                {{ block.settings.video | video_tag: controls: true, autoplay: true, loop: true, muted: true }}
              </div>
            {% endif %}
          </div>
          {% if block.settings.desc_img != blank %}
            <img src="{{ block.settings.desc_img | image_url }}" class="desktop-img">
              <img src="{{ block.settings.desc_mbl_img | image_url }}" class="mobile-img">
            {% endif %}
          </div>
        {% endfor %}
      </div>
      <!-- Swiper Controls -->
      <div class="swiper-pagination"></div>
    </div>
    {% if section.settings.show_nav != blank %}
      <div class="swiper-button-prev custom-prev desktop-only">
        <svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="20" cy="20" r="20" transform="matrix(-1 0 0 1 40 0)" fill="white"/>
          <path d="M23 26L17 20L23 14" stroke="black" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
      <div class="swiper-button-next custom-next desktop-only">
        <svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="20" cy="20" r="20" fill="white"/>
          <path d="M17 26L23 20L17 14" stroke="black" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
    {% endif %}
  </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
       var container = document.querySelector("#{{ section.id }} .custom-swiper-container");
       var pagination = document.querySelector("#{{ section.id }} .swiper-pagination");
       var navnext = document.querySelector("#{{ section.id }} .custom-next");
       var navprev = document.querySelector("#{{ section.id }} .custom-prev");

        new Swiper(container, {
          slidesPerView: {{ section.settings.slides_desktop }},
          spaceBetween: 16,
          allowTouchMove: {{ section.settings.user_action }},
          navigation: {
            nextEl: navnext,
            prevEl: navprev
          },
          pagination: {
            el: pagination,
            type: "progressbar",
          },
          breakpoints: {
            0: {
              slidesPerView: {{ section.settings.slides_mobile }},
              spaceBetween: 10,
              allowTouchMove: true,
            },
            768: {
              slidesPerView: {{ section.settings.slides_tablet }},
              spaceBetween: 10,
            },
            1024: {
              slidesPerView: {{ section.settings.slider_leptop }},
              allowTouchMove: {{ section.settings.user_action }},
            },
            1440: {
              slidesPerView: {{ section.settings.slides_desktop }},
              allowTouchMove: {{ section.settings.user_action }},
            }
          }
        });
      });

  document.addEventListener("DOMContentLoaded", function () {
    const allVideos = [];

    document.querySelectorAll(".video-card").forEach(wrapper => {
      const thumbnail = wrapper.querySelector(".video-thumbnail");
      const videoContainer = wrapper.querySelector(".video-container");
      const video = videoContainer?.querySelector("video");

      if (thumbnail && videoContainer && video) {
        allVideos.push(video);

        thumbnail.addEventListener("click", () => {
          // Pause all other videos
          allVideos.forEach(v => {
            if (v !== video) {
              v.pause();
              v.currentTime = 0; // Optional: reset to beginning
              // Hide other video containers and show thumbnails again
              const otherWrapper = v.closest(".video-card");
              if (otherWrapper) {
                const otherThumbnail = otherWrapper.querySelector(".video-thumbnail");
                const otherContainer = otherWrapper.querySelector(".video-container");
                if (otherThumbnail && otherContainer) {
                  otherThumbnail.style.display = "block";
                  otherContainer.style.display = "none";
                }
              }
            }
          });

          // Play selected video
          thumbnail.style.display = "none";
          videoContainer.style.display = "block";
          video.play();
        });
      }
    });
  });
</script>

{% schema %}
{
  "name": "custom Slider",
  "class": "testimonial-custom",
  "settings": [
    {
      "type": "text",
      "id": "custom_class",
      "label": "Custom Class"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "text",
      "id": "tag",
      "label": "SubHeading"
    },
    {
      "type": "checkbox",
      "id": "user_action",
      "label": "User Action"
    },
    {
      "type": "checkbox",
      "id": "show_nav",
      "label": "Show Navigation"
    },
    {
      "type": "range",
      "id": "slides_mobile",
      "label": "Slides per view (Mobile)",
      "min": 1,
      "max": 3,
      "step": 0.1,
      "default": 1.5
    },
    {
      "type": "range",
      "id": "slides_tablet",
      "label": "Slides per view (tablet)",
      "min": 1,
      "max": 6,
      "step": 0.1,
      "default": 4
    },
    {
      "type": "range",
      "id": "slider_leptop",
      "label": "Slides per view (Leptop)",
      "min": 1,
      "max": 6,
      "step": 0.1,
      "default": 4
    },
    {
      "type": "range",
      "id": "slides_desktop",
      "label": "Slides per view (Desktop)",
      "min": 1,
      "max": 8,
      "step": 0.1,
      "default": 3
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 2,
      "unit": "px",
      "label": "Desktop Padding Top",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 2,
      "unit": "px",
      "label": "Desktop Padding Bottom",
      "default": 80
    },
    {
      "type": "range",
      "id": "mobile_padding_top",
      "min": 0,
      "max": 120,
      "step": 2,
      "unit": "px",
      "label": "Mobile Padding Top",
      "default": 40
    },
    {
      "type": "range",
      "id": "mobile_padding_bottom",
      "min": 0,
      "max": 120,
      "step": 2,
      "unit": "px",
      "label": "Mobile Padding Bottom",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "custom-slider",
      "name": "custom-slider",
      "settings": [
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "image_picker",
          "id": "desktop_image",
          "label": "Desktop Image",
          "info":"Dimesntion  in px : 270 X 314",
        },
        {
          "type": "image_picker",
          "id": "mobile_image",
          "label": "Mobile Image",
          "info":"Dimesntion  in px : 182 X 100",
        },
        {
          "type": "image_picker",
          "id": "thumbnail",
          "label": "Thumbnail Image",
          "info":"Dimension in  px:296 X 178",
        },
        {
          "type": "video",
          "id": "video",
          "label": "Video (upload or select Shopify-hosted)"
        },
        {
          "type": "image_picker",
          "id": "desc_img",
          "label": "Description Image",
          "info":"Dimension in  px:295 X 420",
        },
        {
          "type": "image_picker",
          "id": "desc_mbl_img",
          "label": "Description Mobile Image",
          "info":"Dimension in  px:100 X 196",
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "custom Slider",
      "category": "Custom"
    }
  ]
}
{% endschema %}
