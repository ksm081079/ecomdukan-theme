{% comment %}
  Bundle Pills Section
  Active class is applied when current page URL matches the button's link URL
{% endcomment %}

<div class="bundle-pills-section" id="bundle-pills-{{ section.id }}">
  <div class="bundle-pills-wrapper">
    {% for block in section.blocks %}
      {% if block.type == 'pill' %}
        {% assign pill_url = block.settings.link %}
        {% assign current_url = request.path %}

        {% comment %} Compare current path with pill link path {% endcomment %}
        {% assign pill_path = pill_url | split: '?' | first %}
        {% assign is_active = false %}

        {% if current_url == pill_path or request.path contains pill_path and pill_path != '/' %}
          {% assign is_active = true %}
        {% elsif pill_url contains '?' %}
          {% assign pill_full = pill_url | split: '?' %}
          {% assign pill_query = pill_full[1] %}
          {% if request.path == pill_full[0] and request.query_string == pill_query %}
            {% assign is_active = true %}
          {% endif %}
        {% endif %}

        <a
          href="{{ pill_url }}"
          class="bundle-pill {% if is_active %}active{% endif %}"
          {{ block.shopify_attributes }}
        >
          {{ block.settings.label }}
        </a>
      {% endif %}
    {% endfor %}
  </div>
</div>

<style>
  .bundle-pills-section {
    background-color: {{ section.settings.background_color }};
    padding: {{ section.settings.section_padding }}px 16px;
  }

  .bundle-pills-wrapper {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    align-items: center;
    justify-content: {{ section.settings.alignment }};
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
  }

  .bundle-pill {
    display: inline-flex;
    align-items: center;
    padding: 10px 20px;
    border-radius: 999px;
    border: 1.5px solid {{ section.settings.border_color }};
    background-color: transparent;
    color: {{ section.settings.text_color }};
    font-size: {{ section.settings.font_size }}px;
    font-family: inherit;
    font-weight: 500;
    text-decoration: none;
    white-space: nowrap;
    cursor: pointer;
    transition: background-color 0.2s ease, color 0.2s ease, border-color 0.2s ease;
  }

  .bundle-pill:hover {
    background-color: {{ section.settings.hover_bg_color }};
    color: {{ section.settings.hover_text_color }};
    border-color: {{ section.settings.hover_bg_color }};
  }

  .bundle-pill.active {
    background-color: {{ section.settings.active_bg_color }};
    color: {{ section.settings.active_text_color }};
    border-color: {{ section.settings.active_bg_color }};
  }

  @media (max-width: 768px) {
    .bundle-pills-wrapper {
      gap: 8px;
      justify-content: flex-start;
      overflow-x: auto;
      flex-wrap: nowrap;
      padding-bottom: 4px;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
    }

    .bundle-pills-wrapper::-webkit-scrollbar {
      display: none;
    }

    .bundle-pill {
      font-size: 13px;
      padding: 8px 16px;
      flex-shrink: 0;
    }
    .bundle-pills-section{
      padding: 20px 16px;
    }
  }
</style>

<script>
  (function () {
    // JS-based active detection as fallback (handles query strings & hash)
    var pills = document.querySelectorAll('#bundle-pills-{{ section.id }} .bundle-pill');
    var currentFull = window.location.pathname + window.location.search;

    pills.forEach(function (pill) {
      var href = pill.getAttribute('href');
      if (!href) return;

      // Normalize: strip domain if absolute URL
      var normalized = href.replace(/^https?:\/\/[^\/]+/, '');

      if (
        normalized === currentFull ||
        normalized === window.location.pathname ||
        (normalized.length > 1 && currentFull.startsWith(normalized))
      ) {
        // Remove active from all, set only on matched
        pills.forEach(function (p) { p.classList.remove('active'); });
        pill.classList.add('active');
      }
    });
  })();
</script>

