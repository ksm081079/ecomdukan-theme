{%- liquid
  assign _pt = section.settings.padding_top | default: 0
  assign _pb = section.settings.padding_bottom | default: 0
-%}
{% style %}
  #shopify-section-{{ section.id }} { padding-top: {{ _pt }}px !important; padding-bottom: {{ _pb }}px !important; }
{% endstyle %}
{%- liquid
  assign scheme = section.settings.color_scheme | default: 'scheme-1'
-%}
<div class="color-{{ scheme }} ed-section" style="background: rgb(var(--color-background));">
  <div class="ed-container" style="max-width: 880px;">
    <div style="display: grid; grid-template-columns: 1fr 2fr; gap: var(--sp-7); align-items: start;" class="ed-faq-grid">
      <div>
        {%- if section.settings.eyebrow != blank -%}
          <p class="ed-caption" style="color: var(--ed-text-mute); margin: 0 0 var(--sp-3);">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="ed-display-m" style="margin: 0 0 var(--sp-4);">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.body != blank -%}
          <p class="ed-body" style="color: var(--ed-text-mute);">{{ section.settings.body }}</p>
        {%- endif -%}
      </div>
      <div>
        {%- for block in section.blocks -%}
          <details {{ block.shopify_attributes }} style="border-top: 1.5px solid var(--ed-ink); padding: var(--sp-4) 0;">
            <summary class="ed-headline" style="cursor: pointer; list-style: none; display: flex; justify-content: space-between; align-items: center; gap: var(--sp-4); font-size: 18px; font-weight: 600; color: var(--ed-ink);">
              <span>{{ block.settings.question }}</span>
              <span class="ed-mono" style="font-size: 18px;">+</span>
            </summary>
            <div class="ed-body" style="color: var(--ed-text-mute); padding-top: var(--sp-3);">{{ block.settings.answer }}</div>
          </details>
        {%- endfor -%}
        <div style="border-top: 1.5px solid var(--ed-ink);"></div>
      </div>
    </div>
  </div>
</div>

<style>
  @media (max-width: 749px) { .ed-faq-grid { grid-template-columns: 1fr !important; gap: var(--sp-5) !important; } }
  details[open] summary span:last-child { transform: rotate(45deg); transition: transform 120ms; }
  summary { -webkit-tap-highlight-color: transparent; }
  summary::-webkit-details-marker { display: none; }
</style>

{% schema %}
{
  "name": "ED FAQ",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "FAQ"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Questions, answered"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Intro body"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1",
      "options": [
        {
          "value": "scheme-1",
          "label": "Paper"
        },
        {
          "value": "scheme-2",
          "label": "Snow"
        }
      ]
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding (px)",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding (px)",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 0,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "qa",
      "name": "Q&A",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "Do you offer GST invoices?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer",
          "default": "<p>Yes \u2014 every order ships with a GST-compliant invoice. Enter your GSTIN at checkout.</p>"
        }
      ]
    }
  ],
  "max_blocks": 16
}
{% endschema %}
