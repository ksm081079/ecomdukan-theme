{%- liquid
  assign scheme = section.settings.color_scheme | default: 'scheme-1'
-%}
<div class="color-{{ scheme }} ed-section" style="background: rgb(var(--color-background)); padding-block: var(--sp-6);">
  <div class="ed-container">
    <div class="ed-usp-strip">
      {%- for block in section.blocks -%}
        <div class="ed-usp" {{ block.shopify_attributes }}>
          <h3 class="ed-usp__head">{{ block.settings.heading }}</h3>
          <p class="ed-usp__sub">{{ block.settings.sub }}</p>
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "ED USP strip",
  "tag": "section",
  "class": "ed-usp-section",
  "settings": [
    { "type": "select", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1",
      "options": [
        { "value": "scheme-1", "label": "Paper" },
        { "value": "scheme-2", "label": "Snow" }
      ]
    }
  ],
  "blocks": [
    {
      "type": "promise",
      "name": "Promise",
      "settings": [
        { "type": "text", "id": "heading", "label": "Headline", "default": "In stock, in spec." },
        { "type": "textarea", "id": "sub", "label": "Sub", "default": "What's on the page is in the warehouse, today." }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "ED USP — four promises",
      "blocks": [
        { "type": "promise", "settings": { "heading": "In stock, in spec.", "sub": "What's on the page is in the warehouse, today." } },
        { "type": "promise", "settings": { "heading": "Made for the line.", "sub": "Engineered for thermal printers and packing tables." } },
        { "type": "promise", "settings": { "heading": "Receipts you'd frame.", "sub": "Invoices and packaging that match your brand." } },
        { "type": "promise", "settings": { "heading": "Reorder in one tap.", "sub": "Procurement should not be project work." } }
      ]
    }
  ]
}
{% endschema %}
