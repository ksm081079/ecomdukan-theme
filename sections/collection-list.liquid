{%- liquid
  assign cols_d = section.settings.columns_desktop
  assign cols_m = section.settings.columns_mobile | plus: 0
  if cols_m == 0
    assign cols_m = 2
  endif
-%}

{%- style -%}
  .ed-cl-{{ section.id }} {
    padding: {{ section.settings.padding_top }}px 24px {{ section.settings.padding_bottom }}px;
    max-width: {{ settings.page_width }}px;
    margin: 0 auto;
    box-sizing: border-box;
  }
  @media (max-width: 749px) {
    .ed-cl-{{ section.id }} {
      padding-left: 16px;
      padding-right: 16px;
      padding-top: {{ section.settings.padding_top | times: 0.6 | round }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.6 | round }}px;
    }
  }
  .ed-cl-{{ section.id }} .ed-cl__grid {
    grid-template-columns: repeat({{ cols_d }}, 1fr);
  }
  @media (max-width: 749px) {
    .ed-cl-{{ section.id }} .ed-cl__grid {
      grid-template-columns: repeat({{ cols_m }}, 1fr);
    }
  }
{%- endstyle -%}

<div class="ed-cl ed-cl-{{ section.id }}">
  {%- unless section.settings.title == blank -%}
    <h2 class="ed-cl__heading">{{ section.settings.title }}</h2>
  {%- endunless -%}

  {%- if section.blocks.size > 0 -%}
    <div class="ed-cl__grid">
      {%- for block in section.blocks -%}
        {%- assign col = block.settings.collection -%}
        {%- assign display_title = block.settings.title -%}
        {%- if display_title == blank -%}
          {%- assign display_title = col.title -%}
        {%- endif -%}
        {%- if col.featured_image -%}
          {%- assign card_image = col.featured_image -%}
        {%- elsif col.products.first.featured_image -%}
          {%- assign card_image = col.products.first.featured_image -%}
        {%- else -%}
          {%- assign card_image = nil -%}
        {%- endif -%}

        <a
          href="{{ col.url | default: '#' }}"
          class="ed-cl__card"
          aria-label="{{ display_title | escape }}"
          {{ block.shopify_attributes }}
        >
          <div class="ed-cl__media">
            {%- if card_image -%}
              <img
                class="ed-cl__img"
                src="{{ card_image | image_url: width: 600 }}"
                srcset="{{ card_image | image_url: width: 300 }} 300w,
                        {{ card_image | image_url: width: 600 }} 600w,
                        {{ card_image | image_url: width: 900 }} 900w"
                sizes="(min-width: 990px) calc({{ settings.page_width }}px / {{ cols_d }}), (min-width: 750px) 33vw, 50vw"
                alt="{{ card_image.alt | default: display_title | escape }}"
                loading="lazy"
                width="{{ card_image.width }}"
                height="{{ card_image.height }}"
              >
            {%- else -%}
              <div class="ed-cl__noimg">{{ display_title | slice: 0, 1 | upcase }}</div>
            {%- endif -%}
          </div>
          <h3 class="ed-cl__title">{{ display_title }}</h3>
        </a>
      {%- endfor -%}
    </div>
  {%- endif -%}
</div>

<style>
  .ed-cl__heading {
    margin: 0 0 14px;
    font-family: 'Poppins', sans-serif;
    font-weight: 700;
    font-size: 22px;
    line-height: 1.2;
    color: var(--ed-ink, #0A0B0E);
  }
  .ed-cl__grid {
    display: grid;
    gap: 16px;
  }
  .ed-cl__card {
    display: block;
    color: inherit;
    text-decoration: none;
    border: 1px solid var(--ed-border, #E0DBCF);
    border-radius: 12px;
    overflow: hidden;
    background: #fff;
    transition: border-color 120ms ease, transform 120ms ease;
  }
  .ed-cl__card:hover,
  .ed-cl__card:focus-visible {
    border-color: var(--ed-ink, #0A0B0E);
    transform: translateY(-2px);
  }
  .ed-cl__media {
    position: relative;
    width: 100%;
    aspect-ratio: 1 / 1;
    background: var(--ed-snow, #FBFAF6);
    overflow: hidden;
  }
  .ed-cl__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }
  .ed-cl__noimg {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Poppins', sans-serif;
    font-weight: 700;
    font-size: 48px;
    color: var(--ed-text-mute, #5C6068);
    opacity: 0.4;
  }
  .ed-cl__title {
    margin: 0;
    padding: 10px 12px 12px;
    font-family: 'Poppins', sans-serif;
    font-weight: 600;
    font-size: 14px;
    line-height: 1.3;
    color: var(--ed-ink, #0A0B0E);
  }
  @media (max-width: 749px) {
    .ed-cl__heading { font-size: 18px; margin-bottom: 10px; }
    .ed-cl__grid { gap: 12px; }
    .ed-cl__title { padding: 8px 10px 10px; font-size: 13px; }
  }
</style>

{% schema %}
{
  "name": "Collection list",
  "tag": "section",
  "class": "section section-collection-list",
  "max_blocks": 15,
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "inline_richtext",
      "id": "title",
      "default": "Collections",
      "label": "Heading"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 4,
      "label": "Columns on desktop"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ],
      "default": "2",
      "label": "Columns on mobile"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom",
      "default": 16
    }
  ],
  "blocks": [
    {
      "type": "featured_collection",
      "name": "Collection",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Display name (override)",
          "info": "Leave blank to use the collection’s own title."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection list",
      "blocks": [
        { "type": "featured_collection" },
        { "type": "featured_collection" },
        { "type": "featured_collection" },
        { "type": "featured_collection" }
      ]
    }
  ]
}
{% endschema %}
