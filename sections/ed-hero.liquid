{%- liquid
  assign _pt = section.settings.padding_top | default: 0
  assign _pb = section.settings.padding_bottom | default: 0
-%}
{% style %}
  #shopify-section-{{ section.id }} { padding-top: {{ _pt }}px !important; padding-bottom: {{ _pb }}px !important; }
{% endstyle %}
{%- comment -%}
  ED Hero — 11-may-style full-bleed slideshow carousel.
  Each block = one slide with desktop image + mobile image + optional text overlay.
  Autoplay + arrows + dots. Pure CSS/JS (no swiper).
{%- endcomment -%}

{%- liquid
  assign scheme = section.settings.color_scheme | default: 'scheme-1'
  assign dh = section.settings.desktop_height | default: 800
  assign mh = section.settings.mobile_height | default: 480
  assign effect = section.settings.slide_effect | default: 'slide'
  assign autoplay = section.settings.autoplay
  assign speed = section.settings.autoplay_speed | default: 6
  assign show_arrows = section.settings.show_arrows
  assign show_dots = section.settings.show_dots
  assign id = section.id
-%}

<div class="ed-hero ed-hero--slideshow ed-hero--{{ effect }} color-{{ scheme }}" data-ed-hero data-effect="{{ effect }}" data-autoplay="{{ autoplay }}" data-speed="{{ speed }}" style="--dh: {{ dh }}px; --mh: {{ mh }}px;">
  {%- if section.blocks.size > 0 -%}
    <div class="ed-hero__track" data-ed-hero-track>
      {%- for block in section.blocks -%}
        {%- assign desk = block.settings.image -%}
        {%- assign mob = block.settings.image_mobile | default: block.settings.image -%}
        {%- assign h = block.settings.heading | strip_newlines | escape -%}
        {%- if block.settings.link != blank -%}
          {%- assign slide_href = block.settings.link -%}
        {%- elsif block.settings.cta_link != blank -%}
          {%- assign slide_href = block.settings.cta_link -%}
        {%- else -%}
          {%- assign slide_href = routes.all_products_collection_url -%}
        {%- endif -%}
        {%- assign overlay = block.settings.overlay_opacity | default: 0 -%}
        <div class="ed-hero__slide{% if forloop.first %} is-active{% endif %}" data-ed-slide="{{ forloop.index0 }}" {{ block.shopify_attributes }}>
          <a href="{{ slide_href }}" class="ed-hero__link" data-action="hero_slide" data-slide="{{ forloop.index }}" aria-label="Slide {{ forloop.index }}"><span class="visually-hidden">View</span></a>
          {%- if overlay > 0 -%}
            <div class="ed-hero__overlay" style="background: rgba(0,0,0,{{ overlay | divided_by: 100.0 }});"></div>
          {%- endif -%}
          <picture class="ed-hero__media">
            {%- if mob != blank -%}
              <source media="(max-width: 749px)" srcset="{{ mob | image_url: width: 900 }} 1x, {{ mob | image_url: width: 1400 }} 2x">
            {%- endif -%}
            {%- if desk != blank -%}
              {%- if forloop.first -%}{%- assign loadattr = 'eager' -%}{%- else -%}{%- assign loadattr = 'lazy' -%}{%- endif -%}
              {{ desk | image_url: width: 2400 | image_tag:
                loading: loadattr,
                widths: '900, 1400, 1800, 2400',
                sizes: '100vw',
                alt: h,
                class: 'ed-hero__img' }}
            {%- else -%}
              <div class="ed-hero__placeholder">
                <img src="{{ 'ed-mark.svg' | asset_url }}" alt="" width="80">
              </div>
            {%- endif -%}
          </picture>
          {%- if block.settings.heading != blank or block.settings.subheading != blank or block.settings.cta_label != blank -%}
            {%- assign content_pos = block.settings.content_position | default: 'bottom-left' -%}
            <div class="ed-hero__content ed-hero__content--{{ content_pos }}">
              {%- if block.settings.subheading != blank -%}
                <p class="ed-hero__eyebrow">{{ block.settings.subheading }}</p>
              {%- endif -%}
              {%- if block.settings.heading != blank -%}
                <h2 class="ed-hero__h">{{ block.settings.heading }}</h2>
              {%- endif -%}
              {%- if block.settings.description != blank -%}
                <p class="ed-hero__sub">{{ block.settings.description }}</p>
              {%- endif -%}
              {%- if block.settings.cta_label != blank -%}
                <a href="{{ block.settings.cta_link | default: '#' }}" class="ed-btn ed-btn--primary ed-btn--lg ed-hero__cta" data-action="hero_cta" data-slide="{{ forloop.index }}">{{ block.settings.cta_label }}</a>
              {%- endif -%}
            </div>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>

    {%- if section.blocks.size > 1 -%}
      {%- if show_arrows -%}
        <button type="button" class="ed-hero__nav ed-hero__nav--prev" aria-label="Previous slide" data-ed-hero-prev>‹</button>
        <button type="button" class="ed-hero__nav ed-hero__nav--next" aria-label="Next slide" data-ed-hero-next>›</button>
      {%- endif -%}
      {%- if show_dots -%}
        <div class="ed-hero__dots" role="tablist" aria-label="Slides">
          {%- for block in section.blocks -%}
            <button type="button" class="ed-hero__dot{% if forloop.first %} is-active{% endif %}" data-ed-hero-dot="{{ forloop.index0 }}" aria-label="Slide {{ forloop.index }}"></button>
          {%- endfor -%}
        </div>
      {%- endif -%}
    {%- endif -%}
  {%- else -%}
    <div class="ed-hero__empty">
      <p>Add a slide block in the theme editor to populate the hero.</p>
    </div>
  {%- endif -%}
</div>

<style>
  /* Force the section wrapper to butt against the header above + section below */
  .shopify-section.ed-hero-section,
  .section.ed-section-flush,
  .shopify-section.ed-section-flush {
    margin-top: 0 !important;
    margin-bottom: 0 !important;
    padding-top: 0 !important;
    padding-bottom: 0 !important;
  }
  .ed-hero {
    position: relative;
    width: 100%;
    height: var(--dh);
    overflow: hidden;
    background: var(--ed-paper, #F4F0E8);
    display: block;
  }
  .ed-hero__track {
    position: relative;
    width: 100%;
    height: 100%;
  }
  /* Effect: fade (default fallback) */
  .ed-hero--fade .ed-hero__track { display: block; }
  .ed-hero--fade .ed-hero__slide {
    position: absolute; inset: 0;
    opacity: 0; visibility: hidden;
    transition: opacity 600ms ease;
    cursor: pointer;
  }
  .ed-hero--fade .ed-hero__slide.is-active { opacity: 1; visibility: visible; z-index: 1; }

  /* Effect: slide (taos default — translateX horizontal slide) */
  .ed-hero--slide .ed-hero__track {
    display: flex;
    width: 100%; height: 100%;
    transition: transform 600ms cubic-bezier(0.4, 0, 0.2, 1);
    will-change: transform;
  }
  .ed-hero--slide .ed-hero__slide {
    position: relative;
    flex: 0 0 100%;
    width: 100%; height: 100%;
    cursor: pointer;
    overflow: hidden;
  }

  /* Per-slide dark overlay (controlled by block.overlay_opacity 0-90) */
  .ed-hero__overlay {
    position: absolute; inset: 0;
    z-index: 1;
    pointer-events: none;
  }
  .ed-hero__link {
    position: absolute;
    inset: 0;
    z-index: 3;
    display: block;
    width: 100%;
    height: 100%;
    text-decoration: none;
    color: inherit;
    cursor: pointer;
  }
  /* Content + CTA need to sit above the slide-wide link so the CTA itself is clickable */
  .ed-hero__content { z-index: 4; pointer-events: none; }
  .ed-hero__content .ed-hero__cta { pointer-events: auto; position: relative; z-index: 5; }
  .ed-hero__media {
    position: absolute;
    inset: 0;
    display: block;
    pointer-events: none;
  }
  .ed-hero__img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center;
    display: block;
    background: var(--ed-paper, #F4F0E8);
    pointer-events: none;
    user-select: none;
    -webkit-user-drag: none;
  }
  .ed-hero__placeholder {
    width: 100%; height: 100%;
    display: flex; align-items: center; justify-content: center;
    background: var(--ed-snow, #FBFAF6);
    opacity: 0.6;
  }

  /* Content overlay */
  .ed-hero__content {
    position: absolute;
    z-index: 2;
    max-width: 600px;
    padding: 24px;
    color: #fff;
    text-shadow: 0 2px 16px rgba(10,11,14,0.4);
  }
  .ed-hero__content--bottom-left   { left: 32px; bottom: 32px; }
  .ed-hero__content--bottom-right  { right: 32px; bottom: 32px; text-align: right; }
  .ed-hero__content--bottom-center { left: 50%; bottom: 32px; transform: translateX(-50%); text-align: center; }
  .ed-hero__content--top-left      { left: 32px; top: 32px; }
  .ed-hero__content--top-right     { right: 32px; top: 32px; text-align: right; }
  .ed-hero__content--center        { left: 50%; top: 50%; transform: translate(-50%, -50%); text-align: center; }
  .ed-hero__eyebrow {
    margin: 0 0 8px;
    font-family: "IBM Plex Mono", monospace;
    font-size: 12px; font-weight: 500;
    letter-spacing: 0.08em; text-transform: uppercase;
  }
  .ed-hero__h {
    margin: 0 0 12px;
    font-family: "Poppins", sans-serif; font-weight: 700;
    font-size: clamp(32px, 5.4vw, 70px);
    letter-spacing: -0.03em; line-height: 1.02;
    color: #fff;
  }
  .ed-hero__sub {
    margin: 0 0 20px;
    font-family: "Inter", sans-serif;
    font-size: clamp(14px, 1.4vw, 18px); line-height: 1.5;
  }
  .ed-hero__cta { margin-top: 8px; }

  /* Nav arrows */
  .ed-hero__nav {
    position: absolute;
    top: 50%; transform: translateY(-50%);
    width: 44px; height: 44px;
    border-radius: 50%;
    background: rgba(255,255,255,0.92);
    border: 0;
    color: var(--ed-ink, #0A0B0E);
    font-size: 28px; line-height: 1;
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    box-shadow: 0 4px 12px rgba(10,11,14,0.15);
    z-index: 3;
    transition: background 120ms;
  }
  .ed-hero__nav:hover { background: #fff; }
  .ed-hero__nav--prev { left: 24px; }
  .ed-hero__nav--next { right: 24px; }

  /* Dots */
  .ed-hero__dots {
    position: absolute;
    bottom: 20px; left: 50%;
    transform: translateX(-50%);
    display: flex; gap: 8px;
    z-index: 3;
  }
  .ed-hero__dot {
    width: 8px; height: 8px;
    padding: 0;
    border-radius: 50%;
    background: rgba(255,255,255,0.4);
    border: 0;
    cursor: pointer;
    transition: background 120ms, width 120ms;
  }
  .ed-hero__dot.is-active {
    background: #fff;
    width: 24px;
    border-radius: 4px;
  }

  .ed-hero__empty {
    padding: 80px 24px;
    text-align: center;
    color: var(--ed-text-mute, #5C6068);
  }

  /* Mobile */
  @media (max-width: 749px) {
    .ed-hero { height: var(--mh); }
    .ed-hero__content { padding: 16px; max-width: calc(100% - 32px); }
    .ed-hero__content--bottom-left, .ed-hero__content--bottom-right, .ed-hero__content--bottom-center { bottom: 60px; }
    .ed-hero__content--bottom-left { left: 16px; right: 16px; }
    .ed-hero__content--bottom-right { right: 16px; left: 16px; }
    .ed-hero__h { font-size: clamp(20px, 6vw, 32px); margin-bottom: 8px; }
    .ed-hero__sub { font-size: 13px; margin-bottom: 12px; }
    .ed-hero__nav { width: 36px; height: 36px; font-size: 22px; }
    .ed-hero__nav--prev { left: 8px; }
    .ed-hero__nav--next { right: 8px; }
    .ed-hero__dots { bottom: 14px; }
  }
</style>

<script>
  /* Hard-strip ALL inherited spacing around hero so it sits flush against the header above + section below.
     Runs on DOMContentLoaded so the next/previous siblings are fully parsed. */
  (function() {
    const apply = function() {
      const hero = document.querySelector('.ed-hero');
      if (!hero) return;
      let el = hero;
      while (el && !el.classList.contains('shopify-section')) el = el.parentElement;
      if (!el) return;
      const flush = function(node) {
        if (!node) return;
        node.style.setProperty('margin-top', '0', 'important');
        node.style.setProperty('margin-bottom', '0', 'important');
        node.style.setProperty('padding-top', '0', 'important');
        node.style.setProperty('padding-bottom', '0', 'important');
      };
      flush(el);
      flush(el.previousElementSibling);
      const next = el.nextElementSibling;
      flush(next);
      /* Also strip the top padding of any descendant inside the next section */
      if (next) {
        next.querySelectorAll('section, .ed-section, .ed-cat-wrap, .ed-bs, [class*="ed-"]').forEach(function(n) {
          n.style.setProperty('padding-top', '0', 'important');
          n.style.setProperty('margin-top', '0', 'important');
        });
      }
      const main = document.getElementById('MainContent');
      if (main) {
        main.style.setProperty('margin-top', '0', 'important');
        main.style.setProperty('padding-top', '0', 'important');
      }
    };
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', apply);
    } else {
      apply();
    }
  })();
</script>
<script>
  (function() {
    const root = document.querySelector('[data-ed-hero]');
    if (!root) return;
    const track = root.querySelector('[data-ed-hero-track]');
    const slides = Array.from(root.querySelectorAll('.ed-hero__slide'));
    if (slides.length < 2) return;
    const dots = Array.from(root.querySelectorAll('[data-ed-hero-dot]'));
    const prev = root.querySelector('[data-ed-hero-prev]');
    const next = root.querySelector('[data-ed-hero-next]');
    const autoplay = root.dataset.autoplay === 'true';
    const speedMs = (parseFloat(root.dataset.speed) || 6) * 1000;
    const effect = root.dataset.effect || 'slide';
    let current = 0;
    let timer = null;
    const show = function(i) {
      if (i < 0) i = slides.length - 1;
      if (i >= slides.length) i = 0;
      current = i;
      if (effect === 'slide' && track) {
        track.style.transform = 'translateX(-' + (i * 100) + '%)';
      }
      slides.forEach(function(s, idx) { s.classList.toggle('is-active', idx === i); });
      dots.forEach(function(d, idx) { d.classList.toggle('is-active', idx === i); });
    };
    const start = function() {
      if (!autoplay) return;
      stop();
      timer = setInterval(function() { show(current + 1); }, speedMs);
    };
    const stop = function() { if (timer) { clearInterval(timer); timer = null; } };
    if (prev) prev.addEventListener('click', function() { show(current - 1); start(); });
    if (next) next.addEventListener('click', function() { show(current + 1); start(); });
    dots.forEach(function(d, i) { d.addEventListener('click', function() { show(i); start(); }); });
    root.addEventListener('mouseenter', stop);
    root.addEventListener('mouseleave', start);

    // Touch swipe (mobile)
    let touchX = null;
    root.addEventListener('touchstart', function(e) { touchX = e.touches[0].clientX; stop(); }, { passive: true });
    root.addEventListener('touchend', function(e) {
      if (touchX == null) return;
      const dx = e.changedTouches[0].clientX - touchX;
      if (Math.abs(dx) > 50) show(dx < 0 ? current + 1 : current - 1);
      touchX = null;
      start();
    }, { passive: true });

    start();

    // Tracking
    document.addEventListener('click', function(e) {
      const el = e.target.closest('[data-action="hero_cta"], [data-action="hero_slide"]');
      if (!el || !window.posthog) return;
      try { posthog.capture(el.dataset.action, { slide: el.dataset.slide, href: el.getAttribute('href') }); } catch (err) {}
    });
  })();
</script>

{% schema %}
{
  "name": "ED Hero",
  "tag": "section",
  "class": "ed-hero-section ed-section-flush",
  "settings": [
    {
      "type": "range",
      "id": "desktop_height",
      "label": "Desktop height (px)",
      "min": 360,
      "max": 1000,
      "step": 20,
      "default": 800
    },
    {
      "type": "select",
      "id": "slide_effect",
      "label": "Slide transition",
      "default": "slide",
      "options": [
        { "value": "slide", "label": "Slide (horizontal)" },
        { "value": "fade",  "label": "Fade (cross-fade)" }
      ]
    },
    {
      "type": "range",
      "id": "mobile_height",
      "label": "Mobile height (px)",
      "min": 280,
      "max": 800,
      "step": 20,
      "default": 480
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Autoplay",
      "default": true
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "label": "Autoplay speed (seconds)",
      "min": 3,
      "max": 12,
      "step": 1,
      "default": 6
    },
    {
      "type": "checkbox",
      "id": "show_arrows",
      "label": "Show arrows",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_dots",
      "label": "Show dots",
      "default": true
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1",
      "options": [
        {
          "value": "scheme-1",
          "label": "Paper"
        },
        {
          "value": "scheme-2",
          "label": "Snow"
        },
        {
          "value": "scheme-3",
          "label": "Indigo"
        },
        {
          "value": "scheme-4",
          "label": "Ink"
        }
      ]
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding (px)",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding (px)",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 0,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Desktop image (use ~2400px wide)"
        },
        {
          "type": "image_picker",
          "id": "image_mobile",
          "label": "Mobile image (portrait, ~900px wide; falls back to desktop)"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Slide link"
        },
        {
          "type": "range",
          "id": "overlay_opacity",
          "label": "Image dim overlay (%)",
          "min": 0,
          "max": 90,
          "step": 5,
          "default": 0,
          "unit": "%"
        },
        {
          "type": "header",
          "content": "Optional text overlay"
        },
        {
          "type": "text",
          "id": "subheading",
          "label": "Eyebrow"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description"
        },
        {
          "type": "text",
          "id": "cta_label",
          "label": "CTA label"
        },
        {
          "type": "url",
          "id": "cta_link",
          "label": "CTA link"
        },
        {
          "type": "select",
          "id": "content_position",
          "label": "Content position",
          "default": "bottom-left",
          "options": [
            {
              "value": "bottom-left",
              "label": "Bottom left"
            },
            {
              "value": "bottom-right",
              "label": "Bottom right"
            },
            {
              "value": "bottom-center",
              "label": "Bottom center"
            },
            {
              "value": "top-left",
              "label": "Top left"
            },
            {
              "value": "top-right",
              "label": "Top right"
            },
            {
              "value": "center",
              "label": "Center"
            }
          ]
        }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "ED Hero",
      "blocks": [
        {
          "type": "slide"
        },
        {
          "type": "slide"
        },
        {
          "type": "slide"
        }
      ]
    }
  ]
}
{% endschema %}
