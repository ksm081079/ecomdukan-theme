{%- liquid
  assign scheme = section.settings.color_scheme | default: 'scheme-1'
  assign blog = blogs[section.settings.blog]
  assign post_count = section.settings.post_count | default: 3
-%}
<div class="color-{{ scheme }} ed-section" style="background: rgb(var(--color-background));">
  <div class="ed-container">
    {%- if section.settings.heading != blank -%}
      <div style="display: flex; align-items: baseline; justify-content: space-between; margin-bottom: var(--sp-6); gap: var(--sp-4);">
        <h2 class="ed-display-m" style="margin: 0;">{{ section.settings.heading }}</h2>
        {%- if blog -%}
          <a href="{{ blog.url }}" class="ed-btn--link" style="font-family: var(--font-ed-body); font-weight: 600; font-size: 14px;">All posts →</a>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div style="display: grid; grid-template-columns: repeat({{ post_count }}, 1fr); gap: var(--sp-5);">
      {%- if blog and blog.articles.size > 0 -%}
        {%- for article in blog.articles limit: post_count -%}
          <a href="{{ article.url }}" class="ed-card" style="text-decoration: none; color: inherit; display: flex; flex-direction: column; gap: var(--sp-3);">
            {%- if article.image -%}
              <div style="aspect-ratio: 16/10; overflow: hidden; margin: -24px -24px 0; border-bottom: 1.5px solid var(--ed-ink);">
                {{ article.image | image_url: width: 800 | image_tag: loading: 'lazy', widths: '400, 600, 800', alt: article.title }}
              </div>
            {%- endif -%}
            <p class="ed-caption" style="color: var(--ed-text-mute); margin: var(--sp-2) 0 0;">{{ article.published_at | date: '%d %b %Y' }}</p>
            <h3 class="ed-title" style="margin: 0;">{{ article.title }}</h3>
            {%- if article.excerpt_or_content != blank -%}
              <p class="ed-body-s" style="color: var(--ed-text-mute); margin: 0;">{{ article.excerpt_or_content | strip_html | truncate: 120 }}</p>
            {%- endif -%}
          </a>
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..post_count) -%}
          <div class="ed-card">
            <p class="ed-caption" style="color: var(--ed-text-mute);">Sample post</p>
            <h3 class="ed-title" style="margin: var(--sp-2) 0;">Add posts to your blog to populate this section</h3>
            <p class="ed-body-s" style="color: var(--ed-text-mute); margin: 0;">Pick a blog in the section settings.</p>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</div>

<style>
  @media (max-width: 989px) { .ed-resource-grid { grid-template-columns: 1fr !important; } }
</style>

{% schema %}
{
  "name": "ED Resource teaser (blog)",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "From the blog" },
    { "type": "blog", "id": "blog", "label": "Blog" },
    { "type": "range", "id": "post_count", "label": "Posts to show", "min": 2, "max": 4, "step": 1, "default": 3 },
    { "type": "select", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1",
      "options": [
        { "value": "scheme-1", "label": "Paper" },
        { "value": "scheme-2", "label": "Snow" }
      ]
    }
  ],
  "presets": [{ "name": "ED Resource teaser" }]
}
{% endschema %}
