{%- liquid
  assign scheme = section.settings.color_scheme | default: 'scheme-2'
-%}
<div class="color-{{ scheme }} ed-section" style="background: rgb(var(--color-background)); padding-block: var(--sp-7);">
  <div class="ed-container">
    {%- if section.settings.heading != blank -%}
      <p class="ed-caption" style="text-align: center; color: var(--ed-text-mute); margin: 0 0 var(--sp-5);">{{ section.settings.heading }}</p>
    {%- endif -%}

    <div class="ed-logos">
      {%- for block in section.blocks -%}
        {%- if block.settings.link != blank -%}
          <a href="{{ block.settings.link }}" aria-label="{{ block.settings.name | escape }}" {{ block.shopify_attributes }}>
            {%- if block.settings.logo != blank -%}
              {{ block.settings.logo | image_url: width: 480 | image_tag: loading: 'lazy', alt: block.settings.name }}
            {%- else -%}
              <span class="ed-mono" style="display:block;text-align:center;color:var(--ed-mute);">{{ block.settings.name }}</span>
            {%- endif -%}
          </a>
        {%- else -%}
          <div {{ block.shopify_attributes }}>
            {%- if block.settings.logo != blank -%}
              {{ block.settings.logo | image_url: width: 480 | image_tag: loading: 'lazy', alt: block.settings.name }}
            {%- else -%}
              <span class="ed-mono" style="display:block;text-align:center;color:var(--ed-mute);">{{ block.settings.name }}</span>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "ED Customer logos",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Trusted by D2C brands across India" },
    { "type": "select", "id": "color_scheme", "label": "Color scheme", "default": "scheme-2",
      "options": [
        { "value": "scheme-1", "label": "Paper" },
        { "value": "scheme-2", "label": "Snow" }
      ]
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        { "type": "image_picker", "id": "logo", "label": "Logo (transparent PNG)" },
        { "type": "text", "id": "name", "label": "Name", "default": "Brand" },
        { "type": "url",  "id": "link", "label": "Link (optional)" }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "ED Customer logos",
      "blocks": [
        { "type": "logo" }, { "type": "logo" }, { "type": "logo" }, { "type": "logo" },
        { "type": "logo" }, { "type": "logo" }, { "type": "logo" }, { "type": "logo" }
      ]
    }
  ]
}
{% endschema %}
