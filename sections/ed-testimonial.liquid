{%- liquid
  assign scheme = section.settings.color_scheme | default: 'scheme-1'
-%}
<div class="color-{{ scheme }} ed-section" style="background: rgb(var(--color-background));">
  <div class="ed-container">
    <figure class="ed-quote">
      <span class="ed-shirorekha" style="width: 60px; margin: 0 auto var(--sp-5);"></span>
      <blockquote class="ed-quote__text">"{{ section.settings.quote }}"</blockquote>
      <figcaption class="ed-quote__attr">
        {{ section.settings.attribution }}
        {%- if section.settings.role != blank %} · {{ section.settings.role }}{%- endif -%}
      </figcaption>
    </figure>
  </div>
</div>

{% schema %}
{
  "name": "ED Testimonial",
  "tag": "section",
  "settings": [
    { "type": "textarea", "id": "quote", "label": "Quote", "default": "Reorder went from a half-day spreadsheet to one tap. Their tier pricing pays for itself by the second case." },
    { "type": "text", "id": "attribution", "label": "Attribution", "default": "Riya Mehta" },
    { "type": "text", "id": "role", "label": "Role / Company", "default": "Ops Lead, FreshFold (Mumbai)" },
    { "type": "select", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1",
      "options": [
        { "value": "scheme-1", "label": "Paper" },
        { "value": "scheme-2", "label": "Snow" }
      ]
    }
  ],
  "presets": [{ "name": "ED Testimonial" }]
}
{% endschema %}
