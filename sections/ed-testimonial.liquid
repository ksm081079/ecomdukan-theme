{%- liquid
  assign _pt = section.settings.padding_top | default: 24
  assign _pb = section.settings.padding_bottom | default: 24
-%}
{% style %}
  #shopify-section-{{ section.id }} { padding-top: {{ _pt }}px !important; padding-bottom: {{ _pb }}px !important; }
{% endstyle %}
{%- liquid
  assign scheme = section.settings.color_scheme | default: 'scheme-1'
-%}
<div class="color-{{ scheme }} ed-section" style="background: rgb(var(--color-background));">
  <div class="ed-container">
    <figure class="ed-quote">
      <span class="ed-shirorekha" style="width: 60px; margin: 0 auto var(--sp-5);"></span>
      <blockquote class="ed-quote__text">"{{ section.settings.quote }}"</blockquote>
      <figcaption class="ed-quote__attr">
        {{ section.settings.attribution }}
        {%- if section.settings.role != blank %} · {{ section.settings.role }}{%- endif -%}
      </figcaption>
    </figure>
  </div>
</div>

{% schema %}
{
  "name": "ED Testimonial",
  "tag": "section",
  "settings": [
    {
      "type": "textarea",
      "id": "quote",
      "label": "Quote",
      "default": "Reorder went from a half-day spreadsheet to one tap. Their tier pricing pays for itself by the second case."
    },
    {
      "type": "text",
      "id": "attribution",
      "label": "Attribution",
      "default": "Riya Mehta"
    },
    {
      "type": "text",
      "id": "role",
      "label": "Role / Company",
      "default": "Ops Lead, FreshFold (Mumbai)"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1",
      "options": [
        {
          "value": "scheme-1",
          "label": "Paper"
        },
        {
          "value": "scheme-2",
          "label": "Snow"
        }
      ]
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding (px)",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 24,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding (px)",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 24,
      "unit": "px"
    }
  ]
}
{% endschema %}
