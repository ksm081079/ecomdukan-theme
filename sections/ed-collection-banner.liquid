{%- liquid
  assign _pt = section.settings.padding_top | default: 24
  assign _pb = section.settings.padding_bottom | default: 24
-%}
{% style %}
  #shopify-section-{{ section.id }} { padding-top: {{ _pt }}px !important; padding-bottom: {{ _pb }}px !important; }
{% endstyle %}
{%- liquid
  assign scheme = section.settings.color_scheme | default: 'scheme-2'
  assign sub_menu = linklists[section.settings.sub_nav]
  assign circle_size = section.settings.circle_size | default: 96
-%}

<div class="color-{{ scheme }} ed-coll-banner" style="background: rgb(var(--color-background));">
  <div class="ed-container">
    {%- if section.settings.show_breadcrumb -%}
      <nav class="ed-coll-banner__crumb">
        <a href="{{ routes.root_url }}">Home</a>
        {%- if collection.metafields.custom.parent_collection.value -%}
          <span>›</span>
          <a href="{{ collection.metafields.custom.parent_collection.value.url }}">{{ collection.metafields.custom.parent_collection.value.title }}</a>
        {%- endif -%}
        <span>›</span>
        <span class="ed-coll-banner__crumb-active">{{ collection.title }}</span>
      </nav>
    {%- endif -%}

    <div class="ed-coll-banner__hd">
      <div class="ed-coll-banner__copy">
        <h1 class="ed-coll-banner__title">{{ collection.title }}</h1>
        {%- if collection.description != blank -%}
          <div class="ed-coll-banner__desc">{{ collection.description }}</div>
        {%- endif -%}
      </div>
      <div class="ed-coll-banner__meta">
        <span class="ed-coll-banner__count">{{ collection.products_count }} {{ collection.products_count | pluralize: 'product', 'products' }}</span>
        {%- if section.settings.show_quote_cta -%}
          <a href="{{ section.settings.quote_url | default: '/pages/request-quote' }}" class="ed-coll-banner__quote" data-action="collection_quote_click">Get bulk quote →</a>
        {%- endif -%}
      </div>
    </div>
  </div>

  {%- if sub_menu.links.size > 0 -%}
    <div class="ed-coll-subnav">
      <div class="ed-container">
        <ul class="ed-coll-subnav__list" style="--circle: {{ circle_size }}px;">
          {%- for link in sub_menu.links -%}
            {%- assign is_current = false -%}
            {%- if link.url == collection.url -%}{%- assign is_current = true -%}{%- endif -%}
            {%- if link.type == 'collection_link' and link.object.handle == collection.handle -%}{%- assign is_current = true -%}{%- endif -%}
            <li class="{% if is_current %}is-active{% endif %}">
              <a href="{{ link.url }}" class="ed-coll-subnav__item" data-action="subnav_click" data-cat="{{ link.title | escape }}">
                <span class="ed-coll-subnav__media">
                  {%- if link.type == 'collection_link' and link.object.featured_image -%}
                    {{ link.object.featured_image | image_url: width: 200 | image_tag: loading: 'lazy', widths: '100, 160, 200', alt: link.title, class: 'ed-coll-subnav__img' }}
                  {%- else -%}
                    <span class="ed-coll-subnav__placeholder">{{ link.title | slice: 0, 1 | upcase }}</span>
                  {%- endif -%}
                </span>
                <span class="ed-coll-subnav__label">{{ link.title }}</span>
              </a>
            </li>
          {%- endfor -%}
        </ul>
      </div>
    </div>
  {%- endif -%}
</div>

<style>
  .ed-coll-banner { padding-block: 24px 0; }
  .ed-coll-banner__crumb {
    font-family: "IBM Plex Mono", monospace;
    font-size: 11px; letter-spacing: 0.06em; text-transform: uppercase;
    color: rgba(var(--color-foreground), 0.6);
    margin-bottom: 18px;
    display: flex; flex-wrap: wrap; gap: 6px; align-items: center;
  }
  .ed-coll-banner__crumb a { color: inherit; text-decoration: none; }
  .ed-coll-banner__crumb a:hover { color: var(--ed-electric, #1E5FFF); }
  .ed-coll-banner__crumb-active { color: var(--ed-ink, #0A0B0E); }

  .ed-coll-banner__hd {
    display: flex; justify-content: space-between; align-items: flex-end;
    gap: 24px; flex-wrap: wrap;
    padding-bottom: 18px;
  }
  .ed-coll-banner__copy { max-width: 720px; }
  .ed-coll-banner__title {
    margin: 0 0 6px;
    font-family: "Poppins", sans-serif; font-weight: 700;
    font-size: clamp(28px, 4vw, 44px);
    letter-spacing: -0.04em; line-height: 1.05;
  }
  .ed-coll-banner__desc {
    font-family: "Inter", sans-serif; font-size: 15px;
    color: rgba(var(--color-foreground), 0.75);
    line-height: 1.5;
  }
  .ed-coll-banner__meta {
    display: flex; align-items: center; gap: 20px; flex-wrap: wrap;
  }
  .ed-coll-banner__count {
    font-family: "IBM Plex Mono", monospace;
    font-size: 12px; letter-spacing: 0.06em; text-transform: uppercase;
    color: rgba(var(--color-foreground), 0.6);
  }
  .ed-coll-banner__quote {
    font-family: "Inter", sans-serif; font-weight: 600; font-size: 14px;
    color: var(--ed-electric, #1E5FFF);
    text-decoration: none; border-bottom: 1.5px solid currentColor;
    padding-bottom: 1px;
  }

  /* Sub-nav circle strip (Rentmojo-style) */
  .ed-coll-subnav {
    background: var(--ed-paper, #F4F0E8);
    border-block: 1px solid var(--ed-border, #E0DBCF);
    padding: 16px 0;
    margin-top: 8px;
  }
  .ed-coll-subnav__list {
    list-style: none; margin: 0; padding: 4px 0;
    display: flex; gap: 12px;
    overflow-x: auto;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
  }
  .ed-coll-subnav__list::-webkit-scrollbar { display: none; }
  .ed-coll-subnav__list > li { flex: 0 0 auto; }
  .ed-coll-subnav__item {
    display: flex; flex-direction: column; align-items: center; gap: 8px;
    text-decoration: none; color: var(--ed-ink, #0A0B0E);
    padding: 8px 10px;
    border-radius: 12px;
    border: 1.5px solid transparent;
    transition: background 120ms, border-color 120ms;
    width: calc(var(--circle) + 24px);
  }
  .ed-coll-subnav__item:hover {
    background: rgba(30, 95, 255, 0.06);
  }
  .ed-coll-subnav__list > li.is-active .ed-coll-subnav__item {
    background: rgba(30, 95, 255, 0.10);
    border-color: var(--ed-electric, #1E5FFF);
  }
  .ed-coll-subnav__media {
    width: var(--circle); height: var(--circle);
    border-radius: 50%;
    background: var(--ed-snow, #FBFAF6);
    overflow: hidden;
    display: flex; align-items: center; justify-content: center;
    border: 1px solid var(--ed-border, #E0DBCF);
  }
  .ed-coll-subnav__img {
    width: 100%; height: 100%; object-fit: contain; padding: 8px; box-sizing: border-box;
  }
  .ed-coll-subnav__placeholder {
    font-family: "Poppins", sans-serif; font-weight: 700;
    font-size: calc(var(--circle) * 0.4);
    color: var(--ed-electric, #1E5FFF);
  }
  .ed-coll-subnav__label {
    font-family: "Inter", sans-serif; font-weight: 500;
    font-size: 12px; line-height: 1.2; text-align: center;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;
    overflow: hidden; max-width: 100%;
  }

  @media (max-width: 749px) {
    .ed-coll-banner__hd { padding-bottom: 12px; }
    .ed-coll-subnav { padding: 12px 0; }
  }
</style>

<script>
  document.addEventListener('click', function(e) {
    const el = e.target.closest('[data-action]');
    if (!el || !window.posthog) return;
    const a = el.dataset.action;
    try {
      if (a === 'collection_quote_click') posthog.capture('collection_quote_click', { collection: {{ collection.handle | json }} });
      if (a === 'subnav_click') posthog.capture('collection_subnav_click', { category: el.dataset.cat, href: el.getAttribute('href') });
    } catch (err) {}
  });
</script>

{% schema %}
{
  "name": "ED Collection banner",
  "tag": "section",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_breadcrumb",
      "label": "Show breadcrumb",
      "default": true
    },
    {
      "type": "header",
      "content": "Sub-category navigator (Rentmojo-style circles)"
    },
    {
      "type": "link_list",
      "id": "sub_nav",
      "label": "Menu to use as sub-category strip",
      "info": "Pick a navigation menu in Online Store \u2192 Navigation. Each link becomes a circle. Active item = matches the current collection URL."
    },
    {
      "type": "range",
      "id": "circle_size",
      "label": "Circle size (px)",
      "min": 64,
      "max": 128,
      "step": 4,
      "default": 96
    },
    {
      "type": "header",
      "content": "Quote CTA"
    },
    {
      "type": "checkbox",
      "id": "show_quote_cta",
      "label": "Show 'Get bulk quote' link",
      "default": true
    },
    {
      "type": "url",
      "id": "quote_url",
      "label": "Quote page URL"
    },
    {
      "type": "header",
      "content": "Color scheme"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-2",
      "options": [
        {
          "value": "scheme-1",
          "label": "Paper"
        },
        {
          "value": "scheme-2",
          "label": "Snow"
        }
      ]
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding (px)",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 24,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding (px)",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 24,
      "unit": "px"
    }
  ],
  "enabled_on": {
    "templates": [
      "collection"
    ]
  },
  "presets": [
    {
      "name": "ED Collection banner"
    }
  ]
}
{% endschema %}
