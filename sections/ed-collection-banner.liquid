{%- liquid
  assign scheme = section.settings.color_scheme | default: 'scheme-2'
-%}
<div class="color-{{ scheme }}" style="background: rgb(var(--color-background)); padding: var(--sp-8) 0 var(--sp-6);">
  <div class="ed-container">
    {%- if section.settings.show_breadcrumb -%}
      <nav class="ed-mono" style="font-size: 12px; color: var(--ed-text-mute); margin-bottom: var(--sp-4); text-transform: uppercase; letter-spacing: .06em;">
        <a href="{{ routes.root_url }}" style="color: inherit; text-decoration: none;">Home</a>
        <span> › </span>
        <span style="color: var(--ed-ink);">{{ collection.title }}</span>
      </nav>
    {%- endif -%}

    <div style="display: flex; align-items: end; justify-content: space-between; gap: var(--sp-5); flex-wrap: wrap;">
      <div style="max-width: 720px;">
        <h1 class="ed-display-l" style="margin: 0 0 var(--sp-3);">{{ collection.title }}</h1>
        {%- if collection.description != blank -%}
          <div class="ed-body-l" style="color: var(--ed-text-mute);">{{ collection.description }}</div>
        {%- endif -%}
      </div>
      <p class="ed-mono" style="color: var(--ed-text-mute); margin: 0; text-transform: uppercase; letter-spacing: .06em; font-size: 12px;">
        {{ collection.products_count }} {{ collection.products_count | pluralize: 'product', 'products' }}
      </p>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "ED Collection banner",
  "tag": "section",
  "settings": [
    { "type": "checkbox", "id": "show_breadcrumb", "label": "Show breadcrumb", "default": true },
    { "type": "select", "id": "color_scheme", "label": "Color scheme", "default": "scheme-2",
      "options": [
        { "value": "scheme-1", "label": "Paper" },
        { "value": "scheme-2", "label": "Snow" }
      ]
    }
  ],
  "enabled_on": { "templates": ["collection"] },
  "presets": [{ "name": "ED Collection banner" }]
}
{% endschema %}
