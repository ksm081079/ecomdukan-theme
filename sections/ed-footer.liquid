{%- liquid
  assign _pt = section.settings.padding_top | default: 24
  assign _pb = section.settings.padding_bottom | default: 24
-%}
{% style %}
  #shopify-section-{{ section.id }} { padding-top: {{ _pt }}px !important; padding-bottom: {{ _pb }}px !important; }
{% endstyle %}
{%- liquid
  assign scheme = section.settings.color_scheme | default: 'scheme-4'
  assign show_newsletter = section.settings.show_newsletter
  assign show_payment = section.settings.show_payment
  assign show_back_to_top = section.settings.show_back_to_top
  assign show_social = section.settings.show_social
-%}

<footer class="color-{{ scheme }} ed-footer" style="background: rgb(var(--color-background)); color: rgb(var(--color-foreground));">
  <div class="ed-container ed-footer__wrap">

    {%- comment -%} Newsletter strip (top of footer) {%- endcomment -%}
    {%- if show_newsletter -%}
      <div class="ed-footer__newsletter">
        <div class="ed-footer__newsletter-copy">
          {%- if section.settings.newsletter_eyebrow != blank -%}
            <p class="ed-footer__eyebrow">{{ section.settings.newsletter_eyebrow }}</p>
          {%- endif -%}
          {%- if section.settings.newsletter_heading != blank -%}
            <h2 class="ed-footer__newsletter-heading">{{ section.settings.newsletter_heading }}</h2>
          {%- endif -%}
          {%- if section.settings.newsletter_body != blank -%}
            <p class="ed-footer__newsletter-body">{{ section.settings.newsletter_body }}</p>
          {%- endif -%}
        </div>
        <div class="ed-footer__newsletter-form">
          {%- form 'customer', id: 'EdFooterNewsletter' -%}
            <input type="hidden" name="contact[tags]" value="newsletter">
            <div class="ed-footer__field">
              <input
                type="email"
                name="contact[email]"
                value="{{ form.email }}"
                required
                autocapitalize="off"
                autocomplete="email"
                placeholder="{{ section.settings.placeholder | default: 'you@company.in' }}"
                aria-label="Email"
                class="ed-footer__email"
              >
              <button type="submit" class="ed-footer__submit" name="commit" data-action="newsletter_submit">{{ section.settings.cta_label | default: 'Subscribe' }}</button>
            </div>
            {%- if form.errors -%}
              <p class="ed-footer__msg ed-footer__msg--err">{{ form.errors | default_errors }}</p>
            {%- endif -%}
            {%- if form.posted_successfully? -%}
              <p class="ed-footer__msg ed-footer__msg--ok">Thanks — you're on the list.</p>
            {%- endif -%}
          {%- endform -%}
          {%- if section.settings.disclaimer != blank -%}
            <p class="ed-footer__disclaimer">{{ section.settings.disclaimer }}</p>
          {%- endif -%}
        </div>
      </div>
    {%- endif -%}

    {%- comment -%} Columns: brand + 4 link groups {%- endcomment -%}
    <div class="ed-footer__cols">
      <div class="ed-footer__brand">
        {%- if section.settings.brand_logo != blank -%}
          {{ section.settings.brand_logo | image_url: width: 200 | image_tag:
            loading: 'lazy', widths: '120, 200, 320',
            alt: shop.name, class: 'ed-footer__logo'
          }}
        {%- else -%}
          <h2 class="ed-footer__wordmark">ecomdukan</h2>
        {%- endif -%}
        {%- if section.settings.brand_tagline != blank -%}
          <p class="ed-footer__tagline">{{ section.settings.brand_tagline }}</p>
        {%- endif -%}
        {%- if show_social -%}
          <div class="ed-footer__social">
            {%- if settings.social_instagram_link != blank -%}
              <a href="{{ settings.social_instagram_link }}" aria-label="Instagram" target="_blank" rel="noopener" data-action="social_click" data-network="instagram">{% render 'icon-instagram' %}</a>
            {%- endif -%}
            {%- if settings.social_facebook_link != blank -%}
              <a href="{{ settings.social_facebook_link }}" aria-label="Facebook" target="_blank" rel="noopener" data-action="social_click" data-network="facebook">{% render 'icon-facebook' %}</a>
            {%- endif -%}
            {%- if settings.social_twitter_link != blank -%}
              <a href="{{ settings.social_twitter_link }}" aria-label="Twitter" target="_blank" rel="noopener" data-action="social_click" data-network="twitter">{% render 'icon-twitter' %}</a>
            {%- endif -%}
            {%- if settings.social_youtube_link != blank -%}
              <a href="{{ settings.social_youtube_link }}" aria-label="YouTube" target="_blank" rel="noopener" data-action="social_click" data-network="youtube">{% render 'icon-youtube' %}</a>
            {%- endif -%}
            {%- if settings.social_pinterest_link != blank -%}
              <a href="{{ settings.social_pinterest_link }}" aria-label="Pinterest" target="_blank" rel="noopener" data-action="social_click" data-network="pinterest">{% render 'icon-pinterest' %}</a>
            {%- endif -%}
            {%- if settings.social_tiktok_link != blank -%}
              <a href="{{ settings.social_tiktok_link }}" aria-label="TikTok" target="_blank" rel="noopener" data-action="social_click" data-network="tiktok">{% render 'icon-tiktok' %}</a>
            {%- endif -%}
          </div>
        {%- endif -%}
        {%- if section.settings.support_email != blank or section.settings.support_phone != blank -%}
          <div class="ed-footer__support">
            {%- if section.settings.support_email != blank -%}
              <a href="mailto:{{ section.settings.support_email }}" class="ed-footer__support-link" data-action="contact_click" data-via="email">{{ section.settings.support_email }}</a>
            {%- endif -%}
            {%- if section.settings.support_phone != blank -%}
              <a href="https://wa.me/{{ section.settings.support_phone | replace: '+', '' | replace: ' ', '' | replace: '-', '' }}" class="ed-footer__support-link" target="_blank" rel="noopener" data-action="contact_click" data-via="whatsapp">WhatsApp · {{ section.settings.support_phone }}</a>
            {%- endif -%}
            {%- if section.settings.support_hours != blank -%}
              <p class="ed-footer__support-hours">{{ section.settings.support_hours }}</p>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>

      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'menu' -%}
            <details class="ed-footer__col" {{ block.shopify_attributes }} open>
              <summary class="ed-footer__col-heading">
                <span>{{ block.settings.heading }}</span>
                <span class="ed-footer__chev" aria-hidden="true">+</span>
              </summary>
              <ul class="ed-footer__list">
                {%- for link in block.settings.menu.links -%}
                  <li>
                    <a href="{{ link.url }}" data-action="footer_link" data-label="{{ link.title | escape }}">{{ link.title }}</a>
                  </li>
                {%- endfor -%}
              </ul>
            </details>
          {%- when 'text' -%}
            <details class="ed-footer__col" {{ block.shopify_attributes }} open>
              <summary class="ed-footer__col-heading">
                <span>{{ block.settings.heading }}</span>
                <span class="ed-footer__chev" aria-hidden="true">+</span>
              </summary>
              <div class="ed-footer__list ed-footer__text">{{ block.settings.body }}</div>
            </details>
        {%- endcase -%}
      {%- endfor -%}
    </div>

    {%- comment -%} Trust / payments strip {%- endcomment -%}
    {%- if section.settings.trust_text != blank or show_payment -%}
      <div class="ed-footer__trust">
        {%- if section.settings.trust_text != blank -%}
          <p class="ed-footer__trust-text">{{ section.settings.trust_text }}</p>
        {%- endif -%}
        {%- if show_payment and shop.enabled_payment_types.size > 0 -%}
          <ul class="ed-footer__payments" aria-label="Payment methods">
            {%- for type in shop.enabled_payment_types -%}
              <li>{{ type | payment_type_svg_tag: class: 'ed-footer__payment-icon' }}</li>
            {%- endfor -%}
          </ul>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- comment -%} Compliance / bottom strip {%- endcomment -%}
    <div class="ed-footer__bottom">
      <p class="ed-footer__compliance">
        © {{ 'now' | date: '%Y' }} {{ settings.ed_company_legal_name | default: 'Ecomdukan Pvt. Ltd.' }}
        {%- if settings.ed_gstin != blank %} · GSTIN {{ settings.ed_gstin }}{%- endif -%}
        {%- if settings.ed_cin != blank %} · CIN {{ settings.ed_cin }}{%- endif -%}
        {%- if section.settings.show_made_in_india %} · <span class="ed-footer__mii">Made in India</span>{%- endif -%}
      </p>
      {%- if section.settings.show_policies -%}
        <ul class="ed-footer__policies">
          {%- if shop.privacy_policy %}<li><a href="{{ shop.privacy_policy.url }}">Privacy</a></li>{%- endif -%}
          {%- if shop.terms_of_service %}<li><a href="{{ shop.terms_of_service.url }}">Terms</a></li>{%- endif -%}
          {%- if shop.refund_policy %}<li><a href="{{ shop.refund_policy.url }}">Refunds</a></li>{%- endif -%}
          {%- if shop.shipping_policy %}<li><a href="{{ shop.shipping_policy.url }}">Shipping</a></li>{%- endif -%}
        </ul>
      {%- endif -%}
    </div>
  </div>

  {%- if show_back_to_top -%}
    <button type="button" class="ed-footer__top" aria-label="Back to top" data-action="back_to_top">
      <span aria-hidden="true">↑</span>
    </button>
  {%- endif -%}
</footer>

<style>
  .ed-footer {
    padding-block: clamp(40px, 6vw, 72px) 0;
    font-family: "Inter", sans-serif;
  }
  .ed-container { max-width: 1280px; margin: 0 auto; padding-inline: clamp(16px, 4vw, 32px); }
  .ed-footer__wrap { display: flex; flex-direction: column; gap: clamp(28px, 4vw, 48px); }

  /* Newsletter */
  .ed-footer__newsletter {
    display: grid; gap: 24px;
    grid-template-columns: 1fr 1fr;
    align-items: end;
    padding-bottom: clamp(24px, 4vw, 40px);
    border-bottom: 1px solid rgba(var(--color-foreground), 0.18);
  }
  .ed-footer__eyebrow {
    margin: 0 0 8px;
    font-family: "IBM Plex Mono", monospace;
    font-size: 11px; font-weight: 600;
    letter-spacing: 0.12em; text-transform: uppercase;
    color: rgba(var(--color-foreground), 0.65);
  }
  .ed-footer__newsletter-heading {
    margin: 0;
    font-family: "Poppins", sans-serif; font-weight: 700;
    font-size: clamp(20px, 2.4vw, 28px);
    letter-spacing: -0.025em; line-height: 1.15;
  }
  .ed-footer__newsletter-body {
    margin: 8px 0 0;
    font-size: 14px; line-height: 1.5;
    color: rgba(var(--color-foreground), 0.75);
    max-width: 44ch;
  }
  .ed-footer__field {
    display: flex; gap: 0;
    border: 1.5px solid rgb(var(--color-foreground));
    border-radius: 2px;
    overflow: hidden;
  }
  .ed-footer__email {
    flex: 1;
    border: 0; background: transparent;
    padding: 14px 16px;
    font-family: "Inter", sans-serif; font-size: 14px;
    color: inherit;
    min-width: 0;
  }
  .ed-footer__email:focus { outline: none; background: rgba(var(--color-foreground), 0.06); }
  .ed-footer__email::placeholder { color: rgba(var(--color-foreground), 0.5); }
  .ed-footer__submit {
    border: 0;
    background: var(--ed-electric, #1E5FFF);
    color: var(--ed-paper, #F4F0E8);
    padding: 14px 22px;
    font-family: "Inter", sans-serif; font-weight: 600; font-size: 14px;
    letter-spacing: 0.02em;
    cursor: pointer;
    transition: background 120ms;
  }
  .ed-footer__submit:hover { background: #1747D6; }
  .ed-footer__disclaimer {
    margin: 10px 0 0; font-size: 11px;
    color: rgba(var(--color-foreground), 0.55);
  }
  .ed-footer__msg { margin: 8px 0 0; font-size: 13px; }
  .ed-footer__msg--ok { color: var(--ed-success, #1E6B3A); }
  .ed-footer__msg--err { color: var(--ed-error, #A8281C); }

  /* Columns */
  .ed-footer__cols {
    display: grid; gap: 32px;
    grid-template-columns: 1.4fr repeat(4, 1fr);
  }
  .ed-footer__brand { display: flex; flex-direction: column; gap: 16px; }
  .ed-footer__logo { max-width: 160px; height: auto; }
  .ed-footer__wordmark {
    margin: 0;
    font-family: "Poppins", sans-serif; font-weight: 700;
    font-size: 28px; letter-spacing: -0.045em; line-height: 0.9;
  }
  .ed-footer__tagline {
    margin: 0; font-size: 14px; line-height: 1.5;
    color: rgba(var(--color-foreground), 0.75);
    max-width: 36ch;
  }
  .ed-footer__social { display: flex; gap: 12px; }
  .ed-footer__social a {
    display: inline-flex; align-items: center; justify-content: center;
    width: 32px; height: 32px;
    border: 1px solid rgba(var(--color-foreground), 0.4);
    border-radius: 50%;
    color: inherit;
    transition: background 120ms, color 120ms, border-color 120ms;
  }
  .ed-footer__social a:hover {
    background: var(--ed-electric, #1E5FFF);
    color: var(--ed-paper, #F4F0E8);
    border-color: var(--ed-electric, #1E5FFF);
  }
  .ed-footer__social svg { width: 14px; height: 14px; }
  .ed-footer__support { display: flex; flex-direction: column; gap: 4px; margin-top: 8px; }
  .ed-footer__support-link {
    color: inherit; text-decoration: none;
    font-size: 13px; font-weight: 500;
    border-bottom: 1px solid transparent;
  }
  .ed-footer__support-link:hover { border-bottom-color: currentColor; }
  .ed-footer__support-hours {
    margin: 0; font-size: 12px;
    color: rgba(var(--color-foreground), 0.6);
    font-family: "IBM Plex Mono", monospace;
  }

  .ed-footer__col { min-width: 0; }
  .ed-footer__col-heading {
    list-style: none; cursor: default;
    display: flex; justify-content: space-between; align-items: center;
    font-family: "Inter", sans-serif; font-weight: 600;
    font-size: 13px; letter-spacing: 0.04em; text-transform: uppercase;
    color: inherit; margin: 0 0 12px;
  }
  .ed-footer__col-heading::-webkit-details-marker { display: none; }
  .ed-footer__chev { display: none; }
  .ed-footer__list {
    list-style: none; margin: 0; padding: 0;
    display: flex; flex-direction: column; gap: 8px;
  }
  .ed-footer__list a {
    color: rgba(var(--color-foreground), 0.78);
    text-decoration: none;
    font-size: 14px; line-height: 1.5;
    transition: color 120ms;
  }
  .ed-footer__list a:hover { color: rgb(var(--color-foreground)); text-decoration: underline; }
  .ed-footer__text * { font-size: 13px; line-height: 1.5; }

  /* Trust strip */
  .ed-footer__trust {
    display: flex; justify-content: space-between; align-items: center;
    gap: 20px; flex-wrap: wrap;
    padding: 16px 0;
    border-top: 1px solid rgba(var(--color-foreground), 0.15);
    border-bottom: 1px solid rgba(var(--color-foreground), 0.15);
  }
  .ed-footer__trust-text {
    margin: 0; font-size: 13px;
    color: rgba(var(--color-foreground), 0.75);
  }
  .ed-footer__payments {
    list-style: none; margin: 0; padding: 0;
    display: flex; gap: 8px; flex-wrap: wrap;
  }
  .ed-footer__payment-icon { height: 22px; width: auto; }

  /* Bottom strip */
  .ed-footer__bottom {
    display: flex; justify-content: space-between; align-items: center;
    gap: 16px; flex-wrap: wrap;
    padding: 20px 0 28px;
    font-size: 12px;
    color: rgba(var(--color-foreground), 0.6);
  }
  .ed-footer__compliance { margin: 0; font-family: "IBM Plex Mono", monospace; }
  .ed-footer__mii { color: var(--ed-electric, #1E5FFF); font-weight: 600; }
  .ed-footer__policies {
    list-style: none; margin: 0; padding: 0;
    display: flex; gap: 16px; flex-wrap: wrap;
  }
  .ed-footer__policies a { color: inherit; text-decoration: none; }
  .ed-footer__policies a:hover { text-decoration: underline; }

  /* Back to top */
  .ed-footer__top {
    position: fixed; right: 20px; bottom: 80px;
    width: 44px; height: 44px;
    border: 1.5px solid var(--ed-ink, #0A0B0E);
    border-radius: 50%;
    background: var(--ed-snow, #FBFAF6);
    color: var(--ed-ink, #0A0B0E);
    font-size: 18px; cursor: pointer;
    display: none; align-items: center; justify-content: center;
    z-index: 40;
    transition: transform 120ms;
  }
  .ed-footer__top:hover { transform: translateY(-2px); }
  .ed-footer__top.is-visible { display: inline-flex; }

  /* Responsive */
  @media (max-width: 989px) {
    .ed-footer__cols { grid-template-columns: 1fr 1fr; }
    .ed-footer__brand { grid-column: 1 / -1; }
  }
  @media (max-width: 749px) {
    .ed-footer__newsletter { grid-template-columns: 1fr; gap: 16px; }
    .ed-footer__cols { grid-template-columns: 1fr; gap: 0; }
    .ed-footer__brand { padding-bottom: 16px; border-bottom: 1px solid rgba(var(--color-foreground), 0.15); }
    .ed-footer__col {
      border-bottom: 1px solid rgba(var(--color-foreground), 0.15);
    }
    .ed-footer__col-heading { cursor: pointer; padding: 14px 0; margin: 0; }
    .ed-footer__chev { display: inline-block; font-size: 18px; font-weight: 400; transition: transform 160ms; }
    .ed-footer__col[open] .ed-footer__chev { transform: rotate(45deg); }
    .ed-footer__list { padding-bottom: 14px; }
    .ed-footer__trust { flex-direction: column; align-items: flex-start; }
    .ed-footer__bottom { flex-direction: column; align-items: flex-start; }
    .ed-footer__top { right: 12px; bottom: 92px; }
  }
</style>

<script>
  (function() {
    const ph = function(name, props) { if (window.posthog) try { posthog.capture(name, props || {}); } catch (e) {} };

    // Back to top
    const top = document.querySelector('.ed-footer__top');
    if (top) {
      window.addEventListener('scroll', function() {
        top.classList.toggle('is-visible', window.pageYOffset > 600);
      }, { passive: true });
      top.addEventListener('click', function() {
        window.scrollTo({ top: 0, behavior: 'smooth' });
        ph('back_to_top_click');
      });
    }

    // Footer event tracking
    document.addEventListener('click', function(e) {
      const el = e.target.closest('[data-action]');
      if (!el) return;
      const action = el.dataset.action;
      if (action === 'footer_link') ph('footer_link_click', { label: el.dataset.label, href: el.getAttribute('href') });
      if (action === 'social_click') ph('social_icon_click', { network: el.dataset.network });
      if (action === 'contact_click') ph('contact_click', { via: el.dataset.via });
      if (action === 'newsletter_submit') ph('newsletter_submit', { surface: 'footer' });
    });
  })();
</script>

{% schema %}
{
  "name": "ED Footer",
  "tag": "footer",
  "class": "ed-footer-section",
  "settings": [
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-4",
      "options": [
        {
          "value": "scheme-1",
          "label": "Paper"
        },
        {
          "value": "scheme-2",
          "label": "Snow"
        },
        {
          "value": "scheme-3",
          "label": "Indigo"
        },
        {
          "value": "scheme-4",
          "label": "Ink"
        }
      ]
    },
    {
      "type": "header",
      "content": "Brand block"
    },
    {
      "type": "image_picker",
      "id": "brand_logo",
      "label": "Logo (light version for dark bg)"
    },
    {
      "type": "textarea",
      "id": "brand_tagline",
      "label": "Tagline",
      "default": "Stationery & printer labels, in bulk, in stock \u2014 for the brands building modern India."
    },
    {
      "type": "text",
      "id": "support_email",
      "label": "Support email",
      "default": "hello@ecomdukan.in"
    },
    {
      "type": "text",
      "id": "support_phone",
      "label": "WhatsApp number (with country code)",
      "default": "+91 78426 80660"
    },
    {
      "type": "text",
      "id": "support_hours",
      "label": "Support hours",
      "default": "Mon\u2013Sat \u00b7 9 AM \u2013 7 PM IST"
    },
    {
      "type": "header",
      "content": "Newsletter strip"
    },
    {
      "type": "checkbox",
      "id": "show_newsletter",
      "label": "Show newsletter",
      "default": true
    },
    {
      "type": "text",
      "id": "newsletter_eyebrow",
      "label": "Eyebrow",
      "default": "Newsletter"
    },
    {
      "type": "text",
      "id": "newsletter_heading",
      "label": "Heading",
      "default": "Restock & price-drop alerts"
    },
    {
      "type": "textarea",
      "id": "newsletter_body",
      "label": "Body",
      "default": "One email a week. New SKUs, price drops, and bulk-tier changes. No content marketing, no fluff."
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Email placeholder",
      "default": "you@company.in"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Subscribe"
    },
    {
      "type": "text",
      "id": "disclaimer",
      "label": "Disclaimer",
      "default": "We never share your email. Unsubscribe anytime."
    },
    {
      "type": "header",
      "content": "Trust / payments"
    },
    {
      "type": "text",
      "id": "trust_text",
      "label": "Trust line",
      "default": "Trusted by D2C brands across India \u00b7 GST invoicing on every order \u00b7 Same-day dispatch from Mumbai, Bengaluru, Delhi"
    },
    {
      "type": "checkbox",
      "id": "show_payment",
      "label": "Show payment icons",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_social",
      "label": "Show social icons",
      "default": true
    },
    {
      "type": "header",
      "content": "Bottom strip"
    },
    {
      "type": "checkbox",
      "id": "show_policies",
      "label": "Show policy links",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_made_in_india",
      "label": "Show 'Made in India'",
      "default": true
    },
    {
      "type": "header",
      "content": "Extras"
    },
    {
      "type": "checkbox",
      "id": "show_back_to_top",
      "label": "Show back-to-top button",
      "default": true
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding (px)",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 24,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding (px)",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 24,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "menu",
      "name": "Menu column",
      "settings": [
