{%- comment -%} ED Why-choose — 3-card promo slider (11 may inspired) {%- endcomment -%}

{%- liquid
  assign scheme = section.settings.color_scheme | default: 'scheme-1'
  assign pt = section.settings.padding_top | default: 60
  assign pb = section.settings.padding_bottom | default: 80
-%}

<div class="ed-section color-{{ scheme }}" style="background: rgb(var(--color-background)); padding-top: {{ pt }}px; padding-bottom: {{ pb }}px;">
  <div class="ed-container">
    {%- if section.settings.heading != blank or section.settings.tag != blank -%}
      <div class="ed-why-choose__head">
        <h2 class="ed-why-choose__title">
          {%- if section.settings.heading != blank -%}{{ section.settings.heading }} {%- endif -%}
          {%- if section.settings.tag != blank -%}<span class="ed-why-choose__tag">{{ section.settings.tag }}</span>{%- endif -%}
        </h2>
        {%- if section.settings.subheading != blank -%}
          <p class="ed-why-choose__sub">{{ section.settings.subheading }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="ed-why-choose__grid">
        {%- for block in section.blocks -%}
          {%- if block.settings.link != blank -%}
            <a class="ed-why-choose__card" href="{{ block.settings.link }}" {{ block.shopify_attributes }}>
          {%- else -%}
            <div class="ed-why-choose__card" {{ block.shopify_attributes }}>
          {%- endif -%}
            {%- if block.settings.desktop_image != blank -%}
              <picture>
                {%- if block.settings.mobile_image != blank -%}
                  <source media="(max-width: 749px)" srcset="{{ block.settings.mobile_image | image_url: width: 800 }}">
                {%- endif -%}
                {{ block.settings.desktop_image | image_url: width: 1200 | image_tag: loading: 'lazy', widths: '480, 720, 960, 1200', alt: block.settings.alt | default: 'Why choose us', class: 'ed-why-choose__img' }}
              </picture>
            {%- endif -%}
            {%- if block.settings.caption != blank -%}
              <p class="ed-why-choose__caption">{{ block.settings.caption }}</p>
            {%- endif -%}
          {%- if block.settings.link != blank -%}</a>{%- else -%}</div>{%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</div>

<style>
  .ed-why-choose__head { text-align: center; margin-bottom: 32px; }
  .ed-why-choose__title {
    margin: 0; font-family: "Poppins", sans-serif; font-weight: 700;
    font-size: clamp(24px, 3vw, 36px); letter-spacing: -0.02em; line-height: 1.15;
    color: var(--ed-ink, #0A0B0E);
  }
  .ed-why-choose__tag { color: var(--ed-electric, #1E5FFF); }
  .ed-why-choose__sub {
    margin: 8px 0 0; font-family: "Inter", sans-serif; font-size: 14px;
    color: var(--ed-text-mute, #5C6068);
  }
  .ed-why-choose__grid {
    display: grid;
    grid-template-columns: repeat({{ section.blocks.size | at_most: 4 | at_least: 1 }}, 1fr);
    gap: 18px;
  }
  .ed-why-choose__card {
    display: block; text-decoration: none; color: inherit;
    border-radius: 12px; overflow: hidden;
    background: var(--ed-snow, #FBFAF6);
    border: 1px solid var(--ed-border, #E0DBCF);
    transition: transform 200ms, box-shadow 200ms;
  }
  .ed-why-choose__card:hover { transform: translateY(-3px); box-shadow: 0 12px 28px rgba(10,11,14,0.08); }
  .ed-why-choose__img { width: 100%; height: auto; display: block; }
  .ed-why-choose__caption {
    margin: 0; padding: 14px 16px;
    font-family: "Inter", sans-serif; font-weight: 600; font-size: 14px;
    color: var(--ed-ink, #0A0B0E);
  }
  @media (max-width: 989px) {
    .ed-why-choose__grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 599px) {
    .ed-why-choose__grid { grid-template-columns: 1fr; gap: 12px; }
  }
</style>

{% schema %}
{
  "name": "ED Why choose",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Why choose" },
    { "type": "text", "id": "tag", "label": "Brand tag (colored)", "default": "The Affordable Organic Store?" },
    { "type": "text", "id": "subheading", "label": "Subheading" },
    { "type": "header", "content": "Layout" },
    { "type": "select", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1",
      "options": [
        { "value": "scheme-1", "label": "Paper" },
        { "value": "scheme-2", "label": "Snow" }
      ]
    },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 60 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 80 }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        { "type": "image_picker", "id": "desktop_image", "label": "Desktop image" },
        { "type": "image_picker", "id": "mobile_image", "label": "Mobile image (optional)" },
        { "type": "text", "id": "alt", "label": "Alt text" },
        { "type": "text", "id": "caption", "label": "Caption (optional)" },
        { "type": "url", "id": "link", "label": "Link (optional)" }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "ED Why choose",
      "blocks": [{ "type": "card" }, { "type": "card" }, { "type": "card" }]
    }
  ],
  "enabled_on": { "templates": ["product"] }
}
{% endschema %}
