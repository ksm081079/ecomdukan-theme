{%- liquid
  assign _pt = section.settings.padding_top | default: 0
  assign _pb = section.settings.padding_bottom | default: 0
-%}
{% style %}
  #shopify-section-{{ section.id }} { padding-top: {{ _pt }}px !important; padding-bottom: {{ _pb }}px !important; }
{% endstyle %}
{%- liquid
  assign scheme = section.settings.color_scheme | default: 'scheme-3'
-%}
<div class="color-{{ scheme }} ed-section" style="background: rgb(var(--color-background));">
  <div class="ed-container" style="text-align: center; max-width: 920px;">
    {%- if section.settings.eyebrow != blank -%}
      <p class="ed-caption" style="margin: 0 0 var(--sp-4); color: rgb(var(--color-foreground));">{{ section.settings.eyebrow }}</p>
    {%- endif -%}
    {%- if section.settings.heading != blank -%}
      <h2 class="ed-display-m" style="color: rgb(var(--color-foreground)); margin: 0 0 var(--sp-4);">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.body != blank -%}
      <p class="ed-body-l" style="color: rgb(var(--color-foreground)); opacity: 0.85; margin: 0 0 var(--sp-6);">{{ section.settings.body }}</p>
    {%- endif -%}
    {%- if section.settings.cta_label != blank -%}
      <a href="{{ section.settings.cta_link | default: '#' }}" class="ed-btn ed-btn--primary ed-btn--lg">{{ section.settings.cta_label }}</a>
    {%- endif -%}
    <div class="ed-shutter ed-shutter--on-paper" style="max-width: 240px; margin: var(--sp-6) auto 0; opacity: 0.4;"></div>
  </div>
</div>

{% schema %}
{
  "name": "ED Custom-print CTA",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Custom print"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Need it printed your way?"
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body",
      "default": "Send us a brief \u2014 dimensions, material, finish. We quote in 2 business hours, Mon\u2013Sat, 9 AM \u2013 7 PM IST."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label",
      "default": "Start a custom job"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA link"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-3",
      "options": [
        {
          "value": "scheme-3",
          "label": "Indigo (full-width band)"
        },
        {
          "value": "scheme-4",
          "label": "Ink"
        },
        {
          "value": "scheme-5",
          "label": "Electric"
        }
      ]
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding (px)",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding (px)",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 0,
      "unit": "px"
    }
  ],
  "presets": [
    {
      "name": "ED Custom-print CTA"
    }
  ]
}
{% endschema %}
