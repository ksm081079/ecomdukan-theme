    <script>
document.addEventListener("DOMContentLoaded", function () {
  const youtubeRegex = /https:\/\/youtu\.be\/([a-zA-Z0-9_-]+)(\?[^"\s]*)?/g;

  function convertLinksToIframes(node) {
    if (node.nodeType === Node.TEXT_NODE) {
      const text = node.nodeValue;
      if (youtubeRegex.test(text)) {
        const span = document.createElement("span");
        span.innerHTML = text.replace(youtubeRegex, function (match, videoId) {
         // alert("Detected YouTube Video ID: " + videoId); // ✅ DEBUG ALERT
          return `
            <br>
            <iframe width="560" height="315"
              src="https://www.youtube.com/embed/${videoId}"
              frameborder="0" allowfullscreen></iframe><br>
          `;
        });
        node.parentNode.replaceChild(span, node);
      }
    } else {
      node.childNodes.forEach(convertLinksToIframes);
    }
  }

  convertLinksToIframes(document.body);
});


