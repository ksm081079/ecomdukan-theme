:"body_weight","des_spacing_bottom":30}},"text_7zbxDq":{"type":"text","settings":{"color_scheme":"scheme-1","content_width":"33.3333%","vertical_align":"center","image_link":"","subheading":"","heading":"Our Vision","description":"<p>Imaginе a world whеrе anyonе, anywhеrе, can buy fantastic products without swеating ovеr thе pricе tag. Our vision is simple – we’re dreaming big for a world where everyone, regardless of where they are or what they earn, has easy access to products and services that won’t break the bank. Join us in painting this vision into reality!<\/p>","collection":"","timer":"","expired_message":"Time expired","style":"default","font_size":36,"spacing_bottom":30,"first_button_label":"","first_button_link":"","first_button_type":"primary","second_button_label":"","second_button_link":"","second_button_type":"primary","content_alignment":"left","subheading_font_size":15,"subheading_font_weight":"subheading_weight","subheading_spacing_bottom":8,"heading_font_size":36,"heading_font_weight":"heading_weight","heading_uppercase":false,"heading_spacing_bottom":25,"des_font_size":15,"des_font_weight":"body_weight","des_spacing_bottom":30}}},"block_order":["text_4HeFjG","text_yU9nKn","text_7zbxDq"],"custom_css":[],"settings":{"section_width":"container","heading":"","description":"","header_size":"medium","header_alignment":"center","column_gap":10,"content_background_color":"","equal_height_adjustment":false,"carousel_on_mobile":false,"items_per_row_mobile":1,"padding_top":0,"padding_bottom":0,"reset_spacing":false}},"divider_jTBGQJ":{"type":"divider","settings":{"section_width":"container","border_height":1,"border_color":"#ebebeb","reset_spacing":false}},"rich_text_td9KN9":{"type":"rich-text","blocks":{"heading_izj8pi":{"type":"heading","settings":{"heading":"Our Story","font_size":36,"font_weight":"heading_weight","uppercase":false,"spacing_bottom":10}},"description_Jpw6Dw":{"type":"description","settings":{"description":"<p>The Affordable Organic Store was started by Mr Kamal Gupta and Mrs Manju Gupta. Mr Gupta retired from the Indian Air Force after serving it for 27 years while Mrs Gupta is a retired government school teacher. Together they wanted to work on helping people to lead a sustainable life at an affordable cost.<\/p><p>With this aim, they started The Affordable Organic Store in June 2020. Both of them were fond of gardening but found the available options in the market too expensive for a small balcony garden. Most of the options for buying seeds online provided seeds in bulk, but for their small balcony garden, they needed only a couple of seeds. They tried getting plants from the nursery but often their options were limited by the nursery stock. They also struggled to understand why their nursery plants would not survive for long at home.<\/p>","font_size":18,"font_weight":"body_weight","spacing_bottom":10}},"description_kWEnXx":{"type":"description","settings":{"description":"<p>With these struggles, they decided to start their store. In the initial days, they sold seeds after hand packing them themselves within Hyderabad. Today they have a team of around ten women. They help them in running the operations and deliver across India.<\/p><p>They are happy with their small initiative and take pride in serving every person who wants to start a garden. If you want to connect with them, do write to us at <a href=\"mailto:info@theaffordableorganicstore.com\">info@theaffordableorganicstore.com<\/a><\/p>","font_size":18,"font_weight":"body_weight","spacing_bottom":19}}},"block_order":["heading_izj8pi","description_Jpw6Dw","description_kWEnXx"],"settings":{"section_width":"container","color_scheme":"","content_alignment":"left","content_max_width":100,"enable_expand_content":false,"expand_content_button":"See all Information","padding_top":0,"padding_bottom":25,"reset_spacing":true}},"divider_TAXJn3":{"type":"divider","settings":{"section_width":"container","border_height":1,"border_color":"#ebebeb","reset_sp