ction_jxixqF","collection_WyMTyK","collection_393Yjb","collection_dKAzNh"],"custom_css":["h2.section__header-heading.heading-letter-spacing.mt-0.mb-0 {color: #000;}",":where(.rounded-50) {border-radius: 0;}"],"settings":{"section_width":"fluid_container","color_scheme":"scheme-27a7c9da-d9e3-4009-a56f-299baf393c5e","heading":"Shop by Category","description":"","show_view_all_button":false,"header_size":"medium","header_alignment":"center","display_mode":"grid","image_ratio":"adapt","custom_ratio":"","items_per_row":6,"column_gap":20,"collection_information_position":"below_image","design":"morden","text_alignment":"center","show_product_count":false,"show_icon":false,"show_description":false,"font_size":22,"font_weight":"heading_weight","information_spacing":12,"rounded_image":true,"image_custom_width":true,"image_width":185,"show_arrow":true,"carousel_pagination":"show_dots_on_mobile","infinite":false,"autoplay":false,"autorotate_speed":5,"reveal":false,"items_per_row_mobile":2,"padding_top":0,"padding_bottom":0,"reset_spacing":false}},"products_grid_cwRera":{"type":"products-grid","settings":{"section_width":"fluid_container","color_scheme":"default","heading":"Explore Our Products","description":"","header_size":"medium","header_alignment":"center","collection":"featured-test","items_to_show":100,"items_per_row":4,"column_gap":30,"rows_on_desktop":4,"action_with_additional_products":"load_more","button_label":"Load more","show_banner":false,"sticky_banner":false,"banner_width":30,"position":"left","banner_type":"image","video_url":"","banner_text_color":"default","banner_heading":"","banner_subheading":"","banner_description":"","banner_button_label":"","banner_link":"","carousel_on_mobile":false,"items_per_row_mobile":2,"padding_top":0,"padding_bottom":0,"reset_spacing":false}},"faq_6wDCpy":{"type":"faq","blocks":{"faq_items_U4ytp6":{"type":"faq-items","settings":{"faq_title":"What all do you have at The Affordable Organic Store?","faq_content":"<p>The Affordable Organic store has the widest range of flower seeds, vegetable seeds, pots, planters, manure, vermi-compost, cocopeat, neem powder and any thing you may need for gardening. We also have options for sustainable living like bamboo brushes, wooden tongue cleaner, bamboo straw, loofah and many more.<\/p>"}},"faq_items_AYqYBm":{"type":"faq-items","settings":{"faq_title":"Is The Affordable Organic Store genuine or fake?","faq_content":"<p>We are absolutely genuine. We have our warehouse in Hyderabad and deliver across India. We have served over 100,000 customers since our beginning. The affordable organic store has more than 50,000 followers on Instagram and more than 10,000 followers on Facebook. We are rated more than 4.5 on Google reviews. Rest assured, feel free to reach us on-call (040 66588313), Whatsapp (9502244740) or email info@theaffordableorganicstore.com . Our team will revert in less than 24 hours. You can also write to our CEO at shivam@theaffordableorganicstore.com<br\/><br\/><\/p>"}},"faq_items_cr3AJG":{"type":"faq-items","settings":{"faq_title":"Does The Affordable Organic Store have a Cash on Delivery Option?","faq_content":"<p>Currently, we do not have a cash on delivery option. One can make a cart of Rs 50 and above and make a small purchase. We do not encourage Cash on Delivery as it adds additional Rs 65 on every order by the shipping partners which makes our products expensive. The aim of The Affordable Organic Store is to keep things Affordable for all gardeners. Hence, we do not plan to provide cash on delivery in future as well.<\/p>"}},"faq_items_kgbbik":{"type":"faq-items","settings":{"faq_title":"Will all the seeds germinate?","faq_content":"<p>We provide the highest quality seeds that have a high germination rate. All our seeds are tested for germination in a lab before we ship them. But different seeds require different expertise levels to grow. Please check the difficulty level before selecting your seeds. If you are a beginner try with easy difficulty level seeds.<\/p>"}},"faq_items_dgTG76":{"type":"faq-items","settings":{"faq_title":"When will I receive my order? How to track my order?","faq_content":"<p>We ship the order within 48 hours of the order placed in most cases. We ship via DTDC, Bluedart and Indian post depending upon the service availability. All our packets are dispatched from Hyderabad. Generally, metros take 3-7 days to deliver while non-metros may take up to 7-14 working days after the order is dispatched from our side. For remote places and the northeast, it may take some more time. You will receive a tracking ID, within 48 hours of placing your order. You can track it for continuous updates<\/p>"}},"faq_items_gWHXRM":{"type":"faq-items","settings":{"faq_title":"Can I cancel my order?","faq_content":"<p>Currently, we do not have an order cancellation option. Order once placed will not be cancelled.<\/p>"}},"faq_items_AnzwNq":{"type":"faq-items","settings":{"faq_title":"Can you provide seeds for free?","faq_content":"<p>If you have a great reason and you cannot afford our seeds, we can provide you with our seeds for free provided you have a great reason. Share your reason why you want our seeds for free and how you would use them in a short brief on info@theaffordableorganicstore.com. We will share this on our Facebook page and if more than 200 people like your reason, we will provide you with a coupon of Rs 500 with free shipping from our site.<\/p>"}},"faq_items_LTk3LN":{"type":"faq-items","settings":{"faq_title":"How can I collaborate with you?","faq_content":"<p>We love collaborations with everyone. If you are an influencer, we can do a giveaway, unboxing, workshops, blogs and many other things with you. Feel free to reach us with your details at info@theaffordableorganicstore.com with your details. Our team will connect with you within 48 hours.<\/p>"}},"faq_items_fqg9Hq":{"type":"faq-items","settings":{"faq_title":"How can I supply seeds to you?","faq_content":"<p>Just write to us at procurement@theaffordableorganicstore.com with your details. Our procurement team will connect with you and take it forward.<\/p>"}},"faq_items_pwzPhW":{"type":"faq-items","settings":{"faq_title":"We are an NGO and we want to collaborate with The Affordable Organic Store. How can we do that?","faq_content":"<p>We would be more than happy to collaborate with you. We can provide up to 1000 free seeds packets if we find your cause genuine and you would use them for a great purpose. We support all sustainability and environmental causes. Reach out to us at info@theaffordableorganicstore.com with your details. Our team will help you. <\/p>"}},"faq_items_JfafpG":{"type":"faq-items","settings":{"faq_title":"Do you sponsor events?","faq_content":"<p>We have sponsored many events in the past ranging from college fests, corporate events to events in a gated community. We do not sponsor in cash but do provide vouchers for our site as sponsorship. For sponsorship, send your proposal to info@theaffordableorganicstore.com . <\/p>"}}},"block_order":["faq_items_U4ytp6","faq_items_AYqYBm","faq_items_cr3AJG","faq_items_kgbbik","faq_items_dgTG76","faq_items_gWHXRM","faq_items_AnzwNq","faq_items_LTk3LN","faq_items_fqg9Hq","faq_items_pwzPhW","faq_items_JfafpG"],"settings":{"section_width":"container","color_scheme":"","heading":"Frequently Asked Questions","description":"","header_size":"medium","header_alignment":"center","padding_top":0,"padding_bottom":0,"reset_spacing":false}},"17440180042d4bba54":{"type":"apps","disabled":true,"settings":{}},"multi_content_LfNfT3":{"type":"multi-content","blocks":{"image_PwDDaN":{"type":"image","settings":{"image":"shopify:\/\/shop_images\/Bangalore.webp","image_behavior":"none","image_link":"shopify:\/\/pages\/bangalore","content_width":"16.6%","vertical_align":"start"}},"image_3dky6p":{"type":"image","settings":{"image":"shopify:\/\/shop_images\/Kolkata.webp","image_behavior":"none","image_link":"shopify:\/\/pages\/kolkata","content_width"