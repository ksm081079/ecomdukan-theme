weight","des_spacing_bottom":30}},"text_xwnPP4":{"type":"text","settings":{"color_scheme":"scheme-1","content_width":"33.3333%","vertical_align":"start","image_link":"","subheading":"","heading":"What eco-friendly habits can teams learn?","description":"<p>Teams gain valuable eco-friendly practices they can use in their daily lives.<\/p>","collection":"","timer":"","expired_message":"Time expired","style":"default","font_size":36,"spacing_bottom":30,"first_button_label":"","first_button_link":"","first_button_type":"primary","second_button_label":"","second_button_link":"","second_button_type":"primary","content_alignment":"left","subheading_font_size":12,"subheading_font_weight":"subheading_weight","subheading_spacing_bottom":15,"heading_font_size":36,"heading_font_weight":"heading_weight","heading_uppercase":false,"heading_spacing_bottom":20,"des_font_size":14,"des_font_weight":"body_weight","des_spacing_bottom":30}},"text_KqLjtL":{"type":"text","settings":{"color_scheme":"scheme-1","content_width":"33.3333%","vertical_align":"start","image_link":"","subheading":"","heading":"What makes this drive a unique mix of learning and fun?","description":"<p>A unique blend of learning and enjoyment in a natural setting.<\/p>","collection":"","timer":"","expired_message":"Time expired","style":"default","font_size":36,"spacing_bottom":30,"first_button_label":"","first_button_link":"","first_button_type":"primary","second_button_label":"","second_button_link":"","second_button_type":"primary","content_alignment":"left","subheading_font_size":12,"subheading_font_weight":"subheading_weight","subheading_spacing_bottom":15,"heading_font_size":36,"heading_font_weight":"heading_weight","heading_uppercase":false,"heading_spacing_bottom":20,"des_font_size":14,"des_font_weight":"body_weight","des_spacing_bottom":30}}},"block_order":["text_NGqeXF","text_xwnPP4","text_KqLjtL"],"name":"t:sections.multi_content.name","settings":{"section_width":"fluid_container","heading":"","description":"","header_size":"medium","header_alignment":"center","column_gap":30,"content_background_color":"","equal_height_adjustment":false,"carousel_on_mobile":false,"items_per_row_mobile":1,"padding_top":0,"padding_bottom":0,"reset_spacing":false}},"17468631261971e3aa":{"type":"apps","blocks":{"forms_inline_GfTyjL":{"type":"shopify:\/\/apps\/forms\/blocks\/inline\/8744a304-fcb1-4347-b211-bb6b4759a76a","settings":{"form_id":"458581","text_color":"#202020","button_background_color":"#202020","button_label_color":"#FFFFFF","links_color":"#1878B9","errors_color":"#E02229","text_alignment":"center","form_alignment":"center","padding_top":0,"padding_bottom":0,"padding_right":0,"padding_left":0}}},"block_order":["forms_inline_GfTyjL"],"settings":{}},"faq_t9YeEh":{"type":"faq","blocks":{"faq_items_XXjTKX":{"type":"faq-items","settings":{"faq_title":"1. What is a school farm visit and plantation drive in Hyderabad?","faq_content":"<p>A school farm visit and plantation drive is an educational and environmental activity where students visit a farm, learn about agriculture and sustainability, and actively participate in planting trees or plants to promote ecological awareness.<\/p>"}},"faq_items_7MDRzK":{"type":"faq-items","settings":{"faq_title":"2. How can our school participate in the farm visit and plantation drive in Hyderabad?","faq_content":"<p>Schools can participate by registering through our website or contacting us directly. We’ll guide you through the process, including scheduling a visit and customizing the experience for your students.<\/p>"}},"faq_items_KaYgkA":{"type":"faq-items","settings":{"faq_title":"3. Where will the school farm visit and plantation drive take place?","faq_content":"<p>The event will take place at Akshayakalpa Farm, Hyderabad, a pre-determined eco-friendly location equipped to provide a safe and enriching experience for students.<\/p>"}},"faq_items_dhNa4L":{"type":"faq-items","settings":{"faq_title":"4. Do you provide plants, tools, and guidance for the plantation drive during the school visit?","faq_content":"<p>Yes, we provide all the necessary resources, including plants, tools, and expert guidance, to ensure a smooth and educational plantation drive for the students.<\/p>"}},"faq_items_w3VYmJ":{"type":"faq-items","settings":{"faq_title":"5. What are the educational benefits of a school farm visit and plantation drive?","faq_content":"<p>Students gain hands-on experience in agriculture, learn about the importance of trees and sustainable practices, and develop a deeper appreciation for environmental conservation.<\/p>"}},"faq_items_9nGKUE":{"type":"faq-items","settings":{"faq_title":"6. Is there a minimum or maximum number of students allowed for the farm visit and plantation drive?","faq_content":"<p>We can accommodate groups of all sizes for the tree plantation drive in Hyderabad. Let us know your team size, and we will tailor the event accordingly.<\/p>"}},"faq_items_cbMQke":{"type":"faq-items","settings":{"faq_title":"7. Can we document the school farm visit and plantation drive?","faq_content":"<p>Absolutely! You can document the event, and we can also assist in creating videos or photographs to highlight your efforts.<\/p>"}},"faq_items_mKdt9B":{"type":"faq-items","settings":{"faq_title":"8. Can our school sponsor or collaborate on a plantation drive in Hyderabad?","faq_content":"<p>Yes, schools can sponsor or collaborate on plantation drives. We offer sponsorship packages that can include branding opportunities and a dedicated plantation area.<\/p>"}},"faq_items_d7PxqD":{"type":"faq-items","settings":{"faq_title":"9. What is the long-term impact of a farm visit and tree plantation activity on students?","faq_content":"<p>These activities inspire a sense of responsibility towards the environment, foster teamwork, and provide lifelong lessons on sustainability and the importance of greenery.<\/p>"}},"faq_items_dmKFJG":{"type":"faq-items","settings":{"faq_title":"10. How long does a school farm visit and plantation drive event last?","faq_content":"<p>Our tree plantation drives typically run from 11 AM to 5 PM, but the schedule can be adjusted to suit your team’s availability. Along with tree planting, we offer a variety of events and activities at<strong>Akshayakalpa, Hyderabad<\/strong>, designed to help participants de-stress and reconnect with nature while promoting environmental sustainability.<\/p>"}}},"block_order":["faq_items_XXjTKX","faq_items_7MDRzK","faq_items_KaYgkA","faq_items_dhNa4L","faq_items_w3VYmJ","faq_items_9nGKUE","faq_items_cbMQke","faq_items_mKdt9B","faq_items_d7PxqD","faq_items_dmKFJG"],"name":"t:sections.faq.presets.name","settings":{"section_width":"container","color_scheme":"","heading":"FAQ","description":"","header_size":"medium","header_alignment":"center","padding_top":0,"padding_bottom":0,"reset_spacing":false}}},"order":["main","rich_text_pUNYHK","multi_content_XLxcFr","multi_content_q6UiEe","multi_content_YcTAKa","multi_content_ihDbdm","17468631261971e3aa","faq_t9YeEh"]}