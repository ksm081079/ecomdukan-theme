px 0 0;background:rgba(255,255,255,.95);border:none;width:34px;height:34px;border-radius:50%;font-size:20px;cursor:pointer;display:flex;align-items:center;justify-content:center;z-index:5;padding:0;line-height:1;box-shadow:0 2px 8px rgba(0,0,0,.18);color:#111}.tao-qv-x:hover{background:#0e855b;color:#fff}.tao-qv-gallery{position:relative;background:#faf8f3;margin-top:-44px}.tao-qv-hero{display:block;width:100%;aspect-ratio:1\/1;object-fit:cover;background:#faf8f3}.tao-qv-disc{position:absolute;top:12px;left:12px;background:linear-gradient(135deg,#ff3b30,#e63946);color:#fff;font-size:12px;font-weight:900;padding:6px 11px;border-radius:6px;letter-spacing:.06em;box-shadow:0 4px 14px rgba(230,57,70,.5);animation:tao-pulse 1.6s ease-in-out infinite;text-transform:uppercase}@keyframes tao-pulse{0%,100%{transform:scale(1)}50%{transform:scale(1.04)}}.tao-qv-disc:empty{display:none}.tao-qv-thumbs{display:flex;gap:6px;padding:8px 12px;overflow-x:auto;scrollbar-width:none;background:#fff}.tao-qv-thumbs::-webkit-scrollbar{display:none}.tao-qv-thumbs img{width:48px;height:48px;object-fit:cover;border-radius:6px;border:2px solid transparent;cursor:pointer;flex:0 0 auto;opacity:.7;transition:opacity .12s,border-color .12s}.tao-qv-thumbs img.active,.tao-qv-thumbs img:hover{opacity:1;border-color:#0e855b}.tao-qv-thumbs:empty{display:none}.tao-qv-meta{padding:14px 20px 18px}.tao-qv-tag{display:inline-block;font-size:10px;font-weight:700;letter-spacing:.1em;color:#0e855b;text-transform:uppercase;margin-bottom:6px}.tao-qv-title{font-size:20px;line-height:1.25;margin:0 0 8px;font-weight:700;color:#111}.tao-qv-price{display:flex;align-items:center;gap:10px;margin-bottom:10px;flex-wrap:wrap}.tao-qv-price .now{font-size:22px;font-weight:800;color:#111}.tao-qv-price .was{font-size:15px;color:#e63946;text-decoration:line-through;text-decoration-color:#e63946;text-decoration-thickness:2px;font-weight:600}.tao-qv-price .pct{font-size:11px;font-weight:900;background:linear-gradient(135deg,#ff3b30,#e63946);color:#fff;padding:4px 9px;border-radius:4px;letter-spacing:.06em;box-shadow:0 2px 8px rgba(230,57,70,.4);text-transform:uppercase}.tao-qv-rating{display:flex;align-items:center;gap:6px;margin-bottom:14px;font-size:13px;color:#666;min-height:1px}.tao-qv-rating:empty{display:none}.tao-qv-desc{font-size:14px;line-height:1.55;color:#444;margin-bottom:18px}.tao-qv-desc p{margin:0 0 10px}.tao-qv-desc p:last-child{margin-bottom:0}.tao-qv-desc img{max-width:100%;height:auto;border-radius:6px;margin:8px 0}.tao-qv-desc ul,.tao-qv-desc ol{padding-left:20px;margin:0 0 10px}.tao-qv-desc:empty::before{content:'';display:block;height:60px;background:linear-gradient(90deg,#f0f0f0 0%,#fafafa 50%,#f0f0f0 100%);background-size:200% 100%;animation:tao-skel 1s linear infinite;border-radius:6px}@keyframes tao-skel{from{background-position:200% 0}to{background-position:-200% 0}}.tao-qv-foot{position:sticky;bottom:0;left:0;right:0;background:#fff;padding:12px 20px 14px;border-top:1px solid #ebebeb;box-shadow:0 -8px 20px -10px rgba(0,0,0,.1);z-index:4}.tao-qv-progress{margin-bottom:10px}.tao-qv-progress .row{display:flex;justify-content:space-between;font-size:12px;color:#666;margin-bottom:5px;font-weight:700}.tao-qv-progress .row .done{color:#0e855b}.tao-qv-progress .bar{height:7px;background:#ebebeb;border-radius:999px;overflow:hidden}.tao-qv-progress .bar i{display:block;height:100%;background:linear-gradient(90deg,#ffc107,#0e855b);border-radius:999px;transition:width .35s cubic-bezier(.4,1.4,.6,1);width:0;box-shadow:0 0 8px rgba(14,133,91,.4)}.tao-qv-progress.full .bar i{background:linear-gradient(90deg,#0e855b,#14a06b)}.tao-qv-progress .save{margin-top:8px;display:flex;align-items:center;justify-content:space-between;gap:8px;font-size:12px;min-height:1em}.tao-qv-progress .save:empty{display:none}.tao-qv-progress .save .pill{background:linear-gradient(135deg,#14a06b,#0e855b);color:#fff;padding:5px 11px;border-radius:999px;font-weight:800;letter-spacing:.02em;white-space:nowrap;box-shadow:0 3px 10px rgba(14,133,91,.4)}.tao-qv-progress .save .mrp{color:#e63946;text-decoration:line-through;text-decoration-color:#e63946;text-decoration-thickness:1.8px;font-weight:700;font-size:12px}.tao-qv-progress .save.hint{color:#999;font-weight:500;display:block;text-align:right}.tao-qv-add{display:block;width:100%;background:#0e855b;color:#fff;border:none;padding:14px;font-size:15px;font-weight:800;border-radius:10px;cursor:pointer;letter-spacing:.02em;transition:background .12s,transform .08s,box-shadow .12s;box-shadow:0 4px 14px rgba(14,133,91,.3)}.tao-qv-add:hover{background:#0a6e4a;box-shadow:0 6px 18px rgba(14,133,91,.4)}.tao-qv-add:active{transform:scale(.98)}.tao-qv-add.full{background:#999;cursor:not-allowed;box-shadow:none}body.tao-qv-open{overflow:hidden}@media(max-width:560px){.tao-qv-card{max-width:100%;max-height:94vh;border-radius:16px}.tao-qv-meta{padding:12px 18px 14px}.tao-qv-title{font-size:18px}.tao-qv-foot{padding:10px 18px 12px}}<\/style><div class=\"tao-qv\" id=\"taoQv\" role=\"dialog\" aria-modal=\"true\" aria-hidden=\"true\"><div class=\"tao-qv-card\"><button class=\"tao-qv-x\" type=\"button\" aria-label=\"Close\" data-close>&times;<\/button><div class=\"tao-qv-gallery\"><img class=\"tao-qv-hero\" alt=\"\"><span class=\"tao-qv-disc\"><\/span><\/div><div class=\"tao-qv-thumbs\"><\/div><div class=\"tao-qv-meta\"><span class=\"tao-qv-tag\">Quick view<\/span><h2 class=\"tao-qv-title\"><\/h2><div class=\"tao-qv-price\"><\/div><div class=\"tao-qv-rating\"><\/div><div class=\"tao-qv-desc\"><\/div><\/div><div class=\"tao-qv-foot\"><div class=\"tao-qv-progress\"><div class=\"row\"><span class=\"done\">0 added<\/span><span class=\"left\"><\/span><\/div><div class=\"bar\"><i><\/i><\/div><div class=\"save\"><\/div><\/div><button class=\"tao-qv-add\" type=\"button\">Add to bundle<\/button><\/div><\/div><\/div><script>(function(){function init(){var modal=document.getElementById('taoQv');if(!modal)return;var hero=modal.querySelector('.tao-qv-hero');var disc=modal.querySelector('.tao-qv-disc');var thumbs=modal.querySelector('.tao-qv-thumbs');var titleEl=modal.querySelector('.tao-qv-title');var priceEl=modal.querySelector('.tao-qv-price');var ratingEl=modal.querySelector('.tao-qv-rating');var descEl=modal.querySelector('.tao-qv-desc');var addBtn=modal.querySelector('.tao-qv-add');var cardEl=modal.querySelector('.tao-qv-card');var progressEl=modal.querySelector('.tao-qv-progress');var progressDone=progressEl.querySelector('.done');var progressLeft=progressEl.querySelector('.left');var progressBar=progressEl.querySelector('.bar i');var progressSave=progressEl.querySelector('.save');var activeCard=null;var bundleSection=document.querySelector('.bundle-section');function fmt(cents){return 'Rs. '+(cents\/100).toFixed(2);}function setActiveImage(src){hero.src=src;Array.from(thumbs.children).forEach(function(t){t.classList.toggle('active',t.src===src);});}function updateProgress(){if(!bundleSection){progressEl.style.display='none';return;}var size=parseInt(bundleSection.getAttribute('data-bundle-size')||'5',10);var filled=bundleSection.querySelectorAll('.bundle-slot.filled').length;var pct=Math.min(100,Math.round((filled\/size)*100));progressDone.textContent=filled+' of '+size+' added';progressLeft.textContent=filled>=size?'Bundle full':((size-filled)+' to go');progressBar.style.width=pct+'%';progressEl.classList.toggle('full',filled>=size);addBtn.classList.toggle('full',filled>=size);addBtn.textContent=filled>=size?'Bundle full':'Add to bundle';var saveEl=bundleSection.querySelector('[id^=\"bundle-save-\"],.bundle-mrp-save');var mrpEl=bundleSection.querySelector('[id^=\"bundle-mrp-\"]:not([id*=\"wrap\"]),.bundle-mrp-value');var saveTxt=saveEl?(saveEl.textContent||'').trim():'';var mrpTxt=mrpEl?(mrpEl.textContent||'').trim():'';if(filled===0){progressSave.innerHTML='Add items to unlock savings';progressSave.className='save hint';}else if(saveTxt){var cleanSave=saveTxt.replace(\/^Save\\s+\/i,'');progressSave.className='save';progressSave.innerHTML='<span class=\"pill\">You save '+cleanSave+'<\/span>'+(mrpTxt?'<span class=\"mrp\">MRP '+mrpTxt+'<\/span>':'');}else{progressSave.innerHTML='';progressSave.className='save';}}function openModal(){modal.classList.add('open');modal.setAttribute('aria-hidden','false');document.body.classList.add('tao-qv-open');cardEl.scrollTop=0;updateProgress();}function closeModal(){modal.classList.remove('open');modal.setAttribute('aria-hidden','true');document.body.classList.remove('tao-qv-open');activeCard=null;}function renderFromCard(c){var ds=c.dataset||{};titleEl.textContent=ds.productTitle||(c.querySelector('.product-item__name,h3,h4')||{}).textContent||'';hero.src=ds.productImage||(c.querySelector('img')||{}).src||'';hero.alt=titleEl.textContent;disc.textContent='';priceEl.innerHTML='<span class=\"now\">'+(ds.productPrice||fmt(parseInt(ds.priceCents||'0',10)))+'<\/span>';ratingEl.innerHTML='';var r=c.querySelector('.product__rating,.spr-badge,.jdgm-prev-badge,[class*=\"rating\"]');if(r)ratingEl.appendChild(r.cloneNode(true));thumbs.innerHTML='';descEl.innerHTML='';}function loadReviewsFromPDP(handle){rvMount.innerHTML='<div class=\"tao-rv-loading\">Loading reviews&hellip;<\/div>';reviewsBox.hidden=false;var ifr=document.createElement('iframe');ifr.style.cssText='position:absolute;left:-9999px;top:-9999px;width:900px;height:1400px;border:0;visibility:hidden;opacity:0;pointer-events:none';ifr.setAttribute('aria-hidden','true');ifr.src='\/products\/'+handle;document.body.appendChild(ifr);var tries=0,maxTries=40;var done=false;function cleanup(){if(!done){done=true;try{ifr.remove();}catch(_){}}}function extract(){if(done)return;tries++;try{var doc=ifr.contentDocument;if(doc){var widget=doc.querySelector('.jdgm-rev-widg,.jdgm-widget.jdgm-review-widget');var hasContent=widget&&(widget.querySelector('.jdgm-rev,.jdgm-no-reviews,.jdgm-rev-widg__summary,.jdgm-histogram'));if(hasContent){rvMount.innerHTML='';rvMount.appendChild(widget.cloneNode(true));cleanup();return;}}}catch(_){}if(tries<maxTries){setTimeout(extract,200);}else{rvMount.innerHTML='<div class=\"tao-rv-empty\">No reviews to show yet.<\/div>';cleanup();}}ifr.addEventListener('load',function(){setTimeout(extract,400);});setTimeout(function(){if(!done&&tries===0)extract();},1000);}function enrichFromJson(handle){fetch('\/products\/'+handle+'.js',{cache:'force-cache'}).then(function(r){return r.json();}).then(function(p){if(p.title)titleEl.textContent=p.title;var priceHtml='<span class=\"now\">'+fmt(p.price)+'<\/span>';if(p.compare_at_price&&p.compare_at_price>p.price){var pct=Math.round((1-p.price\/p.compare_at_price)*100);priceHtml+='<span class=\"was\">'+fmt(p.compare_at_price)+'<\/span>';priceHtml+='<span class=\"pct\">SAVE '+pct+'%<\/span>';disc.textContent=pct+'% OFF';}else{disc.textContent='';}priceEl.innerHTML=priceHtml;if(p.description)descEl.innerHTML=p.description;var imgs=(p.images&&p.images.length)?p.images:(p.featured_image?[p.featured_image]:[]);if(imgs.length){hero.src=imgs[0];thumbs.innerHTML='';if(imgs.length>1){imgs.forEach(function(src,i){var t=document.createElement('img');t.src=src;t.alt='';if(i===0)t.classList.add('active');t.addEventListener('click',function(){setActiveImage(src);});thumbs.appendChild(t);});}}}).catch(function(){});}modal.querySelectorAll('[data-close]').forEach(function(el){el.addEventListener('click',closeModal);});modal.addEventListener('click',function(e){if(e.target===modal)closeModal();});document.addEventListener('keydown',function(e){if(e.key==='Escape'&&modal.classList.contains('open'))closeModal();});addBtn.addEventListener('click',function(){if(!activeCard||addBtn.classList.contains('full'))return;var cardAdd=activeCard.querySelector('.card-add-btn,.product__add-cart,[data-add-to-cart],button[type=\"submit\"]');if(cardAdd){cardAdd.click();}closeModal();});if(bundleSection){var mo=new MutationObserver(function(){if(modal.classList.contains('open'))updateProgress();});mo.observe(bundleSection,{subtree:true,attributes:true,attributeFilter:['class']});}var skipSel='.card-add-btn,.product__add-cart,.product__add-cart-bg,button[type=\"submit\"],[data-add-to-cart],[name=\"add\"],.product-form__buttons,.quantity__button,.swiper-pagination,.swiper-button-next,.swiper-button-prev,.swiper-pagination-bullet,.product-card__quick-buy,.product-item__select-options';document.addEventListener('click',function(e){if(e.target.closest(skipSel))return;var c=e.target.closest('.bundle-product-card');if(!c)return;var link=c.querySelector('a[href*=\"\/products\/\"]');if(!link)return;var path=link.getAttribute('href')||link.pathname||'';var m=path.match(\/\\\/products\\\/([^\/?#]+)\/);if(!m)return;e.preventDefault();e.stopPropagation();e.stopImmediatePropagation();activeCard=c;renderFromCard(c);openModal();enrichFromJson(m[1]);},true);}if(document.readyState==='loading'){document.addEventListener('DOMContentLoaded',init);}else{init();}})();<\/script>","color_scheme":"scheme-1","padding_top":0,"padding_bottom":0}}},"order":["main","divider_GNgNrQ","rich_text_iDTxbH","bundle_pills_FBXARp","bundle_5_products_M86C3F","product_bundle_nrQGq3","tao_pdp_preview"]}