{"sections":{"main":{"type":"page-default","settings":{"section_width":"container","padding_top":0,"padding_bottom":0}},"rich_text_YEUW7T":{"type":"rich-text","blocks":{"subheading_fFAGee":{"type":"subheading","settings":{"subheading":"Events at the affordable organic store.","font_size":16,"font_weight":"subheading_weight","uppercase":false,"spacing_bottom":15}},"heading_MVb4Np":{"type":"heading","settings":{"heading":"GREEN LIVING FOR A SUSTAINABLE FUTURE","font_size":36,"font_weight":"heading_weight","uppercase":false,"spacing_bottom":24}},"button_YcbEVQ":{"type":"button","settings":{"first_button_label":"JOIN NOW WITH US","first_button_link":"","first_button_type":"primary","second_button_label":"","second_button_link":"","second_button_type":"primary","spacing_bottom":10}}},"block_order":["subheading_fFAGee","heading_MVb4Np","button_YcbEVQ"],"name":"t:sections.rich_text.name","settings":{"section_width":"container","color_scheme":"","content_alignment":"center","content_max_width":100,"enable_expand_content":false,"expand_content_button":"See all Information","padding_top":0,"padding_bottom":0,"reset_spacing":false}},"custom_html_DULw6M":{"type":"custom-html","name":"t:sections.html_custom.name","settings":{"section_width":"container","color_scheme":"","html_custom":"<div class=\"mainproduct\">\n    <div class=\"entry-content\">\n\n        <section style=\"padding: 40px 20px; background-color: #f9f9f9;\">\n            <div style=\"display: flex; flex-wrap: wrap; align-items: center; max-width: 1200px; margin: 0 auto;\">\n\n                <!-- Left column -->\n                <div style=\"flex: 1 1 50%; padding: 20px;\">\n                    <h3 style=\"font-size: 24px; margin-bottom: 10px; color: #7BAF42;\">TAOS EVENT<\/h3>\n                    <h2 style=\"font-size: 32px; background: linear-gradient(to right, #6ac045, #2e8b57); -webkit-background-clip: text; color: transparent; margin-bottom: 20px;\">\n                        Volunteer with Us!\n                    <\/h2>\n                    <p style=\"font-size: 16px; margin-bottom: 20px;\">\n                        Join our plantation events and contribute to a greener planet! Whether you’re a beginner or a\n                        seasoned\n                        volunteer, we’ll guide you every step of the way. Connect with eco-conscious individuals and\n                        make a\n                        meaningful environmental impact. Sign up now to stay informed about upcoming events!\n                    <\/p>\n                    <a href=\"https:\/\/theaffordableorganicstore.myshopify.com\/pages\/volunteer-with-us\" style=\"display: inline-block; padding: 12px 24px; background-color: #6ac045; color: #fff; text-decoration: none; border-radius: 4px; font-weight: bold;\">\n                        Volunteer now →\n                    <\/a>\n                <\/div>\n\n                <!-- Right column -->\n                <div style=\"flex: 1 1 50%; padding: 20px;\">\n                    <img src=\"https:\/\/i0.wp.com\/theaffordableorganicstore.com\/wp-content\/uploads\/2024\/09\/IMG-20240923-WA0017-scaled.jpg?fit=1024%2C768&amp;ssl=1\" alt=\"Events\" style=\"width: 100%; height: auto; border-radius: 8px;\">\n                <\/div>\n\n            <\/div>\n        <\/section>\n        <section style=\"padding: 40px 20px; background-color: #f9f9f9;\">\n            <div style=\"display: flex; flex-wrap: wrap; align-items: center; max-width: 1200px; margin: 0 auto;\">\n\n\n\n                <!-- Right column -->\n                <div style=\"flex: 1 1 50%; padding: 20px;\">\n                    <img src=\"https:\/\/i0.wp.com\/theaffordableorganicstore.com\/wp-content\/uploads\/2025\/03\/8th-plantation-drive-website-500-x-500-px.png?resize=1024%2C1024&amp;ssl=1\" alt=\"Events\" style=\"width: 100%; height: auto; border-radius: 8px;\">\n                <\/div>\n\n                <!-- Left column -->\n                <div style=\"flex: 1 1 50%; padding: 20px;\">\n                    <h3 style=\"font-size: 24px; margin-bottom: 10px; color: #7BAF42;\">TAOS EVENT<\/h3>\n                    <h2 style=\"font-size: 32px; background: linear-gradient(to right, #6ac045, #2e8b57); -webkit-background-clip: text; color: transparent; margin-bottom: 20px;\">\n                        Hyderabad Event\n                    <\/h2>\n                    <p style=\"font-size: 16px; margin-bottom: 20px;\">\n                        Join The Affordable Organic Store for a day of tree planting at Akshayakalpa Farms on 13th\n                        April, 2025\n                        from 11 AM to 5 PM. Connect with nature, enjoy a farm tour, and savor a delicious lunch.\n                        Register now\n                        for to secure your spot and contribute to a greener future\n                    <\/p>\n                    <a href=\"https:\/\/theaffordableorganicstore.myshopify.com\/pages\/hyderabad-event\" style=\"display: inline-block; padding: 12px 24px; background-color: #6ac045; color: #fff; text-decoration: none; border-radius: 4px; font-weight: bold;\">\n                        Events Deatils\n                    <\/a>\n                <\/div>\n\n            <\/div>\n        <\/section>\n\n        <section style=\"padding: 40px 20px; background-color: #f9f9f9;\">\n            <div style=\"display: flex; flex-wrap: wrap; align-items: center; max-width: 1200px; margin: 0 auto;\">\n\n\n\n                <!-- Left column -->\n                <div style=\"flex: 1 1 50%; padding: 20px;\">\n                    <h3 style=\"font-size: 24px; margin-bottom: 10px; color: #7BAF42;\">TAOS EVENT<\/h3>\n                    <h2 style=\"font-size: 32px; background: linear-gradient(to right, #6ac045, #2e8b57); -webkit-background-clip: text; color: transparent; margin-bottom: 20px;\">\n                        Farm Visits &amp; Plantation Drives for Schools\n                    <\/h2>\n                    <p style=\"font-size: 16px; margin-bottom: 20px;\">\n                        Looking to give your students a hands-on environmental experience?\n                        Join The Affordable Organic Store for affordable farm events and plantation drives!\n\n                        Enjoy activities like:\n                    <\/p>\n<ul>\n                        <li> Tree planting &amp; farm tours<\/li>\n                        <li> Organic gardening workshops<\/li>\n                        <li> Fun outdoor games<\/li>\n                        <li>Eco-friendly practices like composting &amp; rainwater harvesting<\/li>\n                    <\/ul>\n\n                    <p><\/p>\n                    <a href=\"https:\/\/theaffordableorganicstore.myshopify.com\/pages\/farm-visits\" style=\"display: inline-block; padding: 12px 24px; background-color: #6ac045; color: #fff; text-decoration: none; border-radius: 4px; font-weight: bold;\">\n                        Events Deatils\n                    <\/a>\n                <\/div>\n\n                <!-- Right column -->\n                <div style=\"flex: 1 1 50%; padding: 20px;\">\n                    <img src=\"https:\/\/i0.wp.com\/theaffordableorganicstore.com\/wp-content\/uploads\/2024\/11\/Photo-from-yug%E2%9B%A7.jpg?fit=1024%2C1024&amp;ssl=1\" alt=\"Events\" style=\"width: 100%; height: auto; border-radius: 8px;\">\n                <\/div>\n\n            <\/div>\n        <\/section>\n\n\n        <section style=\"padding: 40px 20px; background-color: #f9f9f9;\">\n            <div style=\"display: flex; flex-wrap: wrap; align-items: center; max-width: 1200px; margin: 0 auto;\">\n\n\n\n                <!-- Right column -->\n                <div style=\"flex: 1 1 50%; padding: 20px;\">\n                    <img src=\"https:\/\/i0.wp.com\/theaffordableorganicstore.com\/wp-content\/uploads\/2024\/11\/Corporate-drive.webp?resize=1024%2C576&amp;ssl=1\" alt=\"Events\" style=\"width: 100%; height: auto; border-radius: 8px;\">\n                <\/div>\n\n                <!-- Left column -->\n                <div style=\"flex: 1 1 50%; padding: 20px;\">\n                    <h3 style=\"font-size: 24px; margin-bottom: 10px; color: #7BAF42;\">TAOS EVENT<\/h3>\n                    <h2 style=\"font-size: 32px; background: linear-gradient(to right, #6ac045, #2e8b57); -webkit-background-clip: text; color: transparent; margin-bottom: 20px;\">\n                        Corporate Plantation Drives &amp; Farm Visits\n                    <\/h2>\n                    <p style=\"font-size: 16px; margin-bottom: 20px;\">\n                        Looking for a refreshing way to bring your team together? At The Affordable Organic Store, we\n                        create\n                        experiences that let you step out of the office and into nature. Whether it’s planting trees,\n                        enjoying\n                        farm-fresh meals, or learning about sustainable farming, our activities are designed to inspire,\n                        connect, and recharge your team. Spend a day making memories, doing good for the planet, and\n                        embracing a\n                        healthier, greener lifestyle—together.\n\n                        Why Choose Us?\n                    <\/p>\n<ul>\n                        <li>Foster sustainability with engaging activities.<\/li>\n                        <li> Promote wellness with a day in nature.<\/li>\n                        <li>Build a greener future together.<\/li>\n                    <\/ul>\n\n\n\n                    <p><\/p>\n                    <a href=\"https:\/\/theaffordableorganicstore.myshopify.com\/pages\/corporate-plantation\" style=\"display: inline-block; padding: 12px 24px; background-color: #6ac045; color: #fff; text-decoration: none; border-radius: 4px; font-weight: bold;\">\n                        Let’s Plan Your Day in Nature\n                    <\/a>\n                <\/div>\n\n            <\/div>\n        <\/section>\n    <\/div>\n<\/div>","padding_top":0,"padding_bottom":0,"reset_spacing":false}}},"order":["main","rich_text_YEUW7T","custom_html_DULw6M"]}