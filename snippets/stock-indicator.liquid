{% comment %}
  Stock Level Indicator
  
  Usage:
  {% render 'stock-indicator', product: product, variant: variant, threshold: 10 %}
{% endcomment %}

{%- liquid
  assign show_stock = false
  assign stock_quantity = 0
  assign stock_status = 'in_stock'
  assign stock_message = ''
  
  if variant.inventory_management == 'shopify' and variant.inventory_policy == 'deny'
    assign show_stock = true
    assign stock_quantity = variant.inventory_quantity
    
    if stock_quantity == 0
      assign stock_status = 'out_of_stock'
      assign stock_message = 'Out of Stock'
    elsif stock_quantity <= threshold
      assign stock_status = 'low_stock'
      assign stock_message = 'Only ' | append: stock_quantity | append: ' left!'
    else
      assign stock_status = 'in_stock'
      assign stock_message = 'In Stock'
    endif
  endif
-%}

{%- if show_stock -%}
  <div class="stock-indicator stock-indicator--{{ stock_status }}" data-stock-quantity="{{ stock_quantity }}">
    <span class="stock-indicator__icon">
      {%- if stock_status == 'out_of_stock' -%}
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.5"/>
          <path d="M5 5L11 11M11 5L5 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      {%- elsif stock_status == 'low_stock' -%}
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M8 3V8L11 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          <circle cx="8" cy="8" r="6.5" stroke="currentColor" stroke-width="1.5"/>
        </svg>
      {%- else -%}
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M13 4L6 11L3 8" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      {%- endif -%}
    </span>
    <span class="stock-indicator__text">{{ stock_message }}</span>
  </div>

  <style>
    .stock-indicator {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.375rem 0.75rem;
      border-radius: 6px;
      font-size: 0.8125rem;
      font-weight: 600;
      margin-top: 0.5rem;
    }

    .stock-indicator__icon {
      display: flex;
      align-items: center;
      flex-shrink: 0;
    }

    .stock-indicator--in_stock {
      background: rgba(16, 185, 129, 0.1);
      color: #10b981;
    }

    .stock-indicator--low_stock {
      background: rgba(245, 158, 11, 0.1);
      color: #f59e0b;
      animation: pulse 2s infinite;
    }

    .stock-indicator--out_of_stock {
      background: rgba(239, 68, 68, 0.1);
      color: #ef4444;
    }

    @keyframes pulse {
      0%, 100% {
        opacity: 1;
      }
      50% {
        opacity: 0.8;
      }
    }

    @media screen and (max-width: 749px) {
      .stock-indicator {
        font-size: 0.75rem;
        padding: 0.3125rem 0.625rem;
      }
    }
  </style>
{%- endif -%}

