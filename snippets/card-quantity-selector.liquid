{% comment %}
  Card Quantity Selector for Collection Pages - Matches Homepage Implementation

  Accepts:
  - product: {Object} Product object
  - variant: {Object} Variant object (optional, defaults to first available variant)
  - section_id: {String} Section ID

  Usage:
  {% render 'card-quantity-selector', product: product, section_id: section.id %}
{% endcomment %}

{% comment %} meetanshi code {% endcomment %}
  {% style %}
    .card__quantity-selector .product-form__quantity .quantity::before,
    .card__quantity-selector .product-form__quantity .quantity::after {
      content: unset;
    }
    .card__quantity-selector .product-form__quantity .quantity {
      border: 1px solid #dbdbdb !important;
      border-radius: 50px;
    }
  {% endstyle %}
{% comment %} meetanshi code {% endcomment %}

{%- liquid
  assign variant = variant | default: product.selected_or_first_available_variant
  assign product_form_id = 'card-quantity-' | append: section_id | append: product.id
  assign cart_qty = 0
  for item in cart.items
    if item.variant_id == variant.id
      assign cart_qty = item.quantity
      break
    endif
  endfor
-%}

<div class="card__quantity-selector" data-product-id="{{ product.id }}">
  <div class="product-form__quantity">
    <label class="visually-hidden" for="Quantity-{{ section_id }}-{{ product.id }}">
      {{ 'products.product.quantity.label' | t }}
    </label>
    <quantity-input class="quantity">
      <button class="quantity__button" name="minus" type="button">
        <span class="visually-hidden">
          {{- 'products.product.quantity.decrease' | t: product: product.title | escape -}}
        </span>
        <span class="svg-wrapper">
          {{- 'icon-minus.svg' | inline_asset_content -}}
        </span>
      </button>
      <input
        class="quantity__input"
        type="number"
        name="quantity"
        id="Quantity-{{ section_id }}-{{ product.id }}"
        aria-label="{{ 'products.product.quantity.input_label' | t: product: product.title | escape }}"
        data-cart-quantity="{{ cart_qty }}"
        data-min="{{ variant.quantity_rule.min }}"
        min="{{ variant.quantity_rule.min }}"
        {% if variant.quantity_rule.max != null %}
          data-max="{{ variant.quantity_rule.max }}"
          max="{{ variant.quantity_rule.max }}"
        {% endif %}
        step="{{ variant.quantity_rule.increment | default: 1 }}"
        value="{{ variant.quantity_rule.min }}"
        form="{{ product_form_id }}"
      >
      <button class="quantity__button" name="plus" type="button">
        <span class="visually-hidden">
          {{- 'products.product.quantity.increase' | t: product: product.title | escape -}}
        </span>
        <span class="svg-wrapper">
          {{- 'icon-plus.svg' | inline_asset_content -}}
        </span>
      </button>
    </quantity-input>
  </div>
  
  <div class="product-form__buttons">
    <product-form data-section-id="{{ section_id }}">
      <form action="{{ routes.cart_add_url }}" method="post" enctype="multipart/form-data" novalidate="novalidate" data-type="add-to-cart-form" id="{{ product_form_id }}">
        <input type="hidden" name="id" value="{{ variant.id }}">
        <input type="hidden" name="quantity" value="{{ variant.quantity_rule.min }}" class="product-form-quantity">
        <div class="product-form__error-message-wrapper" role="alert" hidden>
          <svg aria-hidden="true" focusable="false" class="icon icon-error" viewBox="0 0 13 13">
            <circle cx="6.5" cy="6.5" r="5.25" stroke="currentColor" stroke-width="1.25" fill="none"/>
            <path d="m5.227 3.427 5.299 5.299" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/>
            <path d="m10.526 3.427-5.299 5.299" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/>
          </svg>
          <span class="product-form__error-message"></span>
        </div>
        <button
          type="submit"
          name="add"
          class="product-form__cart-submit button button--full-width button--secondary"
          {% if variant.available == false %}
            disabled
          {% endif %}
        >
          <span>
            {%- if variant.available -%}
              {{ 'products.product.add_to_cart' | t }}
            {%- else -%}
              {{ 'products.product.sold_out' | t }}
            {%- endif -%}
          </span>
          <div class="loading__spinner hidden">
            <svg aria-hidden="true" focusable="false" class="spinner" viewBox="0 0 66 66" xmlns="http://www.w3.org/2000/svg">
              <circle class="path" fill="none" stroke-width="6" stroke-linecap="round" cx="33" cy="33" r="30"></circle>
            </svg>
          </div>
        </button>
      </form>
    </product-form>
  </div>
</div>

<style>
  .card__quantity-selector {
    margin-top: 1rem;
  }
  
  .card__quantity-selector .product-form__quantity {
    margin-bottom: 0.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
  }
  
  /* Quantity label is now visually-hidden for accessibility */
  .card__quantity-selector .quantity__label {
    display: none;
  }
  
  .card__quantity-selector .quantity {
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(var(--color-foreground), 0.2);
    border-radius: 0.4rem;
    overflow: hidden;
  }
  
  .card__quantity-selector .quantity__button {
    background: transparent;
    border: none;
    padding: 0.8rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background-color 0.2s ease;
    min-width: 4rem;
  }
  
  .card__quantity-selector .quantity__button:hover {
    background-color: rgba(var(--color-foreground), 0.05);
  }
  
  .card__quantity-selector .quantity__button.disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
  
  .card__quantity-selector .quantity__input {
    border: none;
    text-align: center;
    font-size: 1.4rem;
    padding: 0.8rem;
    width: 6rem;
    background: transparent;
  }
  
  .card__quantity-selector .quantity__input:focus {
    outline: 2px solid rgba(var(--color-foreground), 0.5);
    outline-offset: 2px;
  }
  
  .card__quantity-selector .product-form__cart-submit {
    width: 100%;
    margin-top: 0.5rem;
  }
  
  .card__quantity-selector .product-form__error-message-wrapper {
    margin-top: 0.5rem;
  }
  
  .card__quantity-selector .loading__spinner {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 2rem;
    height: 2rem;
  }
  
  .card__quantity-selector .spinner {
    animation: rotator 1.4s linear infinite;
  }
  
  @keyframes rotator {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(270deg); }
  }
  
  .card__quantity-selector .svg-wrapper {
    width: 1.6rem;
    height: 1.6rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  .card__quantity-selector .svg-wrapper svg {
    width: 100%;
    height: 100%;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const quantitySelector = document.querySelector('[data-product-id="{{ product.id }}"]');
    if (!quantitySelector) return;
    
    const quantityInput = quantitySelector.querySelector('.quantity__input');
    const hiddenQuantityInput = quantitySelector.querySelector('.product-form-quantity');
    
    if (quantityInput && hiddenQuantityInput) {
      // Sync initial value
      hiddenQuantityInput.value = quantityInput.value;
      
      // Listen for quantity changes
      quantityInput.addEventListener('input', function() {
        hiddenQuantityInput.value = this.value;
      });
      
      // Listen for button clicks (plus/minus)
      quantitySelector.addEventListener('click', function(e) {
        if (e.target.closest('.quantity__button')) {
          setTimeout(() => {
            hiddenQuantityInput.value = quantityInput.value;
          }, 10);
        }
      });
    }
  });
</script>