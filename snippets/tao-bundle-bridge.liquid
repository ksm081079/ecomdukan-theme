{%- comment -%}
  TAO Bundle Bridge
  Pushes BYOB bundles whenever a customer engages a single product.
  Touchpoints:
    1. PDP quantity ladder (inline)
    2. ATC popup (Bundle Bridge)
    3. Cart drawer Living Coach
    4. Cart page last-call bar
  Eligibility: only fires when product is in at least one bundle collection.
  Recommendations: Shopify /recommendations/products.json?intent=complementary, falls back to related, then bestsellers.
{%- endcomment -%}

{%- liquid
  assign bundle_collections = "buy-any-3-at-199,buy-any-4-at-299,buy-any-5-at-399,buy-any-4-at-429,buy-any-3-at-529,buy-any-4-at-579" | split: ","
-%}

<style>
/* === Social Proof on PDP === */
/* Hide the theme's built-in sold-product / live-view blocks — we render a single combined version below.
   Use :has() to also hide the surrounding flex wrapper that includes the orphan fire-icon SVG. */
.live_view,
sold-product,
.flex:has(> sold-product),
.review_sold > .flex:has(sold-product),
.product-detail__sold-product, .product__sold-row, .product-sold-row { display:none !important }

/* === PDP product-info column: vertical rhythm ===
   Tag rule: BREATHING space above (title → tag), MINOR space below (tag → price). */
.product-detail__title{margin-bottom:18px !important;line-height:1.18}
.product-tag,
.product-detail__tag,
.product-detail__tags,
.product-detail__title-tag{margin:0 !important;padding:4px 12px !important}
.product-detail__price{margin-top:8px !important;margin-bottom:6px !important}
.tax-include{font-size:12px;color:#888;margin-top:2px;margin-bottom:10px !important;line-height:1.3}
.product-detail__price + .tax-include{margin-top:0}
.review_sold{margin-bottom:8px !important}
.product-detail__short-description{margin-top:8px !important;margin-bottom:12px !important;line-height:1.45}
.product-addons{padding-bottom:14px !important;margin-bottom:14px !important}
.product-detail__variant-picker{margin-bottom:12px !important}
.product-detail__buy-buttons{margin-top:6px !important;margin-bottom:12px !important}
/* Collapse any block-wrapper that ends up empty after we hide theme blocks */
.product-detail__container > *:empty,
.product-detail__info > *:empty{display:none}
@media(max-width:560px){
  .product-detail__title{font-size:24px;margin-bottom:6px !important}
  .product-detail__price{margin-bottom:4px !important}
  .tax-include{margin-bottom:8px !important}
  .product-addons{padding-bottom:12px !important;margin-bottom:12px !important;gap:18px !important}
  .product-detail__variant-picker{margin-bottom:10px !important}
  .product-detail__buy-buttons{margin-top:5px !important;margin-bottom:10px !important}
}

/* === Native +/- qty input HIDDEN on PDP — chip selector replaces it ===
   We keep the input in the DOM (form submission needs it) but visually hide.
   ATC stays full-width on its own row. */
form[action*="/cart/add"] .product-form__quantity{
  position:absolute !important;width:0 !important;height:0 !important;
  overflow:hidden !important;padding:0 !important;margin:0 !important;clip:rect(0,0,0,0);visibility:hidden
}
.product__submit-form-cart{display:flex !important;flex-wrap:wrap;gap:10px !important}
.product__submit-form-cart .button_buy-now{flex:1 1 100% !important;width:100% !important}

/* === PDP qty chips (1 · 2 · 5 · 10) === */
.tao-qty-chips{margin:8px 0 10px;font-family:inherit}
.tao-qty-chips .tao-qty-label{font-size:11px;font-weight:800;letter-spacing:.08em;text-transform:uppercase;color:#666;margin-bottom:8px;display:flex;align-items:baseline;gap:8px}
.tao-qty-chips .tao-qty-label .tao-qty-max{font-size:10px;font-weight:600;color:#999;letter-spacing:.02em;text-transform:none}
.tao-qty-chips .tao-qty-row{display:flex;gap:8px;flex-wrap:wrap;align-items:center}
/* Custom qty input — sits inline as a 5th option, accepts numbers up to max */
.tao-qty-chips .tao-qty-custom{
  position:relative;display:inline-flex;align-items:center;
  flex:1 1 auto;min-width:80px;height:46px;
  border:1.5px dashed #ede9df;border-radius:999px;
  padding:0 14px 0 16px;background:#fff;
  transition:border-color .15s,background .15s
}
.tao-qty-chips .tao-qty-custom:hover{border-color:#c6e1cc;background:#f4f9f5}
.tao-qty-chips .tao-qty-custom.active{border-color:#0e855b;border-style:solid;background:#fff;box-shadow:0 2px 6px rgba(14,133,91,.18)}
.tao-qty-chips .tao-qty-custom .tao-qty-custom-prefix{
  font-size:11px;font-weight:700;color:#999;
  letter-spacing:.04em;text-transform:uppercase;
  padding-right:4px;flex-shrink:0
}
.tao-qty-chips .tao-qty-custom.active .tao-qty-custom-prefix{color:#0e855b}
.tao-qty-chips .tao-qty-custom input{
  flex:1;min-width:0;width:100%;height:100%;
  border:0;background:transparent;outline:none;
  font-size:15px;font-weight:700;color:#1a1a1a;
  font-variant-numeric:tabular-nums;
  text-align:center;padding:0;
  font-family:inherit;
  -moz-appearance:textfield
}
.tao-qty-chips .tao-qty-custom input::-webkit-inner-spin-button,
.tao-qty-chips .tao-qty-custom input::-webkit-outer-spin-button{-webkit-appearance:none;margin:0}
.tao-qty-chips .tao-qty-custom input::placeholder{color:#bbb;font-weight:500}
@media(max-width:560px){
  .tao-qty-chips .tao-qty-custom{height:44px;min-width:74px;padding:0 12px 0 14px}
  .tao-qty-chips .tao-qty-custom .tao-qty-custom-prefix{font-size:10px}
  .tao-qty-chips .tao-qty-custom input{font-size:14px}
}
.tao-qty-chip{
  flex:1 1 0;min-width:56px;
  height:46px;padding:0 16px;
  border:1.5px solid #ede9df;background:#fff;color:#1a1a1a;
  border-radius:999px;font-size:15px;font-weight:700;
  font-variant-numeric:tabular-nums;letter-spacing:.02em;
  cursor:pointer;transition:background .15s,border-color .15s,color .15s,transform .08s,box-shadow .15s;
  font-family:inherit
}
.tao-qty-chip:hover{background:#f4f9f5;border-color:#c6e1cc}
.tao-qty-chip:active{transform:scale(.96)}
.tao-qty-chip.active{
  background:#0e855b;color:#fff;border-color:#0e855b;
  box-shadow:0 2px 6px rgba(14,133,91,.22)
}
.tao-qty-chip:focus-visible{outline:2px solid #0e855b;outline-offset:2px}
@media(max-width:560px){
  .tao-qty-chip{height:44px;font-size:14px;padding:0 14px;min-width:50px}
}

/* === Secondary "Build a X-pack" CTA — only for BYOB-eligible products === */
.tao-build-bundle-cta{
  display:flex;align-items:center;justify-content:center;gap:8px;
  width:100%;margin:0 0 16px;padding:13px 18px;
  background:#fff;color:#0a6e4a;
  border:1.5px solid #0e855b;border-radius:999px;
  font-size:14px;font-weight:700;letter-spacing:.04em;
  cursor:pointer;transition:background .12s,transform .08s,box-shadow .12s;
  font-family:inherit;text-align:center;line-height:1.2
}
.tao-build-bundle-cta:hover{background:#f4f9f5;box-shadow:0 3px 12px rgba(14,133,91,.18)}
.tao-build-bundle-cta:active{transform:scale(.97)}
.tao-build-bundle-cta strong{color:#0a6e4a;font-weight:800}
.tao-build-bundle-cta .tao-bb-icon{
  display:inline-flex;align-items:center;justify-content:center;
  width:20px;height:20px;border-radius:50%;
  background:#0e855b;color:#fff;font-size:14px;font-weight:800;line-height:1
}
.tao-build-bundle-cta .tao-bb-arrow{color:#0a6e4a;font-weight:800;transition:transform .15s}
.tao-build-bundle-cta:hover .tao-bb-arrow{transform:translateX(3px)}
@media(max-width:560px){
  .tao-build-bundle-cta{padding:12px 16px;font-size:13px}
  .tao-build-bundle-cta .tao-bb-icon{width:18px;height:18px;font-size:12px}
}

/* Old ladder — dormant; if any cached page still renders it, hide. */
.tao-bb-ladder{display:none !important}

.tao-sp{display:grid;grid-template-columns:1fr 1fr;gap:0;margin:6px 0 8px;padding:0;background:#fff;border:1px solid #e9e3d3;border-radius:14px;font-family:inherit;overflow:hidden;box-shadow:0 1px 3px rgba(0,0,0,.04)}
.tao-sp-row{display:flex;align-items:center;gap:10px;padding:11px 14px;font-size:13px;color:#3a3a3a;line-height:1.3}
.tao-sp-row + .tao-sp-row{border-left:1px solid #f1ede2}
.tao-sp-row .count{color:#111;font-weight:800;font-variant-numeric:tabular-nums;letter-spacing:-.01em}
.tao-sp-row .label{color:#666;font-size:12px}
.tao-sp .icon{flex-shrink:0;width:28px;height:28px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:14px}
.tao-sp .icon.fire{background:#fef3f3;color:#e63946}
.tao-sp .icon.fire::before{content:'\1F525'}
.tao-sp .icon.eye{background:#f1f8f3;color:#0e855b;position:relative}
.tao-sp .icon.eye::before{content:'\1F441';font-size:13px}
.tao-sp .icon.eye::after{content:'';position:absolute;top:2px;right:2px;width:7px;height:7px;background:#0e855b;border:2px solid #fff;border-radius:50%;animation:tao-sp-pulse 2s ease-in-out infinite}
@keyframes tao-sp-pulse{0%,100%{box-shadow:0 0 0 0 rgba(14,133,91,.55)}50%{box-shadow:0 0 0 5px rgba(14,133,91,0)}}
.tao-sp .stack{display:flex;flex-direction:column;line-height:1.15;min-width:0}
@media(max-width:560px){
  .tao-sp{grid-template-columns:1fr;gap:0}
  .tao-sp-row + .tao-sp-row{border-left:0;border-top:1px solid #f1ede2}
  .tao-sp-row{padding:10px 13px;font-size:12.5px}
  .tao-sp .icon{width:26px;height:26px}
  .tao-sp-row .label{font-size:11.5px}
}



/* Hide theme's built-in free-ship/threshold bar — we render our own */
.free-ship-progress-bar,
[class*="free-ship-progress" i],
[class*="cart_threshold" i],
[class*="cart_shipping" i]:not(.cart-shipping-amount):not([class*="form"]),
.cart-progress.cart-shipping-progress,
.free-shipping-progress-bar,
.cart__shipping-progress,
.shipping-progress-bar { display: none !important; }

/* Hide the theme's bulky sticky add-to-cart bar on PDPs — we render our own slim bar instead */
sticky-add-cart{display:none !important}

/* === Standalone fixed-bottom progress bar (replaces sticky-add-cart on PDP) === */
.tao-sticky-progress{position:fixed;left:0;right:0;bottom:0;z-index:11;padding:9px 16px 10px;background:#faf8f3;border-top:1px solid #ede9df;box-shadow:0 -4px 14px -8px rgba(0,0,0,.12);font-family:inherit;font-size:12.5px;color:#3a3a3a;line-height:1.25;transform:translateY(100%);transition:transform .25s ease,opacity .2s ease;opacity:0;pointer-events:none}
.tao-sticky-progress.show{transform:translateY(0);opacity:1;pointer-events:auto}
.tao-sticky-progress .msg{display:flex;justify-content:space-between;align-items:center;gap:10px;margin-bottom:6px;font-weight:600}
.tao-sticky-progress .msg strong{color:#0e855b;font-weight:800}
.tao-sticky-progress .msg .unlocked{color:#0e855b}
.tao-sticky-progress .msg .pct{color:#999;font-weight:700;flex-shrink:0;font-variant-numeric:tabular-nums}
.tao-sticky-progress .bar{height:5px;background:#ebebeb;border-radius:999px;overflow:hidden}
.tao-sticky-progress .bar i{display:block;height:100%;background:linear-gradient(90deg,#ffc107 0%,#0e855b 100%);border-radius:999px;transition:width .4s cubic-bezier(.4,1.4,.6,1)}
@media(max-width:560px){.tao-sticky-progress{padding:8px 14px 9px;font-size:12px}.tao-sticky-progress .msg{margin-bottom:5px}}

/* === PDP Quantity Ladder === */
.tao-bb-ladder{margin:14px 0 18px;border:1px solid #ede9df;border-radius:12px;overflow:hidden;background:#fff;font-family:inherit}
.tao-bb-ladder__row{display:grid;grid-template-columns:auto 1fr auto;gap:14px;align-items:center;padding:13px 16px;border-bottom:1px solid #f1ede2;cursor:pointer;transition:background .12s}
.tao-bb-ladder__row:last-child{border-bottom:0}
.tao-bb-ladder__row:hover{background:#fafaf5}
.tao-bb-ladder__row.selected{background:#f4f9f5}
.tao-bb-ladder__radio{width:18px;height:18px;border:2px solid #cfcbb8;border-radius:50%;position:relative;flex-shrink:0}
.tao-bb-ladder__row.selected .tao-bb-ladder__radio{border-color:#0e855b}
.tao-bb-ladder__row.selected .tao-bb-ladder__radio::after{content:'';position:absolute;inset:3px;background:#0e855b;border-radius:50%}
.tao-bb-ladder__label{font-size:14px;font-weight:600;color:#111;display:flex;flex-direction:column;gap:2px}
.tao-bb-ladder__label .save{margin-left:8px;font-size:12px;font-weight:700;color:#0e855b}
.tao-bb-ladder__label .pop{display:inline-block;font-size:9px;font-weight:800;background:#0e855b;color:#fff;padding:2px 6px;border-radius:4px;margin-left:8px;letter-spacing:.06em;vertical-align:middle}
.tao-bb-ladder__label .per{font-size:11px;font-weight:500;color:#666;margin-top:2px}
.tao-bb-ladder__price{font-size:14px;font-weight:700;color:#111;font-variant-numeric:tabular-nums}

/* === Bundle Bridge Popup === */
.tao-bb{position:fixed;inset:0;background:rgba(0,0,0,.6);z-index:9998;display:none;align-items:center;justify-content:center;padding:14px;backdrop-filter:blur(2px)}
.tao-bb.open{display:flex;animation:tao-bb-fade .14s ease}
@keyframes tao-bb-fade{from{opacity:0}to{opacity:1}}
.tao-bb-card{position:relative;width:100%;max-width:520px;max-height:92vh;background:#fff;border-radius:20px;overflow-y:auto;-webkit-overflow-scrolling:touch;box-shadow:0 24px 60px -16px rgba(0,0,0,.4);animation:tao-bb-rise .16s ease}
/* Close button — large tap target, always visible at top-right */
.tao-bb-close{position:absolute;top:10px;right:10px;width:36px;height:36px;border-radius:50%;border:0;background:rgba(255,255,255,.95);color:#111;font-size:24px;line-height:1;font-weight:400;cursor:pointer;display:flex;align-items:center;justify-content:center;box-shadow:0 2px 8px rgba(0,0,0,.12);z-index:10;padding:0;transition:background .12s,transform .08s;-webkit-tap-highlight-color:transparent}
.tao-bb-close:hover{background:#fff;transform:scale(1.05)}
.tao-bb-close:active{transform:scale(.95)}
@media(max-width:560px){.tao-bb-close{top:8px;right:8px;width:32px;height:32px;font-size:22px}}
@keyframes tao-bb-rise{from{transform:translateY(14px);opacity:0}to{transform:translateY(0);opacity:1}}


.tao-bb-head{padding:24px 24px 8px}
.tao-bb-eyebrow{font-size:11px;font-weight:700;letter-spacing:.18em;text-transform:uppercase;color:#0e855b;margin:0 0 6px}
.tao-bb-title{font-size:22px;line-height:1.22;margin:0 0 6px;font-weight:700;color:#111;letter-spacing:-.012em}
.tao-bb-sub{font-size:14px;color:#666;margin:0}
.tao-bb-slots{display:flex;gap:8px;padding:16px 24px 8px;flex-wrap:wrap}
.tao-bb-slot{width:64px;height:64px;border-radius:10px;background:#faf8f3;border:2px dashed #d4d0bf;display:flex;align-items:center;justify-content:center;font-size:24px;color:#a09b85;position:relative;overflow:hidden;flex-shrink:0;transition:border-color .15s,transform .15s}
.tao-bb-slot.filled{border-style:solid;border-color:#0e855b;background:#fff;cursor:pointer}
.tao-bb-slot.filled img{width:100%;height:100%;object-fit:cover}
.tao-bb-slot.locked::after{content:'\2713';position:absolute;top:2px;right:4px;color:#fff;background:#0e855b;width:14px;height:14px;border-radius:50%;font-size:9px;display:flex;align-items:center;justify-content:center;font-weight:700}
.tao-bb-slot .rm{position:absolute;top:2px;right:2px;background:rgba(0,0,0,.6);color:#fff;border:none;width:18px;height:18px;border-radius:50%;font-size:11px;cursor:pointer;display:none;align-items:center;justify-content:center;padding:0;line-height:1}
.tao-bb-slot.filled:not(.locked):hover .rm{display:flex}
.tao-bb-progress{padding:0 24px 14px}
.tao-bb-progress .label{display:flex;justify-content:space-between;font-size:12px;font-weight:700;margin-bottom:6px}
.tao-bb-progress .label .done{color:#0e855b}
.tao-bb-progress .label .left{color:#666}
.tao-bb-progress .bar{height:6px;background:#ebebeb;border-radius:999px;overflow:hidden}
.tao-bb-progress .bar i{display:block;height:100%;background:linear-gradient(90deg,#ffc107,#0e855b);width:0;transition:width .35s cubic-bezier(.4,1.4,.6,1);border-radius:999px}
.tao-bb-progress .save{margin-top:8px;font-size:12px;color:#0e855b;font-weight:700;text-align:center}
.tao-bb-progress .save:empty{display:none}
.tao-bb-picks{padding:8px 24px 14px}
.tao-bb-picks h4{margin:0 0 10px;font-size:12px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:#666}
.tao-bb-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:8px}
@media(max-width:480px){.tao-bb-grid{grid-template-columns:repeat(2,1fr)}}
.tao-bb-pick{border:1px solid #ede9df;border-radius:12px;padding:6px 6px 8px;background:#fff;cursor:pointer;text-align:left;transition:all .15s ease;position:relative;display:flex;flex-direction:column;gap:2px;overflow:hidden}
.tao-bb-pick:hover{border-color:#0e855b;box-shadow:0 6px 14px -6px rgba(14,133,91,.25);transform:translateY(-1px)}
.tao-bb-pick img{width:100%;aspect-ratio:1/1;object-fit:cover;border-radius:8px;background:#faf8f3;display:block}
.tao-bb-pick .t{font-size:11.5px;font-weight:600;color:#111;line-height:1.3;margin-top:6px;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;padding:0 2px;min-height:28px}
.tao-bb-pick .prow{display:flex;align-items:center;gap:5px;padding:0 2px;margin-top:2px;flex-wrap:wrap}
.tao-bb-pick .p{font-size:12.5px;color:#111;font-weight:800}
.tao-bb-pick .pwas{font-size:10.5px;color:#999;text-decoration:line-through;text-decoration-color:#e63946}
.tao-bb-pick .ppct{font-size:9.5px;font-weight:800;background:#fef3f3;color:#e63946;padding:1px 5px;border-radius:3px;letter-spacing:.04em;margin-left:auto}
/* Selected state — whole tile is the toggle; checkmark badge signals "tap again to remove" */
.tao-bb-pick.added{border-color:#0e855b;background:#f4f9f5}
.tao-bb-pick.added::after{content:'\2713';position:absolute;top:6px;right:6px;width:22px;height:22px;background:#0e855b;color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:800;box-shadow:0 2px 6px rgba(14,133,91,.35)}
.tao-bb-pick.added:hover{box-shadow:0 6px 14px -6px rgba(230,57,70,.25);border-color:#e63946}
.tao-bb-pick.added:hover::after{content:'\00d7';background:#e63946;box-shadow:0 2px 6px rgba(230,57,70,.35)}
/* Grey-out non-selected tiles once the bundle is full so the picker reads as "done" */
.tao-bb-grid.full .tao-bb-pick:not(.added){opacity:.35;pointer-events:none;filter:grayscale(.6)}
.tao-bb-grid.full .tao-bb-pick:not(.added):hover{transform:none;border-color:#ede9df;box-shadow:none}
.tao-bb-foot{position:sticky;bottom:0;background:#fff;padding:14px 24px 18px;border-top:1px solid #ebebeb;box-shadow:0 -8px 20px -10px rgba(0,0,0,.1)}
.tao-bb-cta{display:block;width:100%;background:#0e855b;color:#fff;border:none;padding:14px;font-size:15px;font-weight:800;border-radius:12px;cursor:pointer;letter-spacing:.02em;transition:background .12s,transform .08s;box-shadow:0 4px 14px rgba(14,133,91,.3)}
.tao-bb-cta:hover{background:#0a6e4a}
.tao-bb-cta:active{transform:scale(.99)}
.tao-bb-cta:disabled{background:#bdb9a8;cursor:not-allowed;box-shadow:none}
.tao-bb-no{display:block;width:100%;margin-top:10px;padding:12px;background:#fafaf5;color:#444;border:1px solid #ede9df;border-radius:10px;font-size:13.5px;font-weight:600;letter-spacing:.02em;cursor:pointer;text-decoration:none;text-align:center;transition:all .14s ease;font-family:inherit}
.tao-bb-no:hover{background:#fff;color:#111;border-color:#cfcbb8}
.tao-bb-no:active{transform:scale(.99)}
.tao-bb-no.loading{background:#fff8e1;color:#5a4500;border-color:#f4e4a3}
.tao-bb-no.error{background:#fdecec;color:#8a1b13;border-color:#e63946}
body.tao-bb-open{overflow:hidden}
