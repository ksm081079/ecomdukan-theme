<script>
async function syncGiftWrapButtonState() {
  const giftBtn = document.getElementById('add-gift-wrap');
  if (!giftBtn) return;

  const variantId = giftBtn.dataset.variantId;
  if (!variantId) return;

  try {
    const cart = await fetch('/cart.js').then(r => r.json());
    const inCart = cart.items.find(i => i.variant_id == variantId);

    if (inCart) {
      giftBtn.innerText = 'Added';
      giftBtn.disabled = true;
    } else {
      giftBtn.innerText = 'Add A Gift Wrap';
      giftBtn.disabled = false;
    }
  } catch (err) {
    console.error('Failed to sync gift wrap button state', err);
  }
}

// Initial sync on page load
syncGiftWrapButtonState();

// Use event delegation so the button works even after the drawer re-renders
document.addEventListener('click', async (e) => {
  const giftBtn = e.target.closest('#add-gift-wrap');
  if (!giftBtn) return;

  e.preventDefault();

  const variantId = giftBtn.dataset.variantId;
  if (!variantId || giftBtn.disabled) return;

  giftBtn.disabled = true;

  try {
    const cart = await fetch('/cart.js').then(r => r.json());
    if (cart.items.find(i => i.variant_id == variantId)) {
      giftBtn.innerText = 'Added';
      return;
    }

    // ➕ Add product
    await fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: variantId, quantity: 1 })
    });

    // ✅ FORCE Dawn cart + bubble update
    const sections = await fetch('/?sections=cart-drawer,header').then(res => res.json());

    // Update drawer
    const drawer = document.querySelector('cart-drawer');
    if (drawer && sections['cart-drawer']) {
      drawer.renderContents({
        sections: { 'cart-drawer': sections['cart-drawer'] }
      });
    }

    // Update cart bubble
    const header = document.querySelector('#shopify-section-header');
    if (header && sections['header']) {
      header.innerHTML = sections['header'];
    }

    giftBtn.innerText = 'Added';
  } catch (err) {
    console.error(err);
    giftBtn.disabled = false;
  }
});

document.addEventListener('cart:refresh', async () => {
  const variantId = document.getElementById('add-gift-wrap')?.dataset.variantId;
  if (!variantId) return;

  const cart = await fetch('/cart.js').then(r => r.json());
  const gift = cart.items.find(i => i.variant_id == variantId);

  if (gift && gift.quantity > 1) {
    await fetch('/cart/change.js', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json'
      },
      body: JSON.stringify({
        id: gift.key,
        quantity: 1
      })
    });
  }

  await syncGiftWrapButtonState();
});
</script>
