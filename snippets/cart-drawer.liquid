<script>
  // Store added product IDs to avoid showing them again
  let addedProductIds = new Set();
  let allProducts = [];
  let currentIndex = 0;
  
  // Global function to refresh recommendations - can be called from anywhere
  window.refreshCartRecommendations = function() {
    fetch('/cart.js')
      .then(response => response.json())
      .then(cart => {
        if (typeof refreshRecommendationsSection === 'function') {
          refreshRecommendationsSection(cart);
        }
      })
      .catch(error => {
        console.error('Error refreshing recommendations:', error);
      });
  };
  
  // Listen for cart updates from anywhere (product pages, collection bundle, etc.)
  document.addEventListener('cart:updated', function() {
    // Wait a bit for cart to fully update, then refresh recommendations
    setTimeout(() => {
      if (typeof refreshRecommendationsSection === 'function') {
        fetch('/cart.js')
          .then(response => response.json())
          .then(cart => refreshRecommendationsSection(cart))
          .catch(() => {});
      }
    }, 300);
  });
  
  // Also listen to theme's pub/sub system
  if (window.subscribe && window.PUB_SUB_EVENTS) {
    window.subscribe(window.PUB_SUB_EVENTS.cartUpdate, function(event) {
      // Only refresh if update didn't come from recommendations (to avoid double refresh)
      if (event && event.source !== 'cart-drawer-recommendations') {
        setTimeout(() => {
          if (typeof refreshRecommendationsSection === 'function') {
            fetch('/cart.js')
              .then(response => response.json())
              .then(cart => refreshRecommendationsSection(cart))
              .catch(() => {});
          }
        }, 300);
      }
    });
  }

  // Make function globally accessible for onclick handlers
  window.addRecommendedProduct = function(button) {
    const variantId = button.getAttribute('data-variant-id');
    const productId = button.getAttribute('data-product-id');
    
    if (!variantId) {
      console.error('No product variant ID found');
      return;
    }

    // Show loading state immediately
    button.classList.add('loading');
    button.disabled = true;
    const btnText = button.querySelector('.btn-text');
    const originalText = btnText ? btnText.textContent : button.textContent;
    const productCard = button.closest('.cart-drawer__recommendation-item');

    // Optimistically update UI - remove card immediately for faster feel
    if (productCard) {
      productCard.style.transition = 'opacity 0.3s ease, transform 0.3s ease';
      productCard.style.opacity = '0.5';
    }

    // Add to cart
    fetch('/cart/add.js', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
      },
      body: JSON.stringify({
        items: [{
          id: variantId,
          quantity: 1
        }]
      })
    })
    .then(response => {
      if (!response.ok) {
        throw new Error('Failed to add to cart');
      }
      return response.json();
    })
    .then(data => {
      // Show success state immediately
      button.classList.remove('loading');
      button.classList.add('success');
      if (btnText) {
        btnText.textContent = 'Added';
      }
      
      // Mark product as added
      addedProductIds.add(productId);
      
      // Optimistically update cart count (increment by 1)
      const cartCountElements = document.querySelectorAll('.cart-count-bubble span, #cart-icon-bubble .count, [data-cart-count]');
      cartCountElements.forEach(el => {
        const currentCount = parseInt(el.textContent || el.getAttribute('data-cart-count') || '0', 10);
        const newCount = currentCount + 1;
        if (el.tagName === 'SPAN' || el.classList.contains('count')) {
          el.textContent = newCount;
        } else {
          el.setAttribute('data-cart-count', newCount);
        }
      });
      
      // Remove product card immediately with animation
      if (productCard && productCard.parentNode) {
        productCard.style.opacity = '0';
        productCard.style.transform = 'scale(0.9) translateY(-10px)';
        setTimeout(() => {
          if (productCard.parentNode) {
            productCard.remove();
            loadNextProduct();
          }
        }, 300);
      }
      
      // Immediately update cart drawer items - CRITICAL for cart to show up
      const routes = window.routes || { cart_url: '/cart' };
      fetch(`${routes.cart_url}?section_id=cart-drawer`)
        .then(response => response.text())
        .then(responseText => {
          const html = new DOMParser().parseFromString(responseText, 'text/html');
          
          // Update cart-drawer-items (the actual cart items list)
          const targetItems = document.querySelector('cart-drawer-items');
          const sourceItems = html.querySelector('cart-drawer-items');
          if (targetItems && sourceItems) {
            targetItems.replaceWith(sourceItems);
          }
          
          // Update cart drawer footer (totals, etc.)
          const targetFooter = document.querySelector('.cart-drawer__footer');
          const sourceFooter = html.querySelector('.cart-drawer__footer');
          if (targetFooter && sourceFooter) {
            targetFooter.innerHTML = sourceFooter.innerHTML;
          }
          
          // Update drawer footer container
          const targetDrawerFooter = document.querySelector('.drawer__footer');
          const sourceDrawerFooter = html.querySelector('.drawer__footer');
          if (targetDrawerFooter && sourceDrawerFooter) {
            const targetFooterContent = targetDrawerFooter.querySelector('.cart-drawer__footer');
            const sourceFooterContent = sourceDrawerFooter.querySelector('.cart-drawer__footer');
            if (targetFooterContent && sourceFooterContent) {
              targetFooterContent.innerHTML = sourceFooterContent.innerHTML;
            }
            
            const targetCtas = targetDrawerFooter.querySelector('.cart__ctas');
            const sourceCtas = sourceDrawerFooter.querySelector('.cart__ctas');
            if (targetCtas && sourceCtas) {
              targetCtas.innerHTML = sourceCtas.innerHTML;
            }
          }
          
          // Fetch cart data for count and events
          return fetch('/cart.js');
        })
        .then(response => response.json())
        .then(cart => {
          // Update cart count with actual value
          cartCountElements.forEach(el => {
            if (el.tagName === 'SPAN' || el.classList.contains('count')) {
              el.textContent = cart.item_count;
            } else {
              el.setAttribute('data-cart-count', cart.item_count);
            }
          });
          
          // Update cart icon bubble
          const cartIconBubble = document.querySelector('#cart-icon-bubble');
          if (cartIconBubble) {
            fetch(`${routes.cart_url}?section_id=cart-icon-bubble`)
              .then(response => response.text())
              .then(html => {
                const parser = new DOMParser();
                const doc = parser.parseFromString(html, 'text/html');
                const newBubble = doc.querySelector('#cart-icon-bubble');
                if (newBubble) {
                  cartIconBubble.innerHTML = newBubble.innerHTML;
                }
              })
              .catch(() => {});
          }
          
          // Trigger cart update event for other components
          if (window.publish && window.PUB_SUB_EVENTS) {
            window.publish(window.PUB_SUB_EVENTS.cartUpdate, { 
              source: 'cart-drawer-recommendations', 
              cartData: cart 
            });
          } else {
            document.dispatchEvent(new CustomEvent('cart:updated', { detail: { cart } }));
          }
          
          // Refresh recommendations in background
          if (typeof refreshRecommendationsSection === 'function') {
            setTimeout(() => {
              refreshRecommendationsSection(cart);
            }, 100);
          }
        })
        .catch(error => {
          console.error('Error updating cart drawer:', error);
          // Still try to trigger update event
          if (window.publish && window.PUB_SUB_EVENTS) {
            window.publish(window.PUB_SUB_EVENTS.cartUpdate, { 
              source: 'cart-drawer-recommendations', 
              cartData: data 
            });
          } else {
            document.dispatchEvent(new CustomEvent('cart:updated'));
          }
        });
    })
    .catch(error => {
      console.error('Error adding to cart:', error);
      // Restore UI on error
      if (productCard) {
        productCard.style.opacity = '1';
        productCard.style.transform = '';
      }
      button.classList.remove('loading');
      button.disabled = false;
      if (btnText) {
        btnText.textContent = 'Try Again';
        setTimeout(() => {
          btnText.textContent = originalText;
        }, 2000);
      } else {
        button.textContent = 'Try Again';
        setTimeout(() => {
          button.textContent = originalText;
        }, 2000);
      }
    });
  }

  // Function to refresh the recommendations section (optimized)
  function refreshRecommendationsSection(cart) {
    // Only refresh if cart has items and recommendations section exists
    const recommendationsSection = document.querySelector('.cart-drawer__recommendations');
    if (!recommendationsSection || !cart || cart.items.length === 0) {
      return;
    }
    
    // Fetch the cart drawer section to get updated recommendations
    fetch('/?section_id=cart-drawer')
          .then(response => {
            if (!response.ok) {
              throw new Error('Failed to fetch cart drawer section');
            }
            return response.text();
          })
          .then(html => {
            const parser = new DOMParser();
            const doc = parser.parseFromString(html, 'text/html');
            
            // Get the updated recommendations section
            const newRecommendations = doc.querySelector('.cart-drawer__recommendations');
            const currentRecommendations = document.querySelector('.cart-drawer__recommendations');
            
              if (newRecommendations && currentRecommendations) {
              console.log('Updating recommendations section...');
              
              // Store the current scroll position
              const grid = currentRecommendations.querySelector('#recommendations-grid');
              const scrollLeft = grid ? grid.scrollLeft : 0;
              
              // Update the recommendations section
              currentRecommendations.innerHTML = newRecommendations.innerHTML;
              
              // Restore scroll position
              const newGrid = currentRecommendations.querySelector('#recommendations-grid');
              if (newGrid && scrollLeft > 0) {
                newGrid.scrollLeft = scrollLeft;
              }
              
              // Remove products that are in cart (in case server didn't filter them)
              const cartProductIds = cart.items.map(item => item.product_id.toString());
              const recommendationItems = currentRecommendations.querySelectorAll('.cart-drawer__recommendation-item');
              
              recommendationItems.forEach(item => {
                const productId = item.getAttribute('data-product-id');
                if (productId && cartProductIds.includes(productId)) {
                  // Animate out and remove
                  item.style.transition = 'opacity 0.4s ease, transform 0.4s ease';
                  item.style.opacity = '0';
                  item.style.transform = 'scale(0.9) translateY(-10px)';
                  setTimeout(() => {
                    if (item.parentNode) {
                      item.remove();
                      // Load next product if available
                      loadNextProduct();
                    }
                  }, 400);
                }
              });
            } else {
              console.warn('Could not find recommendations section to update', {
                newRecommendations: !!newRecommendations,
                currentRecommendations: !!currentRecommendations
              });
            }
          })
          .catch(error => {
            console.error('Error refreshing recommendations:', error);
          });
      }
      
      // Function to reattach event listeners to recommendation buttons
      function reattachRecommendationListeners() {
        const buttons = document.querySelectorAll('.cart-drawer__recommendation-add-btn');
        buttons.forEach(button => {
          // Remove existing listeners and add new one
          const newButton = button.cloneNode(true);
          button.parentNode.replaceChild(newButton, button);
          newButton.addEventListener('click', function() {
            addRecommendedProduct(this);
          });
        });
      }
      
      // Fallback: manual update if theme system doesn't work
      function updateCartDrawerManually() {
        return fetch('/?section_id=cart-drawer')
          .then(response => response.text())
          .then(html => {
            const parser = new DOMParser();
            const doc = parser.parseFromString(html, 'text/html');
            
            // Update recommendations section
            const sectionsToUpdate = ['.cart-drawer__recommendations'];
            sectionsToUpdate.forEach(selector => {
              const newElement = doc.querySelector(selector);
              const currentElement = document.querySelector(selector);
              if (newElement && currentElement) {
                currentElement.innerHTML = newElement.innerHTML;
              }
            });
            
            // Reattach listeners after manual update
            setTimeout(() => {
              reattachRecommendationListeners();
              fetch('/cart.js')
                .then(response => response.json())
                .then(cart => {
                  removeProductsInCart(cart);
                });
            }, 100);

            return fetch('/cart.js')
              .then(response => response.json())
              .then(cart => {
                const cartCountElements = document.querySelectorAll('.cart-count-bubble span, #cart-icon-bubble .count, [data-cart-count]');
                cartCountElements.forEach(el => {
                  if (el.tagName === 'SPAN' || el.classList.contains('count')) {
                    el.textContent = cart.item_count;
                  } else {
                    el.setAttribute('data-cart-count', cart.item_count);
                  }
                });
                
                // Publish cart update event
                if (window.publish) {
                  const PUB_SUB_EVENTS = window.PUB_SUB_EVENTS || { cartUpdate: 'cart-update' };
                  window.publish(PUB_SUB_EVENTS.cartUpdate, { source: 'cart-drawer-recommendations', cartData: cart });
                }
                
                return cart;
              });
          });
      }
      
      // This function is no longer needed - using refreshRecommendationsSection instead
      // Keeping removeProductsInCart for backward compatibility
      function removeProductsInCart(cart) {
        const cartProductIds = cart.items.map(item => item.product_id.toString());
        const recommendationItems = document.querySelectorAll('.cart-drawer__recommendation-item');
        
        recommendationItems.forEach(item => {
          const productId = item.getAttribute('data-product-id');
          if (productId && cartProductIds.includes(productId)) {
            // Animate out and remove
            item.style.transition = 'opacity 0.4s ease, transform 0.4s ease';
            item.style.opacity = '0';
            item.style.transform = 'scale(0.9) translateY(-10px)';
            setTimeout(() => {
              if (item.parentNode) {
                item.remove();
                // Load next product if available
                loadNextProduct();
              }
            }, 400);
          }
        });
      }

  function loadNextProduct() {
    const grid = document.getElementById('recommendations-grid');
    if (!grid) return;

    // Get cart product IDs
    fetch('/cart.js')
      .then(response => response.json())
      .then(cart => {
        const cartProductIds = cart.items.map(item => item.product_id.toString());
        
        // Get the collection from settings or use fallback
        // Check if there's a data attribute or setting for the collection handle
        const recommendationsSection = document.querySelector('.cart-drawer__recommendations');
        let collectionHandle = 'all'; // Default fallback
        
        // Try to get collection from the recommendations section data or settings
        // The collection is set in theme settings: cart_drawer_recommendations_collection
        // We'll fetch from the same source the recommendations came from
        // Since we can't access Liquid variables in JS, we'll use a data attribute if available
        if (recommendationsSection && recommendationsSection.dataset.collectionHandle) {
          collectionHandle = recommendationsSection.dataset.collectionHandle;
        }
        
        // Fetch more products from the collection
        const collectionUrl = collectionHandle === 'all' 
          ? '/collections/all/products.json?limit=50'
          : `/collections/${collectionHandle}/products.json?limit=50`;
        
        fetch(collectionUrl)
          .then(response => {
            if (!response.ok) {
              // Fallback to all products if collection not found
              return fetch('/collections/all/products.json?limit=50');
            }
            return response;
          })
          .then(response => response.json())
          .then(data => {
            if (data.products && data.products.length > 0) {
              // Filter out already shown products and products in cart
              const existingIds = Array.from(document.querySelectorAll('.cart-drawer__recommendation-item'))
                .map(item => item.getAttribute('data-product-id'));
              
              const newProduct = data.products.find(p => {
                const productId = p.id.toString();
                return !existingIds.includes(productId) && 
                       !addedProductIds.has(productId) &&
                       !cartProductIds.includes(productId) &&
                       p.available; // Only show available products
              });

              if (newProduct) {
                addProductCard(newProduct);
              }
            }
          })
          .catch(error => {
            console.error('Error loading next product:', error);
            // Silently fail - don't show errors to user
          });
      })
      .catch(error => {
        console.error('Error fetching cart:', error);
        // Silently fail - don't show errors to user
      });
  }

  function formatMoney(cents) {
    // Use Shopify's money format from the theme
    // Try to use the theme's money format if available
    if (window.Shopify && window.Shopify.formatMoney) {
      return window.Shopify.formatMoney(cents, {{ shop.money_format | json }});
    }
    
    // Fallback: Use Intl.NumberFormat for proper currency formatting
    try {
      const currencyCode = '{{ cart.currency.iso_code }}' || '{{ shop.currency }}' || 'USD';
      const amount = cents / 100;
      return new Intl.NumberFormat('en-US', {
        style: 'currency',
        currency: currencyCode,
        minimumFractionDigits: 2,
        maximumFractionDigits: 2
      }).format(amount);
    } catch (e) {
      // Final fallback: simple format
      const amount = (cents / 100).toFixed(2);
      return '{{ cart.currency.symbol }}' + amount;
    }
  }

  function addProductCard(product) {
    const grid = document.getElementById('recommendations-grid');
    if (!grid) return;

    // Get price from product - Shopify returns it as a string like "69.00"
    const priceString = product.variants[0].price;
    const comparePriceString = product.variants[0].compare_at_price;
    
    // Convert string to number and multiply by 100 to get cents, then format
    const priceInCents = Math.round(parseFloat(priceString) * 100);
    const comparePriceInCents = comparePriceString ? Math.round(parseFloat(comparePriceString) * 100) : null;
    
    // Format using money formatter
    const formattedPrice = formatMoney(priceInCents);
    const formattedComparePrice = comparePriceInCents ? formatMoney(comparePriceInCents) : null;

    const productCard = document.createElement('div');
    productCard.className = 'cart-drawer__recommendation-item';
    productCard.setAttribute('data-product-id', product.id);
    productCard.style.opacity = '0';
    productCard.style.transform = 'scale(0.9)';
    
    productCard.innerHTML = `
      <div class="cart-drawer__recommendation-content">
        <a href="${product.handle ? '/products/' + product.handle : '#'}" class="cart-drawer__recommendation-link">
          ${product.images[0] ? `
            <div class="cart-drawer__recommendation-image-wrapper">
              <img
                src="${product.images[0].src}&width=200"
                alt="${product.title}"
                loading="lazy"
                width="100"
                height="100"
                class="cart-drawer__recommendation-image"
              >
            </div>
          ` : ''}
          <div class="cart-drawer__recommendation-info">
            <h4 class="cart-drawer__recommendation-title">${product.title}</h4>
            <div class="cart-drawer__recommendation-price">
              ${formattedComparePrice ? `<s class="cart-drawer__recommendation-compare-price">${formattedComparePrice}</s>` : ''}
              <span class="cart-drawer__recommendation-current-price">${formattedPrice}</span>
            </div>
          </div>
        </a>
        <button 
          type="button" 
          class="cart-drawer__recommendation-add-btn"
          data-variant-id="${product.variants[0].id}"
          data-product-id="${product.id}"
          onclick="addRecommendedProduct(this);"
        >
          <span class="btn-text">Add to Cart</span>
        </button>
      </div>
    `;

    grid.appendChild(productCard);
    
    // Add fade-in animation class
    productCard.classList.add('fade-in');
    
    // Scroll to show new product smoothly
    setTimeout(() => {
      productCard.scrollIntoView({ behavior: 'smooth', inline: 'end', block: 'nearest' });
    }, 100);
  }
</script>
