{%- comment -%}
  Ecomdukan product card — spec-led, square image, mono SKU, tier hint.
  Args:
    product (required) — Product object
    show_vendor (bool, optional) — show vendor under title
{%- endcomment -%}

{%- liquid
  assign first_variant = product.selected_or_first_available_variant
  assign sku = first_variant.sku | default: product.sku
  assign gsm = product.metafields.specs.gsm.value
  assign pack = product.metafields.specs.pack_qty.value
  assign tier_text = product.metafields.pricing.tiers.value
  assign is_low = false
  if first_variant.inventory_management == 'shopify' and first_variant.inventory_quantity > 0 and first_variant.inventory_quantity < 20
    assign is_low = true
  endif
-%}

<a href="{{ product.url }}" class="ed-product-card" style="display: block; background: var(--ed-snow); border: 1.5px solid var(--ed-ink); border-radius: 2px; text-decoration: none; color: var(--ed-ink); transition: border-width 120ms; overflow: hidden;">
  <div style="position: relative; aspect-ratio: 1/1; background: var(--ed-paper); overflow: hidden; border-bottom: 1.5px solid var(--ed-ink);">
    {%- if product.featured_media -%}
      {{ product.featured_media | image_url: width: 800 | image_tag:
        loading: 'lazy',
        widths: '300, 500, 800',
        sizes: '(min-width: 990px) 25vw, (min-width: 600px) 50vw, 100vw',
        alt: product.featured_media.alt | default: product.title,
        style: 'width:100%;height:100%;object-fit:cover;display:block;'
      }}
    {%- else -%}
      <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;">
        <img src="{{ 'ed-mark.svg' | asset_url }}" alt="" style="width: 60px; opacity: .25;">
      </div>
    {%- endif -%}

    {%- comment -%} Stock badge bottom-left {%- endcomment -%}
    <div style="position: absolute; bottom: 12px; left: 12px;">
      {%- if product.available -%}
        {%- if is_low -%}
          <span class="ed-badge ed-badge--low" style="background: var(--ed-paper);">Low stock</span>
        {%- else -%}
          <span class="ed-badge ed-badge--instock" style="background: var(--ed-paper);">In stock</span>
        {%- endif -%}
      {%- else -%}
        <span class="ed-badge ed-badge--oos" style="background: var(--ed-paper);">Sold out</span>
      {%- endif -%}
    </div>

    {%- if product.tags contains 'new' -%}
      <div style="position: absolute; top: 12px; left: 12px;">
        <span class="ed-badge ed-badge--new" style="background: var(--ed-paper);">New</span>
      </div>
    {%- endif -%}
  </div>

  <div style="padding: 16px;">
    {%- if sku != blank -%}
      <p class="ed-sku" style="margin: 0 0 6px;">{{ sku }}</p>
    {%- endif -%}
    <h3 class="ed-title" style="margin: 0 0 8px; font-size: 16px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">{{ product.title }}</h3>

    {%- if gsm or pack -%}
      <p class="ed-mono" style="color: var(--ed-text-mute); margin: 0 0 12px; font-size: 12px;">
        {%- if gsm %}{{ gsm }} GSM{%- endif -%}
        {%- if gsm and pack %} · {%- endif -%}
        {%- if pack %}{{ pack }}/pack{%- endif -%}
      </p>
    {%- endif -%}

    <div style="display: flex; align-items: baseline; gap: 6px; flex-wrap: wrap;">
      {%- if product.price_varies -%}
        <span class="ed-mono" style="font-size: 11px; color: var(--ed-text-mute); text-transform: uppercase; letter-spacing: .06em;">From</span>
      {%- endif -%}
      <span class="ed-mono" style="font-size: 17px; font-weight: 600; color: var(--ed-ink);">{{ product.price_min | money }}</span>
    </div>
  </div>
</a>

<style>
  .ed-product-card:hover { border-width: 2.5px !important; }
</style>
