{%- comment -%}
  ED Product card — minimal rewrite.
  Renders Shopify's featured image as-is (no carousel, no drag), title, price.
  Args: product (required)
{%- endcomment -%}

{%- liquid
  assign variant = product.selected_or_first_available_variant
  assign price = variant.price
  assign compare_at = variant.compare_at_price
  assign on_sale = false
  if compare_at != blank and compare_at > price
    assign on_sale = true
    assign discount_pct = compare_at | minus: price | times: 100 | divided_by: compare_at
  endif
-%}

<a href="{{ product.url }}" class="ed-pc" data-product-id="{{ product.id }}" data-product-handle="{{ product.handle }}">
  <div class="ed-pc__media">
    {%- if product.featured_image -%}
      <img
        class="ed-pc__img"
        src="{{ product.featured_image | image_url: width: 600 }}"
        srcset="{{ product.featured_image | image_url: width: 300 }} 300w,
                {{ product.featured_image | image_url: width: 600 }} 600w,
                {{ product.featured_image | image_url: width: 900 }} 900w"
        sizes="(min-width: 990px) 25vw, (min-width: 600px) 33vw, 50vw"
        loading="lazy"
        alt="{{ product.featured_image.alt | default: product.title | escape }}"
        width="{{ product.featured_image.width }}"
        height="{{ product.featured_image.height }}"
      >
    {%- else -%}
      <div class="ed-pc__noimg">
        <img src="{{ 'ed-mark.svg' | asset_url }}" alt="" width="40">
      </div>
    {%- endif -%}
    {%- if on_sale -%}
      <span class="ed-pc__badge">−{{ discount_pct }}%</span>
    {%- endif -%}
    {%- unless product.available -%}
      <span class="ed-pc__soldout">Sold out</span>
    {%- endunless -%}
  </div>
  <div class="ed-pc__body">
    <h3 class="ed-pc__title">{{ product.title }}</h3>
    <div class="ed-pc__price">
      <span class="ed-pc__price-now">{{ price | money }}</span>
      {%- if on_sale -%}
        <s class="ed-pc__price-was">{{ compare_at | money }}</s>
      {%- endif -%}
    </div>
  </div>
</a>

<style>
  .ed-pc {
    display: flex;
    flex-direction: column;
    background: #fff;
    border: 1px solid var(--ed-border, #E0DBCF);
    border-radius: 12px;
    overflow: hidden;
    text-decoration: none;
    color: var(--ed-ink, #0A0B0E);
    transition: border-color 120ms, transform 120ms;
    height: 100%;
  }
  .ed-pc:hover {
    border-color: var(--ed-ink, #0A0B0E);
    transform: translateY(-2px);
  }
  .ed-pc__media {
    position: relative;
    width: 100%;
    aspect-ratio: 1 / 1;
    background: var(--ed-snow, #FBFAF6);
    overflow: hidden;
  }
  .ed-pc__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    pointer-events: none;
    user-select: none;
    -webkit-user-drag: none;
  }
  .ed-pc__noimg {
    width: 100%; height: 100%;
    display: flex; align-items: center; justify-content: center;
    opacity: 0.25;
  }
  .ed-pc__badge {
    position: absolute; top: 8px; right: 8px;
    background: var(--ed-electric, #1E5FFF);
    color: #fff;
    font-family: "IBM Plex Mono", monospace;
    font-weight: 700; font-size: 11px;
    padding: 3px 7px;
    border-radius: 6px;
    letter-spacing: 0.02em;
  }
  .ed-pc__soldout {
    position: absolute; bottom: 8px; left: 8px;
    background: rgba(10,11,14,0.85);
    color: #fff;
    font-family: "Inter", sans-serif;
    font-weight: 600; font-size: 10px;
    padding: 3px 8px;
    border-radius: 6px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .ed-pc__body {
    padding: 10px 12px 12px;
    display: flex;
    flex-direction: column;
    gap: 4px;
    flex: 1;
  }
  .ed-pc__title {
    margin: 0;
    font-family: "Inter", sans-serif;
    font-size: 13px; font-weight: 600;
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    color: var(--ed-ink, #0A0B0E);
  }
  .ed-pc__price {
    margin-top: auto;
    display: flex;
    align-items: baseline;
    gap: 6px;
  }
  .ed-pc__price-now {
    font-family: "IBM Plex Mono", monospace;
    font-weight: 700; font-size: 15px;
    color: var(--ed-ink, #0A0B0E);
  }
  .ed-pc__price-was {
    font-family: "IBM Plex Mono", monospace;
    font-size: 12px;
    color: var(--ed-text-mute, #5C6068);
    text-decoration: line-through;
  }
  @media (max-width: 749px) {
    .ed-pc__body { padding: 8px 10px 10px; }
    .ed-pc__title { font-size: 12px; }
    .ed-pc__price-now { font-size: 13px; }
    .ed-pc__price-was { font-size: 11px; }
    .ed-pc__badge { font-size: 10px; padding: 2px 5px; top: 6px; right: 6px; }
  }
</style>
