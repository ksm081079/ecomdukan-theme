{%- liquid
  assign wa_enabled = settings.whatsapp_floating_enabled
  assign wa_number = settings.whatsapp_number | default: ''
  assign wa_msg = settings.whatsapp_floating_message | default: 'Hi, I need help with my order.'
  assign wa_pos = settings.whatsapp_floating_position | default: 'bottom_right'
  assign wa_msg_encoded = wa_msg | url_encode
-%}

{%- if wa_enabled and wa_number != blank -%}
  <a
    class="ed-wa-float ed-wa-float--{{ wa_pos }}"
    href="https://wa.me/{{ wa_number }}?text={{ wa_msg_encoded }}"
    target="_blank"
    rel="noopener"
    aria-label="Chat on WhatsApp"
  >
    <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M.057 24l1.687-6.163a11.867 11.867 0 01-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.817 11.817 0 018.413 3.488 11.824 11.824 0 013.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892-1.99 0-3.951-.5-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 001.683 5.55l-.999 3.648 3.805-.897zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413z"/></svg>
  </a>

  <style>
    .ed-wa-float {
      position: fixed;
      bottom: 20px;
      z-index: 9998;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 56px;
      height: 56px;
      border-radius: 50%;
      background: #25D366;
      color: #fff;
      text-decoration: none;
      box-shadow: 0 6px 18px rgba(10, 11, 14, 0.18);
      transition: transform 150ms ease, background 150ms ease, box-shadow 150ms ease;
    }
    .ed-wa-float--bottom_right { right: 20px; }
    .ed-wa-float--bottom_left  { left: 20px; }
    .ed-wa-float:hover,
    .ed-wa-float:focus-visible {
      background: #1FB257;
      transform: translateY(-2px);
      box-shadow: 0 10px 22px rgba(10, 11, 14, 0.22);
      color: #fff;
    }
    @media (max-width: 749px) {
      .ed-wa-float {
        width: 52px;
        height: 52px;
        bottom: 16px;
      }
      .ed-wa-float--bottom_right { right: 16px; }
      .ed-wa-float--bottom_left  { left: 16px; }
    }
  </style>
{%- endif -%}
